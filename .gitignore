## .NET gitignore
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/
# Test results
TestResults/
[Cc]overage*/
*.coveragexml
*.coverage
# Rider
.idea/
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
# JetBrains Rider
*.sln.iml
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream

# Extension build output
/extensions/
.botnexus-agent
node_modules/

# BotNexus runtime credentials — never commit auth tokens or API keys
auth.json
.botnexus/auth.json
*.botnexus-auth
# Local config overrides that may contain secrets
botnexus.local.json
config.local.json
*.log
*.txt
# Keep tracked .txt files despite the *.txt rule above
!requirements.txt
!tests/**/Snapshots/*.txt
site/**/*
