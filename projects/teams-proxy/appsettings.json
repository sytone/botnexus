{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "TeamsProxy": {
    "AgentId": "",
    "SessionId": "",
    "BotClientId": "",
    "ManagedIdentityClientId": "",
    "ServiceBusFullyQualifiedNamespace": "",
