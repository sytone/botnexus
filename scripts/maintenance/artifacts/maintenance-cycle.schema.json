{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Maintenance cycle record",
  "type": "object",
  "required": [
    "schemaVersion",
    "environment",
    "cycleId",
    "criterionMet",
    "baseline",
    "actual",
    "comparative",
    "negativeControls",
    "treeReceipts",
    "prManifest",
    "events"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "environment": {
      "enum": [
        "preproduction",
        "production"
      ]
    },
    "cycleId": {
      "type": "string"
    },
    "criterionMet": {
      "type": "boolean"
    },
    "baseline": {
      "type": "object"
    },
    "actual": {
      "type": "object"
    },
    "comparative": {
      "type": "object"
    },
    "negativeControls": {
      "type": "object"
    },
    "treeReceipts": {
      "type": "array"
    },
    "prManifest": {
      "type": "array"
    },
    "events": {
      "type": "array"
    }
  }
}
