#!/bin/sh
# BotNexus pre-push hook (versioned; activate with scripts/repo/install-hooks.ps1)
# #1602 rides the push path: catch a core.bare/identity flip and repair it BEFORE the push
# touches the shared config, so a parallel worktree push cannot leave the canonical repo bare.
set -e
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo .)

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -File "$repo_root/scripts/repo/guard-bare.ps1" -Quiet || {
    echo "❌ core.bare guard could not repair the repo. Aborting push (#1602)."; exit 1; }
fi
bare=$(git config --local --get core.bare 2>/dev/null || echo false)
if [ "$bare" = "true" ]; then
  echo "❌ core.bare=true on a working clone (#1602). Aborting push. Run: git config core.bare false"; exit 1
fi
exit 0