{
  "openapi": "3.0.1",
  "info": {
    "title": "BotNexus Gateway",
    "version": "0.0.0.0"
  },
  "paths": {
    "/api/Agents": {
      "get": {
        "tags": [
          "Agents"
        ],
        "summary": "Lists all registered agents.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentDescriptor"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentDescriptor"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentDescriptor"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Agents"
        ],
        "summary": "Registers a new agent.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentDescriptor"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentDescriptor"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AgentDescriptor"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agents/{agentId}": {
      "get": {
        "tags": [
          "Agents"
        ],
        "summary": "Gets a specific agent by ID.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AgentDescriptor"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentDescriptor"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentDescriptor"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Agents"
        ],
        "summary": "Unregisters an agent.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Agents/{agentId}/sessions/{sessionId}/status": {
      "get": {
        "tags": [
          "Agents"
        ],
        "summary": "Gets the status of a running agent instance.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/AgentInstance"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentInstance"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/AgentInstance"
                }
              }
            }
          }
        }
      }
    },
    "/api/Agents/instances": {
      "get": {
        "tags": [
          "Agents"
        ],
        "summary": "Lists all active agent instances.",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentInstance"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentInstance"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AgentInstance"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Agents/{agentId}/sessions/{sessionId}/stop": {
      "post": {
        "tags": [
          "Agents"
        ],
        "summary": "Stops a specific agent instance.",
        "parameters": [
          {
            "name": "agentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": [
          "BotNexus.Gateway.Api"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Chat": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Sends a message to an agent and returns the complete response.\r\nFor streaming, connect via `ws://host/ws`.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Chat/steer": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Injects a steering message into an active agent run.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Chat/follow-up": {
      "post": {
        "tags": [
          "Chat"
        ],
        "summary": "Queues a follow-up message for an active agent session.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/AgentControlRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/config/validate": {
      "get": {
        "tags": [
          "Config"
        ],
        "summary": "Validates the platform configuration file and returns any errors.",
        "parameters": [
          {
            "name": "path",
            "in": "query",
            "description": "Optional explicit path to a config file. Defaults to `~/.botnexus/config.json`.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigValidationResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigValidationResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ConfigValidationResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sessions": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Lists sessions, optionally filtered by agent ID.",
        "parameters": [
          {
            "name": "agentId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GatewaySession"
                  }
                }
              },
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GatewaySession"
                  }
                }
              },
              "text/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/GatewaySession"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/Sessions/{sessionId}": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Gets a specific session by ID.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Sessions"
        ],
        "summary": "Deletes a session.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Sessions/{sessionId}/history": {
      "get": {
        "tags": [
          "Sessions"
        ],
        "summary": "Gets paginated session history for long-running conversations.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 0
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/SessionHistoryResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionHistoryResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionHistoryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sessions/{sessionId}/suspend": {
      "patch": {
        "tags": [
          "Sessions"
        ],
        "summary": "Suspends an active session.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              }
            }
          }
        }
      }
    },
    "/api/Sessions/{sessionId}/resume": {
      "patch": {
        "tags": [
          "Sessions"
        ],
        "summary": "Resumes a suspended session.",
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/GatewaySession"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AgentControlRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "nullable": true
          },
          "sessionId": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Agent control request payload."
      },
      "AgentDescriptor": {
        "required": [
          "agentId",
          "apiProvider",
          "displayName",
          "modelId"
        ],
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "modelId": {
            "type": "string",
            "nullable": true
          },
          "apiProvider": {
            "type": "string",
            "nullable": true
          },
          "systemPrompt": {
            "type": "string",
            "nullable": true
          },
          "systemPromptFile": {
            "type": "string",
            "nullable": true
          },
          "toolIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "subAgentIds": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "isolationStrategy": {
            "type": "string",
            "nullable": true
          },
          "maxConcurrentSessions": {
            "type": "integer",
            "format": "int32"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "nullable": true
          },
          "isolationOptions": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AgentInstance": {
        "required": [
          "agentId",
          "instanceId",
          "isolationStrategy",
          "sessionId"
        ],
        "type": "object",
        "properties": {
          "instanceId": {
            "type": "string",
            "nullable": true
          },
          "agentId": {
            "type": "string",
            "nullable": true
          },
          "sessionId": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "$ref": "#/components/schemas/AgentInstanceStatus"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastActiveAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "isolationStrategy": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "AgentInstanceStatus": {
        "enum": [
          0,
          1,
          2,
          3,
          4,
          5
        ],
        "type": "integer",
        "format": "int32"
      },
      "AgentResponseUsage": {
        "type": "object",
        "properties": {
          "inputTokens": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "outputTokens": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ChatRequest": {
        "type": "object",
        "properties": {
          "agentId": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "sessionId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Chat request payload."
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "usage": {
            "$ref": "#/components/schemas/AgentResponseUsage"
          }
        },
        "additionalProperties": false,
        "description": "Chat response payload."
      },
      "ConfigValidationResponse": {
        "type": "object",
        "properties": {
          "isValid": {
            "type": "boolean",
            "description": "Whether the configuration passed all validation rules."
          },
          "configPath": {
            "type": "string",
            "description": "Resolved path to the configuration file that was validated.",
            "nullable": true
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Validation errors, empty when IsValid is true.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Result of a platform configuration validation check."
      },
      "GatewaySession": {
        "required": [
          "agentId",
          "sessionId"
        ],
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "nullable": true
          },
          "agentId": {
            "type": "string",
            "nullable": true
          },
          "channelType": {
            "type": "string",
            "nullable": true
          },
          "callerId": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "$ref": "#/components/schemas/SessionStatus"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "history": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionEntry"
            },
            "nullable": true
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "nullable": true
            },
            "nullable": true
          },
          "nextSequenceId": {
            "type": "integer",
            "format": "int64"
          },
          "streamEventLog": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/GatewaySessionStreamEvent"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "GatewaySessionStreamEvent": {
        "type": "object",
        "properties": {
          "sequenceId": {
            "type": "integer",
            "format": "int64"
          },
          "payloadJson": {
            "type": "string",
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      },
      "SessionEntry": {
        "required": [
          "content",
          "role"
        ],
        "type": "object",
        "properties": {
          "role": {
            "type": "string",
            "nullable": true
          },
          "content": {
            "type": "string",
            "nullable": true
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "toolName": {
            "type": "string",
            "nullable": true
          },
          "toolCallId": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SessionHistoryResponse": {
        "type": "object",
        "properties": {
          "offset": {
            "type": "integer",
            "format": "int32"
          },
          "limit": {
            "type": "integer",
            "format": "int32"
          },
          "totalCount": {
            "type": "integer",
            "format": "int32"
          },
          "entries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SessionEntry"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "SessionStatus": {
        "enum": [
          0,
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      }
    }
  },
  "tags": [
    {
      "name": "Agents",
      "description": "REST API for agent registration and lifecycle management."
    },
    {
      "name": "Chat",
      "description": "REST endpoint for non-streaming chat. For real-time streaming, use the WebSocket endpoint."
    },
    {
      "name": "Config",
      "description": "REST API for platform configuration diagnostics."
    },
    {
      "name": "Sessions",
      "description": "REST API for session management — listing, inspecting, and deleting sessions."
    }
  ]
}