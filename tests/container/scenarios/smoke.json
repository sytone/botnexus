{
  "name": "Container Smoke Test",
  "description": "Verifies the gateway starts and its core APIs respond — no LLM calls required.",
  "timeout_seconds": 15,
  "agents": [],
  "steps": [
    {
      "action": "api_get",
      "path": "/health",
      "expected_status": 200,
      "expected_contains": "ok"
    },
    {
      "action": "api_get",
      "path": "/api/agents",
      "expected_status": 200
    },
    {
      "action": "api_get",
      "path": "/api/config",
      "expected_status": 200
    },
    {
      "action": "api_get",
      "path": "/api/config/validate",
      "expected_status": 200,
      "expected_contains": "isValid"
    },
    {
      "action": "api_get",
      "path": "/api/uptime",
      "expected_status": 200,
      "expected_contains": "startedAt"
    }
  ]
}
