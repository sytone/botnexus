{
  "name": "Rapid Fire Messages",
  "description": "Send 5 messages rapidly to one agent, verify all get responses",
  "timeout_seconds": 60,
  "agents": [
    {
      "id": "test-rapid",
      "display_name": "Rapid",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "Reply with exactly one word: OK"
    }
  ],
  "steps": [
    { "action": "send_message", "agent": "test-rapid", "content": "Msg 1", "label": "m1" },
    { "action": "send_message", "agent": "test-rapid", "content": "Msg 2", "label": "m2" },
    { "action": "send_message", "agent": "test-rapid", "content": "Msg 3", "label": "m3" },
    { "action": "wait_for_event", "type": "ContentDelta", "from_step": "m1", "timeout_seconds": 30 },
    { "action": "wait_for_event", "type": "ContentDelta", "from_step": "m2", "timeout_seconds": 30 },
    { "action": "wait_for_event", "type": "ContentDelta", "from_step": "m3", "timeout_seconds": 30 }
  ]
}