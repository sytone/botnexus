{
  "name": "Concurrent Agent Responses",
  "description": "Verify two agents respond independently without blocking",
  "timeout_seconds": 30,
  "agents": [
    {
      "id": "test-alpha",
      "display_name": "Alpha",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "You are Alpha. Reply with exactly: ALPHA_OK"
    },
    {
      "id": "test-beta", 
      "display_name": "Beta",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "You are Beta. Reply with exactly: BETA_OK"
    }
  ],
  "steps": [
    {
      "action": "send_message",
      "agent": "test-alpha",
      "content": "Hello Alpha",
      "label": "alpha-msg"
    },
    {
      "action": "send_message",
      "agent": "test-beta",
      "content": "Hello Beta",
      "label": "beta-msg"
    },
    {
      "action": "wait_for_events",
      "events": [
        { "type": "ContentDelta", "from_step": "alpha-msg" },
        { "type": "ContentDelta", "from_step": "beta-msg" }
      ],
      "timeout_seconds": 20
    },
    {
      "action": "assert",
      "condition": "both_responded",
      "steps": ["alpha-msg", "beta-msg"]
    }
  ]
}