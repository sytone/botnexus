{
  "name": "Session Reset and Reuse",
  "description": "Verify agent responds after session reset (sealed→active)",
  "timeout_seconds": 30,
  "agents": [
    {
      "id": "test-echo",
      "display_name": "Echo",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "Echo the user message back exactly."
    }
  ],
  "steps": [
    {
      "action": "send_message",
      "agent": "test-echo",
      "content": "Hello",
      "label": "first-msg"
    },
    {
      "action": "wait_for_event",
      "type": "ContentDelta",
      "from_step": "first-msg",
      "timeout_seconds": 15
    },
    {
      "action": "reset_session",
      "agent": "test-echo"
    },
    {
      "action": "send_message",
      "agent": "test-echo",
      "content": "After reset",
      "label": "second-msg"
    },
    {
      "action": "wait_for_event",
      "type": "ContentDelta",
      "from_step": "second-msg",
      "timeout_seconds": 15
    },
    {
      "action": "assert",
      "condition": "responded",
      "step": "second-msg"
    }
  ]
}