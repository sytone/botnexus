{
  "name": "MCP Tool Integration",
  "description": "Start a test MCP server, register an agent with MCP config pointing at it, verify agent can see and use the MCP tool",
  "timeout_seconds": 45,
  "mcp_servers": [
    { "name": "ping" }
  ],
  "agents": [
    {
      "id": "test-mcp-agent",
      "display_name": "MCP Test Agent",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "You have a tool called 'ping'. When the user says 'ping', call that tool. Report the tool result.",
      "extensions": {
        "botnexus-mcp": {
          "servers": {
            "ping": {
              "url": "{{mcp:ping}}"
            }
          }
        }
      }
    }
  ],
  "steps": [
    {
      "action": "send_message",
      "agent": "test-mcp-agent",
      "content": "ping",
      "label": "ping-msg"
    },
    {
      "action": "wait_for_event",
      "type": "ToolStart",
      "from_step": "ping-msg",
      "timeout_seconds": 20
    },
    {
      "action": "wait_for_event",
      "type": "ToolEnd",
      "from_step": "ping-msg",
      "timeout_seconds": 15
    },
    {
      "action": "wait_for_event",
      "type": "ContentDelta",
      "from_step": "ping-msg",
      "timeout_seconds": 15
    },
    {
      "action": "assert",
      "condition": "responded",
      "step": "ping-msg"
    }
  ]
}
