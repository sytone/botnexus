{
  "name": "Concurrent Tool Blocking — Parallel Tracks",
  "description": "Agent A runs tools (slow), Agent B replies instantly. Parallel tracks prove no cross-agent blocking.",
  "timeout_seconds": 60,
  "agents": [
    {
      "id": "test-tooluser",
      "display_name": "Tool User",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "When the user says 'search', use the bash tool to run: echo 'searching...' && sleep 3 && echo 'done'. Always use tools when asked."
    },
    {
      "id": "test-quickreply",
      "display_name": "Quick Reply",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "Reply with exactly one word: QUICK. Nothing else."
    }
  ],
  "tracks": [
    {
      "name": "Tool Agent (slow)",
      "steps": [
        { "action": "send_message", "agent": "test-tooluser", "content": "search for recent files", "label": "tool-msg" },
        { "action": "wait_for_event", "type": "ToolStart", "from_step": "tool-msg", "timeout_seconds": 20 },
        { "action": "wait_for_event", "type": "ToolEnd", "from_step": "tool-msg", "timeout_seconds": 30 }
      ]
    },
    {
      "name": "Quick Agent (fast)",
      "steps": [
        { "action": "send_message", "agent": "test-quickreply", "content": "hi", "label": "quick-msg" },
        { "action": "wait_for_event", "type": "ContentDelta", "from_step": "quick-msg", "timeout_seconds": 15 }
      ]
    }
  ],
  "steps": [
    {
      "action": "assert_timing",
      "description": "Quick agent must respond while tool agent is still executing",
      "fast_step": "quick-msg",
      "slow_step": "tool-msg"
    },
    {
      "action": "assert",
      "condition": "both_responded",
      "steps": ["tool-msg", "quick-msg"]
    }
  ]
}
