{
  "name": "Multi-MCP Server Loading",
  "description": "Start 3 MCP servers and verify all 3 inject tools into the agent",
  "timeout_seconds": 45,
  "mcp_servers": [
    { "name": "server-a" },
    { "name": "server-b" },
    { "name": "server-c" }
  ],
  "agents": [
    {
      "id": "test-multi-mcp",
      "display_name": "Multi MCP Agent",
      "model": "gpt-4.1",
      "provider": "github-copilot",
      "system_prompt": "You have multiple tools from MCP servers. When asked to ping, call any available 'ping' tool and report the result.",
      "extensions": {
        "botnexus-mcp": {
          "servers": {
            "alpha": { "url": "{{mcp:server-a}}" },
            "beta": { "url": "{{mcp:server-b}}" },
            "gamma": { "url": "{{mcp:server-c}}" }
          }
        }
      }
    }
  ],
  "steps": [
    {
      "action": "delay",
      "timeout_seconds": 5
    },
    {
      "action": "send_message",
      "agent": "test-multi-mcp",
      "content": "ping",
      "label": "ping-msg"
    },
    {
      "action": "wait_for_event",
      "type": "ToolStart",
      "from_step": "ping-msg",
      "timeout_seconds": 20
    },
    {
      "action": "wait_for_event",
      "type": "ContentDelta",
      "from_step": "ping-msg",
      "timeout_seconds": 15
    },
    {
      "action": "assert",
      "condition": "responded",
      "step": "ping-msg"
    }
  ]
}
