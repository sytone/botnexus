@inject HttpClient Http
@inject IJSRuntime JS
@inject IClientStateStore Store
@inject IGatewayRestClient RestClient
@implements IDisposable
@using System.Text.Json

@if (_showPanel)
{
    <div class="config-overlay" @onclick="Close" @onkeydown="HandleKeyDown" tabindex="-1">
        <div class="config-dialog" role="dialog" aria-modal="true" aria-labelledby="agent-config-title" @onclick:stopPropagation="true">
            <div class="config-header">
                <h3 id="agent-config-title">⚙ Agent Configuration</h3>
                <button class="config-close-btn" @onclick="Close">✕</button>
            </div>

            @if (_loading)
            {
                <div class="config-loading">
                    <div class="loading-spinner small"></div>
                    <span>Loading configuration…</span>
                </div>
            }
            else
            {
                <div class="config-body">
                    <div class="config-field">
                        <label>Agent ID</label>
                        <span class="config-value mono">@AgentId</span>
                    </div>

                    <div class="config-field">
                        <label>Display Name</label>
                        <span class="config-value">@Agent?.DisplayName</span>
                    </div>

                    <div class="config-field">
                        <label>Session ID</label>
                        <span class="config-value mono">@(Agent?.ActiveConversationSessionId ?? "—")</span>
                    </div>

                    <div class="config-field">
                        <label>Channel Type</label>
                        <span class="config-value">@(Agent?.ChannelType ?? "signalr")</span>
                    </div>

                    @if (_agentConfig is not null)
                    {
                        <div class="config-field">
                            <label>Model</label>
                            @if (_availableModels.Count > 0)
                            {
                                <select class="config-select" @bind="_selectedModel">
                                    @foreach (var model in _availableModels)
                                    {
                                        <option value="@model">@model</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <span class="config-value mono">@(_agentConfig.Model ?? "—")</span>
                            }
                        </div>

                        <div class="config-field">
                            <label>Provider</label>
                            <span class="config-value">@(_agentConfig.Provider ?? "—")</span>
                        </div>

                        <div class="config-field">
                            <label>Tool Count</label>
                            <div class="config-field-with-badge">
                                <span class="config-value">@_agentConfig.ToolCount</span>
                                @if (IsInherited("toolIds"))
                                {
                                    <span class="world-default-badge" title="Inherited from agents.defaults">World default</span>
                                }
                            </div>
                        </div>

                        @if (_agentConfig.MemoryEnabled.HasValue)
                        {
                            <div class="config-field">
                                <label>Memory</label>
                                <div class="config-field-with-badge">
                                    <span class="config-value">@(_agentConfig.MemoryEnabled.Value ? "Enabled" : "Disabled")</span>
                                    @if (IsInherited("memory.enabled"))
                                    {
                                        <span class="world-default-badge" title="Inherited from agents.defaults">World default</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (_agentConfig.HeartbeatEnabled.HasValue)
                        {
                            <div class="config-field">
                                <label>Heartbeat</label>
                                <div class="config-field-with-badge">
                                    <span class="config-value">@(_agentConfig.HeartbeatEnabled.Value ? "Enabled" : "Disabled")</span>
                                    @if (IsInherited("heartbeat.enabled"))
                                    {
                                        <span class="world-default-badge" title="Inherited from agents.defaults">World default</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (_agentConfig.HeartbeatIntervalMinutes.HasValue)
                        {
                            <div class="config-field">
                                <label>Heartbeat Interval</label>
                                <div class="config-field-with-badge">
                                    <span class="config-value">@_agentConfig.HeartbeatIntervalMinutes.Value min</span>
                                    @if (IsInherited("heartbeat.intervalMinutes"))
                                    {
                                        <span class="world-default-badge" title="Inherited from agents.defaults">World default</span>
                                    }
                                </div>
                            </div>
                        }

                        @if (_agentConfig.HasFileAccess)
                        {
                            <div class="config-field">
                                <label>File Access</label>
                                <div class="config-field-with-badge">
                                    <span class="config-value">Configured</span>
                                    @if (IsInherited("fileAccess"))
                                    {
                                        <span class="world-default-badge" title="Inherited from agents.defaults">World default</span>
                                    }
                                </div>
                            </div>
                        }

                        <div class="config-field">
                            <label>System Prompt Size</label>
                            <span class="config-value">@(_contextSize ?? "—")</span>
                        </div>
                    }

                    @if (_error is not null)
                    {
                        <div class="config-error">@_error</div>
                    }
                </div>

                <div class="config-actions">
                    @if (_availableModels.Count > 0 && _selectedModel != _agentConfig?.Model)
                    {
                        <button class="config-save-btn" @onclick="SaveModel" disabled="@_saving">
                            @(_saving ? "Saving…" : "Save Model")
                        </button>
                    }
                    <button class="cancel-btn" @onclick="Close">Close</button>
                </div>
            }
        </div>
    </div>
}

@code {

    protected override void OnInitialized()
    {
        Store.OnChanged += HandleStoreChanged;
    }

    private void HandleStoreChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= HandleStoreChanged;
    }
    [Parameter, EditorRequired]
    public string AgentId { get; set; } = default!;

    private AgentState? Agent => Store.GetAgent(AgentId);
    private bool _showPanel;
    private bool _loading;
    private bool _saving;
    private string? _error;
    private AgentConfigDto? _agentConfig;
    private List<string> _availableModels = [];
    private string _selectedModel = "";
    private string? _contextSize;
    private Dictionary<string, bool> _inheritedFields = new(StringComparer.OrdinalIgnoreCase);

    private bool IsInherited(string fieldPath) =>
        _inheritedFields.TryGetValue(fieldPath, out var inherited) && inherited;

    public async Task Open()
    {
        _showPanel = true;
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var apiBase = RestClient.ApiBaseUrl;
            if (apiBase is null || Agent is null)
                return;

            try
            {
                _agentConfig = await Http.GetFromJsonAsync<AgentConfigDto>($"{apiBase}agents/{AgentId}");
                _selectedModel = _agentConfig?.Model ?? "";
            }
            catch
            {
                _agentConfig = null;
            }

            try
            {
                var models = await Http.GetFromJsonAsync<List<string>>($"{apiBase}agents/{AgentId}/models");
                _availableModels = models ?? [];
            }
            catch
            {
                _availableModels = [];
            }

            await ComputeInheritanceBadgesAsync(apiBase);

            if (Agent.ActiveConversationSessionId is not null)
            {
                try
                {
                    var context = await Http.GetFromJsonAsync<ContextInfoDto>($"{apiBase}agents/{AgentId}/sessions/{Agent.ActiveConversationSessionId}/context");
                    _contextSize = context?.SystemPromptTokens is not null
                        ? $"{context.SystemPromptTokens:N0} tokens"
                        : "—";
                }
                catch
                {
                    _contextSize = "unavailable";
                }
            }
            else
            {
                _contextSize = "no active session";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load config: {ex.Message}";
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task ComputeInheritanceBadgesAsync(string apiBase)
    {
        _inheritedFields.Clear();
        try
        {
            var effective = await Http.GetFromJsonAsync<EffectiveAgentConfigResponse>($"{apiBase}config/agents/{AgentId}/effective");
            if (effective?.Sources is null) return;
            foreach (var (field, source) in effective.Sources)
                _inheritedFields[field] = string.Equals(source, "inherited", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            _inheritedFields.Clear();
        }
    }

    private void Close() => _showPanel = false;

    private void HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            Close();
    }

    private async Task SaveModel()
    {
        if (string.IsNullOrEmpty(_selectedModel) || RestClient.ApiBaseUrl is null)
            return;

        _saving = true;
        _error = null;

        try
        {
            var payload = new { model = _selectedModel };
            var response = await Http.PutAsJsonAsync($"{RestClient.ApiBaseUrl}agents/{AgentId}", payload);
            if (response.IsSuccessStatusCode)
            {
                if (_agentConfig is not null)
                    _agentConfig = _agentConfig with { Model = _selectedModel };
            }
            else
            {
                _error = $"Save failed: {response.StatusCode}";
            }
        }
        catch (Exception ex)
        {
            _error = $"Save failed: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private sealed class EffectiveAgentConfigResponse
    {
        public string? AgentId { get; init; }
        public bool DefaultsApplied { get; init; }
        public Dictionary<string, string>? Sources { get; init; }
    }

    private sealed record AgentConfigDto
    {
        public string? AgentId { get; init; }
        public string? DisplayName { get; init; }
        public string? Model { get; init; }
        public string? Provider { get; init; }
        public int ToolCount { get; init; }
        public bool? MemoryEnabled { get; init; }
        public bool? HeartbeatEnabled { get; init; }
        public int? HeartbeatIntervalMinutes { get; init; }
        public bool HasFileAccess { get; init; }
    }

    private sealed record ContextInfoDto
    {
        public int? SystemPromptTokens { get; init; }
        public int? TotalTokens { get; init; }
    }
}
