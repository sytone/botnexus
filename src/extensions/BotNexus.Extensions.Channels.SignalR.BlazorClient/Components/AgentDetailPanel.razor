    // Recompute the thinking/context option sets from the currently selected model, clearing any
    // now-invalid selection so the editor never persists a value the model cannot honour (#1705).
    private void RefreshModelCapabilities()
    {
        var selected = _models.FirstOrDefault(m => m.ModelId == _model?.ModelId);
        _supportedThinkingLevels = selected?.SupportedThinkingLevels ?? [];
        _supportedContextSizes = selected?.SupportedContextSizes ?? [];
        if (_model is not null)
        {
            if (_model.Thinking is not null && !_supportedThinkingLevels.Contains(_model.Thinking))
                _model.Thinking = null;
            if (_model.ContextWindow is not null && !_supportedContextSizes.Contains(_model.ContextWindow.Value))
                _model.ContextWindow = null;
        }
    }
