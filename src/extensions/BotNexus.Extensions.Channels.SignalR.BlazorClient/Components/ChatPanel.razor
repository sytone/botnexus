    // #1691: invoked from JS (chatScroll.observeTopForLoadMore) when the user scrolls near the top.
    // Fetches and prepends the next older page, preserving the visual scroll position so the view
    // does not jump. The shared paging logic lives in AgentInteractionService.LoadMoreHistoryAsync.
    [JSInvokable]
    public async Task OnScrolledToTop() => await LoadMoreHistory();

    private async Task LoadMoreHistory()
    {
        if (_isLoadingMore || ActiveConversationId is not { } convId)
            return;
        if (ActiveConversation is not { HasMoreHistory: true })
            return;

        _isLoadingMore = true;
        StateHasChanged();
        double previousHeight = 0;
        try
        {
            try { previousHeight = await JS.InvokeAsync<double>("chatScroll.captureScrollHeight", _messagesContainer); }
            catch (JSDisconnectedException) { }

            var added = await Interaction.LoadMoreHistoryAsync(AgentId, convId);

            // Suppress the auto-scroll-to-bottom that a message-count jump would otherwise trigger,
            // then pin the previously-visible message in place after the prepend renders.
            if (added > 0)
            {
                _lastRenderedMessageCount = Messages.Count;
                StateHasChanged();
                try { await JS.InvokeVoidAsync("chatScroll.restoreScrollAfterPrepend", _messagesContainer, previousHeight); }
                catch (JSDisconnectedException) { }
            }
        }
        finally
        {
            _isLoadingMore = false;
            StateHasChanged();
        }
    }


    private async Task HandleAskUserSubmit(AskUserPromptSubmission submission)
    {
        var prompt = PendingAskUserPrompt;
        if (prompt is null)
            return;

        _askUserError = null;
        prompt.IsSubmitting = true;
        Store.NotifyChanged();

        try
        {
            await Interaction.RespondToAskUserAsync(
                prompt.ConversationId,
                prompt.RequestId,
                submission.FreeFormText,
                submission.SelectedValues,
                submission.Cancelled);

            Store.ClearPendingAskUser(prompt.ConversationId);
            Store.AppendMessage(prompt.ConversationId, new ChatMessage("System", BuildAskUserSummary(submission), DateTimeOffset.UtcNow));
            _forceScrollNext = true;
        }
        catch (Exception ex)
        {
            prompt.IsSubmitting = false;
            _askUserError = $"Failed to submit response: {ex.Message}";
            Store.NotifyChanged();
        }
    }

    private Task HandleAskUserTimeout()
    {
        var prompt = PendingAskUserPrompt;
        if (prompt is null)
            return Task.CompletedTask;

        Store.ClearPendingAskUser(prompt.ConversationId);
        Store.AppendMessage(prompt.ConversationId, new ChatMessage("System", "Prompt timed out before you could answer.", DateTimeOffset.UtcNow));
        _forceScrollNext = true;
        return Task.CompletedTask;
    }

    private static string BuildAskUserSummary(AskUserPromptSubmission submission)
    {
        if (submission.Cancelled)
            return "You cancelled the prompt.";

        var selected = submission.SelectedValues is { Length: > 0 }
            ? string.Join(", ", submission.SelectedValues)
            : null;
        var freeForm = string.IsNullOrWhiteSpace(submission.FreeFormText) ? null : submission.FreeFormText.Trim();

        return (selected, freeForm) switch
        {
            (not null, not null) => $"You answered: {selected} | {freeForm}",
            (not null, null) => $"You answered: {selected}",
            (null, not null) => $"You answered: {freeForm}",
            _ => "You answered."
        };
    }

    private string GetSubAgentStatus() => IsStreaming ? "⏳ Running" : "✅ Completed";
