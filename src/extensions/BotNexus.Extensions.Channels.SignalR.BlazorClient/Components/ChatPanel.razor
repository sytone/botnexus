    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            // Focus-trap entry: when the tool pop-out modal opens, move focus into the
            // dialog so Esc / Tab are captured and screen readers land inside it.
            if (_toolModalOpen && !_toolModalFocused)
            {
                _toolModalFocused = true;
                try { await _toolModalDialog.FocusAsync(); } catch { }
            }
            else if (!_toolModalOpen && _toolModalFocused)
            {
                _toolModalFocused = false;
            }

            // Reset enter-prevention binding when textarea is recreated (read-only → interactive)
            var hasInlinePrompt = PendingAskUserPrompt is not null;
            if ((_wasReadOnly && !IsReadOnly) || (_hadAskUserPrompt && !hasInlinePrompt))
                _enterPreventionBound = false;
            _wasReadOnly = IsReadOnly;
            _hadAskUserPrompt = hasInlinePrompt;

            if (!_enterPreventionBound && !IsReadOnly && !hasInlinePrompt)
            {
                await JS.InvokeVoidAsync("chatScroll.preventEnterSubmit", _inputElement);
                _enterPreventionBound = true;
            }

            if (!_attachmentPasteBound && !IsReadOnly && !hasInlinePrompt)
            {
                _attachmentPasteRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("chatAttachments.bindPaste", _inputElement, _attachmentPasteRef);
                _attachmentPasteBound = true;
            }

            // #1691: attach the scroll-to-top observer once so scrolling up fetches the next older
            // page. Idempotent on the JS side too; bind only after the container exists.
            if (!_loadMoreObserverBound)
            {
                _loadMoreRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("chatScroll.observeTopForLoadMore", _messagesContainer, _loadMoreRef);
                _loadMoreObserverBound = true;
            }

            var needsRender = false;
            foreach (var msg in Messages.ToList())
            {
                if (ShouldRenderAsMarkdown(msg.Role) && !string.IsNullOrEmpty(msg.Content) && !_markdownCache.ContainsKey(msg.Id))
                {
                    var html = await JS.InvokeAsync<string>("BotNexus.renderMarkdown", msg.Content);
                    _markdownCache[msg.Id] = html;
                    needsRender = true;
                }
            }

            if (needsRender)
            {
                StateHasChanged();
                return;
            }

            await JS.InvokeVoidAsync("BotNexus.attachCodeCopyButtons", _messagesContainer);

            var isActive = AgentId == Store.ActiveAgentId;
            if (isActive && !_wasActive)
                _forceScrollNext = true;
            _wasActive = isActive;

            var currentConvId = ActiveConversation?.ConversationId;
            var currentCount = Messages.Count;
            if (currentConvId != _lastActiveConversationId)
            {
                _forceScrollNext = true;
                _lastActiveConversationId = currentConvId;
                _lastRenderedMessageCount = currentCount;
            }
            else if (currentCount > _lastRenderedMessageCount + 5)
            {
                _forceScrollNext = true;
                _lastRenderedMessageCount = currentCount;
            }
            else
            {
                _lastRenderedMessageCount = currentCount;
            }

            if (firstRender || _forceScrollNext)
            {
                _forceScrollNext = false;
                await JS.InvokeVoidAsync("chatScroll.forceScrollToBottom", _messagesContainer);
            }
            else
            {
                await JS.InvokeVoidAsync("chatScroll.scrollToBottom", _messagesContainer, IsStreaming);
            }
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        UpdateCommandPalette();

        if (e is { Key: "Enter", ShiftKey: false })
        {
            if (_showCommandPalette && _filteredCommands.Count > 0)
            {
                var cmd = _filteredCommands.FirstOrDefault(c => c.Name == _selectedCommand) ?? _filteredCommands[0];
                await ExecuteCommand(cmd);
                return;
            }

            if (IsStreaming)
                await SteerAgent();
            else
                await SendMessage();
        }
        else if (e is { Key: "Escape" })
        {
            if (_showCommandPalette)
                _showCommandPalette = false;
            else if (IsStreaming)
                await AbortAgent();
        }
        else if (e is { Key: "Tab" } && _showCommandPalette && _filteredCommands.Count > 0)
        {
            _inputText = _filteredCommands[0].Name + " ";
            _showCommandPalette = false;
        }
    }

    private async Task SendMessage()
    {
        var text = _inputText?.Trim() ?? string.Empty;
        if ((string.IsNullOrEmpty(text) && _attachments.Count == 0) || !IsConnected) return;
        var attachments = _attachments.ToArray();
        _inputText = ""; _attachments.Clear(); _attachmentError = null; _showCommandPalette = false; _forceScrollNext = true;
        if (attachments.Length == 0)
            await Interaction.SendMessageAsync(AgentId, text);
        else
            await Interaction.SendMessageAsync(AgentId, text, attachments);
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        var drafts = new List<DraftAttachment>();
        foreach (var file in e.GetMultipleFiles(AttachmentLimits.MaxCount + 1))
        {
            if (file.Size > AttachmentLimits.MaxFileBytes) { await AddDraftAttachmentsAsync([new(file.Name, file.ContentType, string.Empty, file.Size)]); continue; }
            await using var stream = file.OpenReadStream(AttachmentLimits.MaxFileBytes);
            using var memory = new MemoryStream(); await stream.CopyToAsync(memory);
            drafts.Add(new(file.Name, string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType, Convert.ToBase64String(memory.ToArray()), file.Size));
        }
        await AddDraftAttachmentsAsync(drafts);
    }

    [JSInvokable]
    public Task OnAttachmentsPasted(IReadOnlyList<DraftAttachment> attachments) => AddDraftAttachmentsAsync(attachments);

    public Task AddDraftAttachmentsAsync(IReadOnlyList<DraftAttachment> attachments)
    {
        _attachmentError = null;
        foreach (var attachment in attachments)
        {
            if (_attachments.Count >= AttachmentLimits.MaxCount) { _attachmentError = $"You can attach up to {AttachmentLimits.MaxCount} files."; break; }
            if (attachment.Size > AttachmentLimits.MaxFileBytes) { _attachmentError = $"{attachment.FileName} is too large. Maximum file size is {FormatBytes(AttachmentLimits.MaxFileBytes)}."; continue; }
            if (_attachments.Sum(x => x.Size) + attachment.Size > AttachmentLimits.MaxTotalBytes) { _attachmentError = $"Attachments exceed the {FormatBytes(AttachmentLimits.MaxTotalBytes)} total limit."; break; }
            _attachments.Add(attachment);
        }
        StateHasChanged(); return Task.CompletedTask;
    }
    private void RemoveAttachment(DraftAttachment attachment) { _attachments.Remove(attachment); _attachmentError = null; }
    private static string FormatBytes(long bytes) => bytes >= 1024 * 1024 ? $"{bytes / (1024d * 1024d):0.#} MB" : $"{Math.Max(1, bytes / 1024d):0.#} KB";

