@inject IJSRuntime JS
@inject IClientStateStore Store
@inject IAgentInteractionService Interaction
@inject IPortalPreferencesService Prefs
@inject ISlashCommandDispatcher CommandDispatcher
@implements IDisposable
@using System.Text.Json
@using System.Text.Encodings.Web
@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services.SlashCommands

<div class="chat-panel">
    <header class="chat-header">
        <div class="chat-header-left">
            <div class="chat-title-stack">
                <div class="chat-title-heading-row">
                    @if (HasActiveConversation)
                    {
                        @if (_editingTitle)
                        {
                            <input class="conversation-title-input conversation-title-h3"
                                   @bind="_titleDraft"
                                   @bind:event="oninput"
                                   @onblur="SaveTitle"
                                   @onkeydown="TitleKeyDown"
                                   maxlength="200" />
                        }
                        else
                        {
                            @if (IsReadOnly)
                            {
                                <h3 class="conversation-title" title="@ActiveConversationId">@ActiveConversationTitle</h3>
                            }
                            else
                            {
                                <h3 class="conversation-title editable" @onclick="StartEditTitle" title="@($"{ActiveConversationId} - click to rename")">@ActiveConversationTitle</h3>
                            }
                            @if (ActiveConversation?.IsDefault == true)
                            {
                                <span class="conversation-default-badge">Default</span>
                            }
                        }
                    }
                    else
                    {
                        <h3>@DisplayName</h3>
                    }
                </div>
            </div>

            @if (IsStreaming)
            {
                <span class="streaming-badge" data-testid="streaming-badge">Streaming…</span>
            }
        </div>
        <div class="chat-header-actions">
            <button class="toggle-btn @(!ShowThinking ? "toggled-off" : "")" data-testid="chat-thinking-toggle"
                    @onclick="ToggleThinking" title="Toggle thinking visibility">
                💭
            </button>
            <button class="toggle-btn @(!ShowTools ? "toggled-off" : "")" data-testid="chat-tools-toggle"
                    @onclick="ToggleTools" title="Toggle tool visibility">
                🔧
            </button>
            <button class="config-btn" data-testid="chat-config-btn" @onclick="OpenConfig" title="Agent configuration">
                ⚙
            </button>
            @if (!IsReadOnly)
            {
                <button class="new-chat-btn" data-testid="chat-new-session-btn" @onclick="ConfirmNewSession" title="Start a new session in this conversation"
                        disabled="@IsStreaming">
                    ↺ New session
                </button>
            }
        </div>
        <div class="chat-header-overflow">
            <button class="chat-header-overflow-trigger"
                    @onclick="ToggleMobileActionsMenu"
                    aria-expanded="@_showMobileActionsMenu"
                    aria-label="More chat actions"
                    title="More actions">
                ⋮
            </button>
            @if (_showMobileActionsMenu)
            {
                <div class="chat-header-overflow-menu">
                    <button class="toggle-btn @(!ShowThinking ? "toggled-off" : "")"
                            @onclick="ToggleThinkingFromMenu"
                            title="Toggle thinking visibility">
                        💭
                    </button>
                    <button class="toggle-btn @(!ShowTools ? "toggled-off" : "")"
                            @onclick="ToggleToolsFromMenu"
                            title="Toggle tool visibility">
                        🔧
                    </button>
                    <button class="config-btn" @onclick="OpenConfigFromMenu" title="Agent configuration">
                        ⚙
                    </button>
                    @if (!IsReadOnly)
                    {
                        <button class="new-chat-btn"
                                @onclick="ConfirmNewSessionFromMenu"
                                title="Start a new session in this conversation"
                                disabled="@IsStreaming">
                            ↺ New session
                        </button>
                    }
                </div>
            }
        </div>
        @if (!IsReadOnly)
        {
            <SessionControls AgentId="@AgentId" />
        }
    </header>

    @if (_showNewSessionConfirm)
    {
        <div class="reset-confirm-overlay" @onclick="CancelNewSession">
            <div class="reset-confirm-dialog" @onclick:stopPropagation="true">
                <p>Start a new session for <strong>@DisplayName</strong>?</p>
                <p class="text-muted">The current session will be sealed. History stays in this conversation.</p>
                <div class="reset-confirm-actions">
                    <button class="cancel-btn" @onclick="CancelNewSession">Cancel</button>
                    <button class="confirm-btn" @onclick="DoNewSession">New session</button>
                </div>
            </div>
        </div>
    }

    @if (_toolModalOpen)
    {
        <div class="tool-modal-overlay" data-testid="tool-modal-overlay"
             @onclick="CloseToolModal"
             @onkeydown="ToolModalKeyDown"
             tabindex="-1">
            <div class="tool-modal-dialog" role="dialog" aria-modal="true"
                 aria-label="@($"Tool {_toolModalTitle}")"
                 data-testid="tool-modal"
                 @onclick:stopPropagation="true"
                 @ref="_toolModalDialog">
                <div class="tool-modal-header">
                    <span class="tool-modal-title">@_toolModalTitle</span>
                    <button class="tool-modal-close" type="button"
                            data-testid="tool-modal-close"
                            title="Close" aria-label="Close"
                            @onclick="CloseToolModal">&#x2715;</button>
                </div>
                <pre class="tool-modal-content" data-testid="tool-modal-content">@_toolModalDecoded</pre>
            </div>
        </div>
    }

    @if (IsReadOnly)
    {
        <div class="read-only-banner" role="status" aria-label="Read-only sub-agent session view">
            <span class="read-only-badge">🔍 Sub-agent session</span>
            <span class="read-only-status @(IsStreaming ? "" : "completed")">@GetSubAgentStatus()</span>
            <span class="read-only-label">Read-only — you can observe but not interact</span>
        </div>
    }

    <div class="messages-container" data-testid="chat-messages" @ref="_messagesContainer">
        @if (HasMoreHistory)
        {
            <div class="history-load-more" data-testid="chat-load-more">
                @if (IsLoadingMore)
                {
                    <div class="loading-spinner small"></div>
                    <span>Loading older messages…</span>
                }
                else
                {
                    <button class="load-more-btn" data-testid="chat-load-more-btn" @onclick="LoadMoreHistory">
                        Load older messages
                    </button>
                }
            </div>
        }
        @if (IsLoadingHistory)
        {
            <div class="history-loading">
                <div class="loading-spinner small"></div>
                <span>Loading history…</span>
            </div>
        }

        @if (!HasActiveConversation && !IsLoadingConversations)
        {
            <div class="chat-empty-state">
                Select a conversation or start a new one.
            </div>
        }

        @if (HasActiveConversation && !IsLoadingHistory && HistoryLoadFailed && !HasMessages)
        {
            <div class="chat-empty-state chat-empty-state-error" data-testid="chat-history-error" role="alert">
                Could not load messages for this conversation. Try selecting it again or refreshing.
            </div>
        }
        else if (HasActiveConversation && !IsLoadingHistory && !HasMessages)
        {
            <div class="chat-empty-state chat-empty-state-empty" data-testid="chat-no-messages" role="status">
                No messages yet. Send a message to get started.
            </div>
        }

        @foreach (var msg in Messages)
        {
            @* Keyed wrapper: forces Blazor to diff message subtrees by identity, not list
               position. Without this, appending a committed message mid-stream (which changes
               the list length in the same render batch that removes the streaming bubble)
               causes positional diffing to retarget retained text nodes onto the wrong logical
               message, duplicating streamed fragments in the DOM (garbled live messages that
               render fine on reload-from-store). display:contents keeps layout unchanged. *@
            <div @key="msg.Id" style="display:contents">
            @if (msg.IsBoundary)
            {
                <div class="session-boundary" role="separator" aria-label="Session boundary">
                    <span class="session-boundary-line"></span>
                    <span class="session-boundary-label">@msg.BoundaryLabel</span>
                    <span class="session-boundary-line"></span>
                </div>
            }
            else if (msg.IsCompaction)
            {
                <div class="compaction-boundary" role="separator" aria-label="Context compacted" data-testid="compaction-boundary">
                    <span class="compaction-boundary-line"></span>
                    <span class="compaction-boundary-label">&#x1F4E6; @msg.BoundaryLabel</span>
                    <span class="compaction-boundary-line"></span>
                </div>
            }
            else if (msg.Role == "System")
            {
                <div class="system-message" data-testid="chat-system-message">@msg.Content</div>
            }
            else if (msg.IsToolCall)
            {
                <div class="message tool @(msg.ToolIsError == true ? "tool-error" : "") @(_expandedTools.Contains(msg.Id) ? "expanded" : "") @(!ShowTools ? "visibility-hidden" : "")"
                     style="@(!ShowTools ? "display:none" : "")">
                    <div class="tool-header" @onclick="() => ToggleToolDetails(msg.Id)">
                        <span class="tool-icon">@(msg.ToolResult is null ? "⏳" : (msg.ToolIsError == true ? "❌" : "✅"))</span>
                        <span class="tool-name">@ToolDescriptionFormatter.FormatDescription(msg.ToolName ?? "tool", msg.ToolArgs)</span>
                        @if (msg.ToolDuration is not null)
                        {
                            <span class="tool-duration">@FormatDuration(msg.ToolDuration.Value)</span>
                        }
                        <span class="tool-expand">@(_expandedTools.Contains(msg.Id) ? "▾" : "▸")</span>
                    </div>
                    @if (_expandedTools.Contains(msg.Id))
                    {
                        <div class="tool-details">
                            @if (msg.ToolArgs is not null)
                            {
                                <div class="tool-section">
                                    <div class="tool-section-header">
                                        <span class="tool-section-label">Arguments</span>
                                        <button class="tool-popout-btn"
                                                type="button"
                                                data-testid="tool-popout-args"
                                                title="Pop out arguments"
                                                aria-label="Pop out arguments"
                                                @onclick='() => OpenToolModal("Arguments", msg.ToolArgs)'>
                                            &#x2922;
                                        </button>
                                        <button class="tool-copy-btn @(_copiedSectionId == $"{msg.Id}-args" ? "copied" : "")"
                                                type="button"
                                                title="@(_copiedSectionId == $"{msg.Id}-args" ? "Copied!" : "Copy arguments")"
                                                aria-label="@(_copiedSectionId == $"{msg.Id}-args" ? "Copied!" : "Copy arguments")"
                                                @onclick="() => CopyToolSection(msg.Id, CopySectionArgs, msg.ToolArgs)">
                                            @(_copiedSectionId == $"{msg.Id}-args" ? "✓" : "📋")
                                        </button>
                                    </div>
                                    <pre class="tool-content">@msg.ToolArgs</pre>
                                </div>
                            }
                            @if (msg.ToolResult is not null)
                            {
                                <div class="tool-section">
                                    <div class="tool-section-header">
                                        <span class="tool-section-label">Result</span>
                                        <button class="tool-popout-btn"
                                                type="button"
                                                data-testid="tool-popout-result"
                                                title="Pop out result"
                                                aria-label="Pop out result"
                                                @onclick='() => OpenToolModal("Result", msg.ToolResult)'>
                                            &#x2922;
                                        </button>
                                        <button class="tool-copy-btn @(_copiedSectionId == $"{msg.Id}-result" ? "copied" : "")"
                                                type="button"
                                                title="@(_copiedSectionId == $"{msg.Id}-result" ? "Copied!" : "Copy result")"
                                                aria-label="@(_copiedSectionId == $"{msg.Id}-result" ? "Copied!" : "Copy result")"
                                                @onclick="() => CopyToolSection(msg.Id, CopySectionResult, msg.ToolResult)">
                                            @(_copiedSectionId == $"{msg.Id}-result" ? "✓" : "📋")
                                        </button>
                                    </div>
                                    <pre class="tool-content">@msg.ToolResult</pre>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                @if (msg.Role == "Assistant" && !string.IsNullOrEmpty(msg.ThinkingContent))
                {
                    <div class="thinking-block @(!ShowThinking ? "visibility-hidden" : "")"
                         style="@(!ShowThinking ? "display:none" : "")">
                        <details open>
                            <summary class="thinking-summary">💭 Thinking…</summary>
                            <div class="thinking-content">@msg.ThinkingContent</div>
                        </details>
                    </div>
                }

                @if (!(msg.Role == "Assistant" && string.IsNullOrEmpty(msg.Content) && !string.IsNullOrEmpty(msg.ThinkingContent)))
                {
                <div class="message @msg.CssClass"
                     data-testid="message"
                     data-message-role="@msg.Role">
                    <div class="message-header">
                        <span class="message-role">@msg.Role</span>
                        <div class="message-meta">
                            <span class="message-time">@FormatTimestamp(msg.Timestamp)</span>
                            @if (msg.Role == "Assistant" && !string.IsNullOrWhiteSpace(msg.Content))
                            {
                                <button class="msg-copy-btn @(_copiedMessageId == msg.Id ? "copied" : "")"
                                        type="button"
                                        title="@(_copiedMessageId == msg.Id ? "Copied!" : "Copy message")"
                                        aria-label="@(_copiedMessageId == msg.Id ? "Copied!" : "Copy message")"
                                        @onclick="() => CopyMessage(msg.Id, msg.Content)">
                                    @(_copiedMessageId == msg.Id ? "✓" : "📋")
                                </button>
                            }
                        </div>
                    </div>
                    @if (msg.Role == "Assistant" && (msg.InputTokens.HasValue || msg.CacheRead.HasValue || msg.CacheWrite.HasValue))
                    {
                        <div class="msg-token-stats" data-testid="msg-token-stats" title="Token usage for this message">
                            @if (msg.InputTokens.HasValue)
                            {
                                <span class="token-stat token-stat-input" data-testid="token-stat-input" title="Input tokens">&#8679; @(msg.InputTokens.Value.ToString("N0"))</span>
                            }
                            @if (msg.OutputTokens.HasValue)
                            {
                                <span class="token-stat token-stat-output" data-testid="token-stat-output" title="Output tokens">&#8681; @(msg.OutputTokens.Value.ToString("N0"))</span>
                            }
                            @if (msg.CacheRead.HasValue && msg.CacheRead.Value > 0)
                            {
                                <span class="token-stat token-stat-cache-read" data-testid="token-stat-cache-read" title="Cache read tokens">&#127991; @(msg.CacheRead.Value.ToString("N0"))</span>
                            }
                            @if (msg.CacheWrite.HasValue && msg.CacheWrite.Value > 0)
                            {
                                <span class="token-stat token-stat-cache-write" data-testid="token-stat-cache-write" title="Cache write tokens">&#128204; @(msg.CacheWrite.Value.ToString("N0"))</span>
                            }
                        </div>
                    }                    @if (ShouldRenderAsMarkdown(msg.Role) && _markdownCache.TryGetValue(msg.Id, out var rendered))
                    {
                        <div class="msg-content">@((MarkupString)rendered)</div>
                    }
                    else
                    {
                        <div class="message-content">@msg.Content</div>
                    }
                </div>
                }
            }
            </div>
        }

        @if (IsMessageStreaming && !string.IsNullOrEmpty(ThinkingBuffer))
        {
            <div class="thinking-block live @(!ShowThinking ? "visibility-hidden" : "")"
                 style="@(!ShowThinking ? "display:none" : "")">
                <details open>
                    <summary class="thinking-summary">💭 Thinking… <span class="streaming-indicator">●</span></summary>
                    <div class="thinking-content">@ThinkingBuffer</div>
                </details>
            </div>
        }

        @if (IsMessageStreaming && !string.IsNullOrEmpty(CurrentStreamBuffer))
        {
            <div class="message assistant streaming"
                 @key="@("__streaming__")"
                 data-testid="streaming-message"
                 data-message-role="Assistant">
                <div class="message-header">
                    <span class="message-role">Assistant</span>
                    <span class="message-time">now</span>
                </div>
                <div class="message-content">@CurrentStreamBuffer</div>
                <span class="streaming-indicator">●</span>
            </div>
        }
    </div>

    <SteeringQueuePanel ConversationId="@ActiveConversationId" />

    @if (_showCommandPalette)
    {
        <div class="command-palette" data-testid="command-palette">
            @foreach (var cmd in _filteredCommands)
            {
                <button class="command-item @(cmd.Name == _selectedCommand ? "selected" : "")"
                        @onclick="() => ExecuteCommand(cmd)">
                    <span class="command-name">@cmd.Name</span>
                    <span class="command-desc">@cmd.Description</span>
                </button>
            }
        </div>
    }

    @if (!IsReadOnly && PendingAskUserPrompt is not null)
    {
        <div class="chat-input-area ask-user-input-area">
            <AskUserPrompt Prompt="PendingAskUserPrompt"
                           ErrorMessage="_askUserError"
                           OnSubmit="HandleAskUserSubmit"
                           OnTimeout="HandleAskUserTimeout" />
        </div>
    }
    else
    {
        <div class="chat-input-area">
            @if (!IsReadOnly)
            {
                <textarea class="chat-input @ExpandingInputClass"
                          data-testid="chat-input"
                          @ref="_inputElement"
                          @bind="_inputText"
                          @bind:event="oninput"
                          @bind:after="HandleInputChanged"
                          @onkeydown="HandleKeyDown"
                          placeholder="@InputPlaceholder"
                          disabled="@(!IsConnected)" />

                <div class="attachment-composer">
                    <label class="attach-btn" data-testid="chat-attach" title="Attach files" aria-label="Attach files">&#x1F4CE;<InputFile class="attachment-input" OnChange="HandleFilesSelected" multiple /></label>
                    @foreach (var attachment in _attachments)
                    {
                        <span class="attachment-chip" data-testid="attachment-chip"><span class="attachment-name">@attachment.FileName</span><span class="attachment-size">@FormatBytes(attachment.Size)</span><button type="button" data-testid="attachment-remove" aria-label="@($"Remove {attachment.FileName}")" @onclick="() => RemoveAttachment(attachment)">&#x2715;</button></span>
                    }
                    @if (_attachmentError is not null) { <div class="attachment-error" role="alert">@_attachmentError</div> }
                </div>

                @if (IsStreaming)
                {
                    <button class="steer-btn" data-testid="chat-steer-btn"
                            @onclick="SteerAgent"
                            disabled="@(string.IsNullOrWhiteSpace(_inputText))"
                            title="Steer: inject this guidance at the next turn boundary (Enter)">
                        🔀 Steer
                    </button>
                    <button class="interrupt-steer-btn" data-testid="chat-redirect-btn"
                            @onclick="InterruptAndSteer"
                            disabled="@(string.IsNullOrWhiteSpace(_inputText))"
                            title="Redirect: stop the current step and steer with this message right away">
                        Redirect
                    </button>
                    <button class="followup-btn" data-testid="chat-followup-btn"
                            @onclick="FollowUpAgent"
                            disabled="@(string.IsNullOrWhiteSpace(_inputText))"
                            title="Follow Up: queue this message to run after the agent finishes the whole loop">
                        ➕ Follow Up
                    </button>
                    <button class="abort-btn" data-testid="chat-abort-btn"
                            @onclick="AbortAgent"
                            title="Stop the agent (Escape)">
                        ⏹ Stop
                    </button>
                }
                else
                {
                    <button class="send-btn"
                            data-testid="chat-send"
                            @onclick="SendMessage"
                            disabled="@(!IsConnected || (string.IsNullOrWhiteSpace(_inputText) && _attachments.Count == 0))">
                        Send
                    </button>
                }
            }
        </div>
    }
</div>

<AgentConfigPanel @ref="_configPanel" AgentId="@AgentId" />

@code {
    [Parameter, EditorRequired]
    public string AgentId { get; set; } = default!;

    private AgentState? Agent => Store.GetAgent(AgentId);

    protected override void OnInitialized()
    {
        Store.OnChanged += HandleStoreChanged;
    }

    private void HandleStoreChanged()
    {
        if (PendingAskUserPrompt is null)
            _askUserError = null;

        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Store.OnChanged -= HandleStoreChanged;
        _loadMoreRef?.Dispose();
        _attachmentPasteRef?.Dispose();
    }
    private ConversationState? ActiveConversation =>
        Agent?.ActiveConversationId is not null ? Agent.Conversations.GetValueOrDefault(Agent.ActiveConversationId) : null;

    private string DisplayName => Agent?.DisplayName ?? AgentId;
    private string? ActiveConversationId => Agent?.ActiveConversationId;
    private bool HasActiveConversation => ActiveConversation is not null;
    private string? ActiveConversationTitle => ActiveConversation?.Title;
private bool IsStreaming =>
        Agent?.ActiveConversationId is string activeConvId
            ? Store.GetStreamState(activeConvId).IsTurnActive
            : false; // no active conversation = not in turn
    private bool IsReadOnly => (Agent?.IsReadOnly ?? false) || (ActiveConversation?.IsVirtualSession ?? false);
    private bool IsConnected => Agent?.IsConnected ?? false;
    private bool ShowThinking => Agent?.ShowThinking ?? true;
    private bool ShowTools => Agent?.ShowTools ?? true;
    private bool IsLoadingConversations => Agent?.IsLoadingConversations ?? false;
    private bool IsLoadingHistory => ActiveConversation?.IsLoadingHistory ?? false;
    private string? ProcessingStage => Agent?.ProcessingStage;
    private IReadOnlyList<ChatMessage> Messages => ActiveConversation?.Messages ?? [];
    private bool HasMessages => Messages.Count > 0;
    private bool HistoryLoadFailed => ActiveConversation?.HistoryLoadFailed ?? false;
    private bool HasMoreHistory => ActiveConversation?.HasMoreHistory ?? false;
    private bool IsLoadingMore => _isLoadingMore;
    private AskUserPromptState? PendingAskUserPrompt =>
        ActiveConversationId is not null ? Store.GetPendingAskUser(ActiveConversationId) : null;
    // The broad IsStreaming (= IsTurnActive) keeps steer/stop controls visible across the whole
    // run loop, but it also flips true on RunStarted BEFORE the first token. Gating the live
    // streaming/thinking bubbles on that would paint a (now-cleared, but historically stale)
    // buffer as raw text in the pre-token window — the reported "prior reply flashes as raw
    // markdown after send". The bubbles must key off the narrow per-message streaming flag,
    // which MessageStart asserts only once real content is arriving (mirrors the mobile Chat.razor
    // guard). ClearBuffers on RunStarted is the belt; this guard is the braces.
    private bool IsMessageStreaming =>
        ActiveConversationId is string convId && Store.GetStreamState(convId).IsStreaming;
    private string ThinkingBuffer => ActiveConversation?.StreamState.ThinkingBuffer ?? string.Empty;
    private string CurrentStreamBuffer => ActiveConversation?.StreamState.Buffer ?? string.Empty;
    private string ExpandingInputClass => Prefs?.Current?.ExpandingInput == true ? "expanding" : string.Empty;

    private string _inputText = "";
    private readonly List<DraftAttachment> _attachments = [];
    private string? _attachmentError;
    private DotNetObjectReference<ChatPanel>? _attachmentPasteRef;
    private bool _attachmentPasteBound;
    private ElementReference _messagesContainer;
        private ElementReference _inputElement;
    // #1691: load-more (scroll-up pagination) state.
    private bool _isLoadingMore;
    private bool _loadMoreObserverBound;
    private DotNetObjectReference<ChatPanel>? _loadMoreRef;

    private async Task HandleInputChanged()
    {
        UpdateCommandPalette();
        if (Prefs?.Current?.ExpandingInput == true)
            await JS.InvokeVoidAsync("chatScroll.autoResizeTextarea", _inputElement, Prefs.Current.ExpandingInputMaxLines);
        // Update command palette on every input change so typing slash triggers it.
        UpdateCommandPalette();
    }

    private async Task ToggleExpandingInput()
        => await Prefs.SetExpandingInputAsync(!Prefs.Current.ExpandingInput);
    private bool _enterPreventionBound;
    private bool _wasReadOnly;
    private bool _hadAskUserPrompt;
    private AgentConfigPanel? _configPanel;
    private bool _editingTitle;
    private string _titleDraft = "";
    private readonly Dictionary<string, string> _markdownCache = new();

    // #1475: user and assistant messages both render through the Markdown pipeline.
    // Platform-generated roles (System, Tool, Error, Notification) stay on raw text rendering.
    private static bool ShouldRenderAsMarkdown(string? role) =>
        string.Equals(role, "Assistant", StringComparison.OrdinalIgnoreCase)
        || string.Equals(role, "User", StringComparison.OrdinalIgnoreCase);
    private readonly HashSet<string> _expandedTools = new();
    private bool _showCommandPalette;
    private string _selectedCommand = "";
    private bool _forceScrollNext;
    private bool _wasActive;
    private string? _lastActiveConversationId;
    private int _lastRenderedMessageCount;
    private bool _showNewSessionConfirm;
    private bool _showMobileActionsMenu;
    private string? _copiedMessageId;
    private string? _copiedSectionId;
    private string? _askUserError;
    private static readonly TimeSpan s_copyFeedbackDuration = TimeSpan.FromSeconds(2);
    private const string CopySectionArgs = "args";
    private const string CopySectionResult = "result";

    // ── Tool pop-out modal state ────────────────────────────────────────
    private bool _toolModalOpen;
    private string _toolModalTitle = "";
    private string _toolModalDecoded = "";
    private ElementReference _toolModalDialog;
    private bool _toolModalFocused;

    // #1949: the slash-command surface and its execute-mapping now live in the shared
    // BlazorClient.Core registry/dispatcher so desktop and mobile stay in lock-step.
    private IReadOnlyList<SlashCommand> _filteredCommands = [];
    private bool _cancellingTitle;

    private void StartEditTitle()
    {
        if (IsReadOnly)
            return;

        _titleDraft = ActiveConversationTitle ?? "";
        _editingTitle = true;
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("eval", "document.querySelector('.conversation-title-input')?.focus()"); }
            catch { }
        });
    }

    private async Task SaveTitle()
    {
        // If the user pressed Escape, the browser fires blur after keydown - ignore the save.
        if (_cancellingTitle)
        {
            _cancellingTitle = false;
            _editingTitle = false;
            StateHasChanged();
            return;
        }

        if (IsReadOnly)
        {
            _editingTitle = false;
            StateHasChanged();
            return;
        }

        _editingTitle = false;
        var draft = _titleDraft.Trim();
        if (!string.IsNullOrWhiteSpace(draft) && draft != ActiveConversationTitle)
            await Interaction.RenameConversationAsync(AgentId, ActiveConversationId, draft);
        else
            StateHasChanged();
    }

    private async Task TitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveTitle();
        else if (e.Key == "Escape")
        {
            // Set flag before StateHasChanged so the blur event fired by Escape is suppressed.
            _cancellingTitle = true;
            _titleDraft = ActiveConversationTitle ?? "";
            _editingTitle = false;
            StateHasChanged();
        }
    }

