@inject IJSRuntime JS
@inject IClientStateStore Store
@inject IAgentInteractionService Interaction
@implements IDisposable

<div class="chat-panel">
    <header class="chat-header">
        <div class="chat-header-left">
            <div class="chat-title-stack">
                <div class="chat-title-heading-row">
                    @if (HasActiveConversation)
                    {
                        @if (_editingTitle)
                        {
                            <input class="conversation-title-input conversation-title-h3"
                                   @bind="_titleDraft"
                                   @bind:event="oninput"
                                   @onblur="SaveTitle"
                                   @onkeydown="TitleKeyDown"
                                   maxlength="200" />
                        }
                        else
                        {
                            @if (IsReadOnly)
                            {
                                <h3 class="conversation-title">@ActiveConversationTitle</h3>
                            }
                            else
                            {
                                <h3 class="conversation-title editable" @onclick="StartEditTitle" title="Click to rename">@ActiveConversationTitle</h3>
                            }
                            @if (ActiveConversation?.IsDefault == true)
                            {
                                <span class="conversation-default-badge">Default</span>
                            }
                        }
                    }
                    else
                    {
                        <h3>@DisplayName</h3>
                    }
                </div>
            </div>

            @if (IsStreaming)
            {
                <span class="streaming-badge">Streaming…</span>
            }
        </div>
        <div class="chat-header-actions">
            <button class="toggle-btn @(!ShowThinking ? "toggled-off" : "")"
                    @onclick="ToggleThinking" title="Toggle thinking visibility">
                💭
            </button>
            <button class="toggle-btn @(!ShowTools ? "toggled-off" : "")"
                    @onclick="ToggleTools" title="Toggle tool visibility">
                🔧
            </button>
            <button class="config-btn" @onclick="OpenConfig" title="Agent configuration">
                ⚙
            </button>
            @if (!IsReadOnly)
            {
                <button class="new-chat-btn" @onclick="ConfirmNewSession" title="Start a new session in this conversation"
                        disabled="@IsStreaming">
                    ↺ New session
                </button>
            }
        </div>
        <div class="chat-header-overflow">
            <button class="chat-header-overflow-trigger"
                    @onclick="ToggleMobileActionsMenu"
                    aria-expanded="@_showMobileActionsMenu"
                    aria-label="More chat actions"
                    title="More actions">
                ⋮
            </button>
            @if (_showMobileActionsMenu)
            {
                <div class="chat-header-overflow-menu">
                    <button class="toggle-btn @(!ShowThinking ? "toggled-off" : "")"
                            @onclick="ToggleThinkingFromMenu"
                            title="Toggle thinking visibility">
                        💭
                    </button>
                    <button class="toggle-btn @(!ShowTools ? "toggled-off" : "")"
                            @onclick="ToggleToolsFromMenu"
                            title="Toggle tool visibility">
                        🔧
                    </button>
                    <button class="config-btn" @onclick="OpenConfigFromMenu" title="Agent configuration">
                        ⚙
                    </button>
                    @if (!IsReadOnly)
                    {
                        <button class="new-chat-btn"
                                @onclick="ConfirmNewSessionFromMenu"
                                title="Start a new session in this conversation"
                                disabled="@IsStreaming">
                            ↺ New session
                        </button>
                    }
                </div>
            }
        </div>
        @if (!IsReadOnly)
        {
            <SessionControls AgentId="@AgentId" />
        }
    </header>

    @if (_showNewSessionConfirm)
    {
        <div class="reset-confirm-overlay" @onclick="CancelNewSession">
            <div class="reset-confirm-dialog" @onclick:stopPropagation="true">
                <p>Start a new session for <strong>@DisplayName</strong>?</p>
                <p class="text-muted">The current session will be sealed. History stays in this conversation.</p>
                <div class="reset-confirm-actions">
                    <button class="cancel-btn" @onclick="CancelNewSession">Cancel</button>
                    <button class="confirm-btn" @onclick="DoNewSession">New session</button>
                </div>
            </div>
        </div>
    }

    @if (IsReadOnly)
    {
        <div class="read-only-banner" role="status" aria-label="Read-only sub-agent session view">
            <span class="read-only-badge">🔍 Sub-agent session</span>
            <span class="read-only-status @(IsStreaming ? "" : "completed")">@GetSubAgentStatus()</span>
            <span class="read-only-label">Read-only — you can observe but not interact</span>
        </div>
    }

    @if (IsStreaming && ProcessingStage is not null)
    {
        <div class="processing-status-bar">
            @ProcessingStage
        </div>
    }

    <div class="messages-container" @ref="_messagesContainer">
        @if (IsLoadingHistory)
        {
            <div class="history-loading">
                <div class="loading-spinner small"></div>
                <span>Loading history…</span>
            </div>
        }

        @if (!HasActiveConversation && !IsLoadingConversations)
        {
            <div class="chat-empty-state">
                Select a conversation or start a new one.
            </div>
        }

        @foreach (var msg in Messages)
        {
            @if (msg.IsBoundary)
            {
                <div class="session-boundary" role="separator" aria-label="Session boundary">
                    <span class="session-boundary-line"></span>
                    <span class="session-boundary-label">@msg.BoundaryLabel</span>
                    <span class="session-boundary-line"></span>
                </div>
            }
            else if (msg.Role == "System")
            {
                <div class="system-message">@msg.Content</div>
            }
            else if (msg.IsToolCall)
            {
                <div class="message tool @(msg.ToolIsError == true ? "tool-error" : "") @(_expandedTools.Contains(msg.Id) ? "expanded" : "") @(!ShowTools ? "visibility-hidden" : "")"
                     style="@(!ShowTools ? "display:none" : "")">
                    <div class="tool-header" @onclick="() => ToggleToolDetails(msg.Id)">
                        <span class="tool-icon">@(msg.ToolResult is null ? "⏳" : (msg.ToolIsError == true ? "❌" : "✅"))</span>
                        <span class="tool-name">@msg.ToolName</span>
                        @if (msg.ToolDuration is not null)
                        {
                            <span class="tool-duration">@FormatDuration(msg.ToolDuration.Value)</span>
                        }
                        <span class="tool-expand">@(_expandedTools.Contains(msg.Id) ? "▾" : "▸")</span>
                    </div>
                    @if (_expandedTools.Contains(msg.Id))
                    {
                        <div class="tool-details">
                            @if (msg.ToolArgs is not null)
                            {
                                <div class="tool-section">
                                    <span class="tool-section-label">Arguments</span>
                                    <pre class="tool-content">@msg.ToolArgs</pre>
                                </div>
                            }
                            @if (msg.ToolResult is not null)
                            {
                                <div class="tool-section">
                                    <span class="tool-section-label">Result</span>
                                    <pre class="tool-content">@msg.ToolResult</pre>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                @if (msg.Role == "Assistant" && !string.IsNullOrEmpty(msg.ThinkingContent))
                {
                    <div class="thinking-block @(!ShowThinking ? "visibility-hidden" : "")"
                         style="@(!ShowThinking ? "display:none" : "")">
                        <details>
                            <summary class="thinking-summary">💭 Thinking…</summary>
                            <div class="thinking-content">@msg.ThinkingContent</div>
                        </details>
                    </div>
                }

                <div class="message @msg.CssClass">
                    <div class="message-header">
                        <span class="message-role">@msg.Role</span>
                        <div class="message-meta">
                            <span class="message-time">@FormatTimestamp(msg.Timestamp)</span>
                            @if (msg.Role == "Assistant" && !string.IsNullOrWhiteSpace(msg.Content))
                            {
                                <button class="msg-copy-btn @(_copiedMessageId == msg.Id ? "copied" : "")"
                                        type="button"
                                        title="@(_copiedMessageId == msg.Id ? "Copied!" : "Copy message")"
                                        aria-label="@(_copiedMessageId == msg.Id ? "Copied!" : "Copy message")"
                                        @onclick="() => CopyMessage(msg.Id, msg.Content)">
                                    @(_copiedMessageId == msg.Id ? "✓" : "📋")
                                </button>
                            }
                        </div>
                    </div>
                    @if (msg.Role == "Assistant" && _markdownCache.TryGetValue(msg.Id, out var rendered))
                    {
                        <div class="msg-content">@((MarkupString)rendered)</div>
                    }
                    else
                    {
                        <div class="message-content">@msg.Content</div>
                    }
                </div>
            }
        }

        @if (IsStreaming && !string.IsNullOrEmpty(ThinkingBuffer))
        {
            <div class="thinking-block live @(!ShowThinking ? "visibility-hidden" : "")"
                 style="@(!ShowThinking ? "display:none" : "")">
                <details open>
                    <summary class="thinking-summary">💭 Thinking… <span class="streaming-indicator">●</span></summary>
                    <div class="thinking-content">@ThinkingBuffer</div>
                </details>
            </div>
        }

        @if (IsStreaming && !string.IsNullOrEmpty(CurrentStreamBuffer))
        {
            <div class="message assistant streaming">
                <div class="message-header">
                    <span class="message-role">Assistant</span>
                    <span class="message-time">now</span>
                </div>
                <div class="message-content">@CurrentStreamBuffer</div>
                <span class="streaming-indicator">●</span>
            </div>
        }
    </div>

    @if (_showCommandPalette)
    {
        <div class="command-palette">
            @foreach (var cmd in _filteredCommands)
            {
                <button class="command-item @(cmd.Name == _selectedCommand ? "selected" : "")"
                        @onclick="() => ExecuteCommand(cmd)">
                    <span class="command-name">@cmd.Name</span>
                    <span class="command-desc">@cmd.Description</span>
                </button>
            }
        </div>
    }

    <div class="chat-input-area">
        @if (!IsReadOnly)
        {
            <textarea class="chat-input"
                      @ref="_inputElement"
                      @bind="_inputText"
                      @bind:event="oninput"
                      @onkeydown="HandleKeyDown"
                      placeholder="@InputPlaceholder"
                      disabled="@(!IsConnected)" />
            @if (_isRecording)
            {
                <button class="recording-btn" @onclick="StopRecording" title="Stop recording">
                    🔴 Stop
                </button>
            }
            else
            {
                <button class="mic-btn" @onclick="StartRecording" title="Record audio message"
                        disabled="@(!IsConnected)">
                    🎤
                </button>
            }
            @if (IsStreaming)
            {
                <button class="steer-btn"
                        @onclick="SteerAgent"
                        disabled="@(string.IsNullOrWhiteSpace(_inputText))"
                        title="Redirect the agent's response (Shift+Enter for newline)">
                    🔀 Steer
                </button>
                <button class="abort-btn"
                        @onclick="AbortAgent"
                        title="Stop the agent (Escape)">
                    ⏹ Stop
                </button>
            }
            else
            {
                <button class="send-btn"
                        @onclick="SendMessage"
                        disabled="@(!IsConnected || string.IsNullOrWhiteSpace(_inputText))">
                    Send
                </button>
            }
        }
    </div>
</div>

<AgentConfigPanel @ref="_configPanel" AgentId="@AgentId" />

@code {
    [Parameter, EditorRequired]
    public string AgentId { get; set; } = default!;

    private AgentState? Agent => Store.GetAgent(AgentId);

    protected override void OnInitialized()
    {
        Store.OnChanged += HandleStoreChanged;
    }

    private void HandleStoreChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= HandleStoreChanged;
    }
    private ConversationState? ActiveConversation =>
        Agent?.ActiveConversationId is not null ? Agent.Conversations.GetValueOrDefault(Agent.ActiveConversationId) : null;

    private string DisplayName => Agent?.DisplayName ?? AgentId;
    private string? ActiveConversationId => Agent?.ActiveConversationId;
    private bool HasActiveConversation => ActiveConversation is not null;
    private string? ActiveConversationTitle => ActiveConversation?.Title;
private bool IsStreaming =>
        Agent?.ActiveConversationId is string activeConvId
            ? Store.GetStreamState(activeConvId).IsStreaming
            : false; // no active conversation = not streaming
    private bool IsReadOnly => (Agent?.IsReadOnly ?? false) || (ActiveConversation?.IsVirtualSession ?? false);
    private bool IsConnected => Agent?.IsConnected ?? false;
    private bool ShowThinking => Agent?.ShowThinking ?? true;
    private bool ShowTools => Agent?.ShowTools ?? true;
    private bool IsLoadingConversations => Agent?.IsLoadingConversations ?? false;
    private bool IsLoadingHistory => ActiveConversation?.IsLoadingHistory ?? false;
    private string? ProcessingStage => Agent?.ProcessingStage;
    private IReadOnlyList<ChatMessage> Messages => ActiveConversation?.Messages ?? [];
    private string ThinkingBuffer => ActiveConversation?.StreamState.ThinkingBuffer ?? string.Empty;
    private string CurrentStreamBuffer => ActiveConversation?.StreamState.Buffer ?? string.Empty;

    private string _inputText = "";
    private ElementReference _messagesContainer;
    private ElementReference _inputElement;
    private bool _enterPreventionBound;
    private bool _wasReadOnly;
    private AgentConfigPanel? _configPanel;
    private bool _editingTitle;
    private string _titleDraft = "";
    private readonly Dictionary<string, string> _markdownCache = new();
    private readonly HashSet<string> _expandedTools = new();
    private bool _isRecording;
    private bool _showCommandPalette;
    private string _selectedCommand = "";
    private bool _forceScrollNext;
    private bool _wasActive;
    private string? _lastActiveConversationId;
    private int _lastRenderedMessageCount;
    private bool _showNewSessionConfirm;
    private bool _showMobileActionsMenu;
    private string? _copiedMessageId;
    private static readonly TimeSpan s_copyFeedbackDuration = TimeSpan.FromSeconds(2);

    private sealed record SlashCommand(string Name, string Description);

    private static readonly SlashCommand[] s_allCommands =
    [
        new("/new", "Reset session and start fresh"),
        new("/compact", "Compact session to reduce tokens"),
        new("/clear", "Clear local messages"),
        new("/prompts", "Browse reusable prompt templates")
    ];

    private SlashCommand[] _filteredCommands = [];

    private void StartEditTitle()
    {
        if (IsReadOnly)
            return;

        _titleDraft = ActiveConversationTitle ?? "";
        _editingTitle = true;
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            await Task.Delay(50);
            try { await JS.InvokeVoidAsync("eval", "document.querySelector('.conversation-title-input')?.focus()"); }
            catch { }
        });
    }

    private async Task SaveTitle()
    {
        if (IsReadOnly)
        {
            _editingTitle = false;
            StateHasChanged();
            return;
        }

        _editingTitle = false;
        var draft = _titleDraft.Trim();
        if (!string.IsNullOrWhiteSpace(draft) && draft != ActiveConversationTitle)
            await Interaction.RenameConversationAsync(AgentId, ActiveConversationId, draft);
        else
            StateHasChanged();
    }

    private async Task TitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveTitle();
        else if (e.Key == "Escape")
        {
            _editingTitle = false;
            StateHasChanged();
        }
    }

    private void ToggleToolDetails(string messageId)
    {
        if (!_expandedTools.Remove(messageId))
            _expandedTools.Add(messageId);
    }

    private static string FormatDuration(TimeSpan d) => d.TotalSeconds < 1
        ? $"{d.TotalMilliseconds:0}ms"
        : $"{d.TotalSeconds:0.0}s";

    private static string FormatTimestamp(DateTimeOffset ts)
    {
        var local = ts.ToLocalTime();
        var now = DateTimeOffset.Now;
        return local.Date == now.Date
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d, h:mm tt");
    }

    private string InputPlaceholder => IsStreaming
        ? "Type to steer the response…"
        : "Type a message… (/ for commands like /prompts, Shift+Enter for newline)";

    private void ToggleTools()
    {
        if (Agent is null) return;
        Agent.ShowTools = !Agent.ShowTools;
        Store.NotifyChanged();
    }

    private void ToggleThinking()
    {
        if (Agent is null) return;
        Agent.ShowThinking = !Agent.ShowThinking;
        Store.NotifyChanged();
    }

    private void ToggleToolsFromMenu()
    {
        ToggleTools();
        _showMobileActionsMenu = false;
    }

    private void ToggleThinkingFromMenu()
    {
        ToggleThinking();
        _showMobileActionsMenu = false;
    }

    private async Task StartRecording()
    {
        try
        {
            var started = await JS.InvokeAsync<bool>("BotNexusAudio.startRecording");
            _isRecording = started;
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Recording failed: {ex.Message}");
        }
    }

    private async Task StopRecording()
    {
        try
        {
            var base64Audio = await JS.InvokeAsync<string?>("BotNexusAudio.stopRecording");
            _isRecording = false;
            if (base64Audio is not null)
                await Interaction.SendMessageAsync(AgentId, $"[audio:webm;base64,{base64Audio}]");
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Stop recording failed: {ex.Message}");
            _isRecording = false;
        }
    }

    private void UpdateCommandPalette()
    {
        var text = _inputText?.Trim() ?? "";
        if (text.StartsWith('/') && !text.Contains(' '))
        {
            _showCommandPalette = true;
            _filteredCommands = text == "/"
                ? s_allCommands
                : s_allCommands.Where(c => c.Name.StartsWith(text, StringComparison.OrdinalIgnoreCase)).ToArray();
            _selectedCommand = _filteredCommands.Length > 0 ? _filteredCommands[0].Name : "";
        }
        else
        {
            _showCommandPalette = false;
            _filteredCommands = [];
        }
    }

    private async Task ExecuteCommand(SlashCommand cmd)
    {
        _showCommandPalette = false;
        _inputText = "";

        switch (cmd.Name)
        {
            case "/new":
                await Interaction.ResetSessionAsync(AgentId);
                break;
            case "/compact":
                await Interaction.CompactSessionAsync(AgentId);
                break;
            case "/clear":
                Interaction.ClearLocalMessages(AgentId);
                break;
            case "/prompts":
                await Interaction.SendMessageAsync(AgentId, "/prompts");
                break;
        }
    }

    private async Task OpenConfig()
    {
        if (_configPanel is not null)
            await _configPanel.Open();
    }

    private async Task OpenConfigFromMenu()
    {
        _showMobileActionsMenu = false;
        await OpenConfig();
    }

    private void ConfirmNewSession()
    {
        if (IsReadOnly)
            return;

        _showNewSessionConfirm = true;
    }

    private void ConfirmNewSessionFromMenu()
    {
        _showMobileActionsMenu = false;
        ConfirmNewSession();
    }

    private void ToggleMobileActionsMenu()
    {
        _showMobileActionsMenu = !_showMobileActionsMenu;
    }
    private void CancelNewSession() => _showNewSessionConfirm = false;

    private async Task CopyMessage(string messageId, string content)
    {
        try
        {
            var copied = await JS.InvokeAsync<bool>("BotNexus.copyToClipboard", content);
            if (!copied)
                return;

            _copiedMessageId = messageId;
            StateHasChanged();

            await Task.Delay(s_copyFeedbackDuration);
            if (_copiedMessageId == messageId)
            {
                _copiedMessageId = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Copy message failed: {ex.Message}");
        }
    }

    private async Task DoNewSession()
    {
        if (IsReadOnly)
            return;

        _showNewSessionConfirm = false;
        await Interaction.ResetSessionAsync(AgentId);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            // Reset enter-prevention binding when textarea is recreated (read-only → interactive)
            if (_wasReadOnly && !IsReadOnly)
                _enterPreventionBound = false;
            _wasReadOnly = IsReadOnly;

            if (!_enterPreventionBound && !IsReadOnly)
            {
                await JS.InvokeVoidAsync("chatScroll.preventEnterSubmit", _inputElement);
                _enterPreventionBound = true;
            }

            var needsRender = false;
            foreach (var msg in Messages.ToList())
            {
                if (msg.Role == "Assistant" && !_markdownCache.ContainsKey(msg.Id))
                {
                    var html = await JS.InvokeAsync<string>("BotNexus.renderMarkdown", msg.Content);
                    _markdownCache[msg.Id] = html;
                    needsRender = true;
                }
            }

            if (needsRender)
            {
                StateHasChanged();
                return;
            }

            await JS.InvokeVoidAsync("BotNexus.attachCodeCopyButtons", _messagesContainer);

            var isActive = AgentId == Store.ActiveAgentId;
            if (isActive && !_wasActive)
                _forceScrollNext = true;
            _wasActive = isActive;

            var currentConvId = ActiveConversation?.ConversationId;
            var currentCount = Messages.Count;
            if (currentConvId != _lastActiveConversationId)
            {
                _forceScrollNext = true;
                _lastActiveConversationId = currentConvId;
                _lastRenderedMessageCount = currentCount;
            }
            else if (currentCount > _lastRenderedMessageCount + 5)
            {
                _forceScrollNext = true;
                _lastRenderedMessageCount = currentCount;
            }
            else
            {
                _lastRenderedMessageCount = currentCount;
            }

            if (firstRender || _forceScrollNext)
            {
                _forceScrollNext = false;
                await JS.InvokeVoidAsync("chatScroll.forceScrollToBottom", _messagesContainer);
            }
            else
            {
                await JS.InvokeVoidAsync("chatScroll.scrollToBottom", _messagesContainer, IsStreaming);
            }
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        UpdateCommandPalette();

        if (e is { Key: "Enter", ShiftKey: false })
        {
            if (_showCommandPalette && _filteredCommands.Length > 0)
            {
                var cmd = _filteredCommands.FirstOrDefault(c => c.Name == _selectedCommand) ?? _filteredCommands[0];
                await ExecuteCommand(cmd);
                return;
            }

            if (IsStreaming)
                await SteerAgent();
            else
                await SendMessage();
        }
        else if (e is { Key: "Escape" })
        {
            if (_showCommandPalette)
                _showCommandPalette = false;
            else if (IsStreaming)
                await AbortAgent();
        }
        else if (e is { Key: "Tab" } && _showCommandPalette && _filteredCommands.Length > 0)
        {
            _inputText = _filteredCommands[0].Name + " ";
            _showCommandPalette = false;
        }
    }

    private async Task SendMessage()
    {
        var text = _inputText?.Trim();
        if (string.IsNullOrEmpty(text) || !IsConnected)
            return;

        _inputText = "";
        _showCommandPalette = false;
        _forceScrollNext = true;
        await Interaction.SendMessageAsync(AgentId, text);
    }

    private async Task SteerAgent()
    {
        var text = _inputText?.Trim();
        if (string.IsNullOrEmpty(text) || !IsConnected)
            return;

        _inputText = "";
        await Interaction.SteerAsync(AgentId, text);
    }

    private async Task AbortAgent() => await Interaction.AbortAsync(AgentId);

    private string GetSubAgentStatus() => IsStreaming ? "⏳ Running" : "✅ Completed";
}
