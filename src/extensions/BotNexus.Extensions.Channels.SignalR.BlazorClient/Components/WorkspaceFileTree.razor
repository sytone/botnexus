@if (Entries.Count == 0)
{
    <div class="workspace-state">Workspace is empty.</div>
}
else
{
    <ul class="workspace-tree-list" role="tree">
        @foreach (var entry in OrderedEntries)
        {
            var fullPath = BuildPath(ParentPath, entry.Name);
            var isDirectory = IsDirectory(entry);
            var isExpanded = isDirectory && IsExpanded(fullPath);
            var isProtected = !isDirectory && IsProtectedFile(entry.Name);
            var rowCss = isDirectory
                ? "workspace-tree-row workspace-tree-directory"
                : $"workspace-tree-row workspace-tree-file {(IsSelected(fullPath) ? "selected" : string.Empty)}";
            var indentLevel = Depth + 1;

            <li role="treeitem" aria-expanded="@(isDirectory ? isExpanded : null)">
                <div class="workspace-tree-row-wrapper">
                    <button type="button"
                            data-path="@fullPath"
                            class="@rowCss"
                            style="padding-left: @(indentLevel * 0.9m)rem"
                            @onclick="() => OnRowClicked(entry, fullPath)">
                        @if (isDirectory)
                        {
                            <span class="workspace-tree-chevron" aria-hidden="true">@(isExpanded ? "▾" : "▸")</span>
                            <span class="workspace-tree-icon" aria-hidden="true">📁</span>
                        }
                        else
                        {
                            <span class="workspace-tree-chevron spacer" aria-hidden="true"></span>
                            <span class="workspace-tree-icon" aria-hidden="true">📄</span>
                        }
                        <span class="workspace-tree-name">@entry.Name</span>
                    </button>
                    @{
                        var deleteTitle = isProtected ? (entry.Name + " is a protected file and cannot be deleted.") : ("Delete " + fullPath);
                        var deleteLabel = isProtected ? ("Cannot delete protected file " + entry.Name) : ("Delete " + fullPath);
                        var deleteCss = isProtected ? "workspace-tree-delete workspace-tree-delete-disabled" : "workspace-tree-delete";
                    }
                    <button type="button"
                            class="@deleteCss"
                            title="@deleteTitle"
                            aria-label="@deleteLabel"
                            disabled="@isProtected"
                            @onclick:stopPropagation="true"
                            @onclick="() => { if (!isProtected) OnDeleteRequested.InvokeAsync(fullPath); }">
                        🗑
                    </button>
                </div>

                @if (isDirectory && isExpanded)
                {
                    <div class="workspace-tree-children">
                        @if (GetDirectoryLoadingState(fullPath))
                        {
                            <div class="workspace-state">Loading…</div>
                        }
                        else if (!string.IsNullOrWhiteSpace(GetDirectoryError(fullPath)))
                        {
                            <div class="workspace-state workspace-state-error">@GetDirectoryError(fullPath)</div>
                        }
                        else if (GetDirectoryEntries(fullPath) is { } childEntries)
                        {
                            <WorkspaceFileTree Entries="childEntries"
                                               ParentPath="@fullPath"
                                               Depth="@(Depth + 1)"
                                               ExpandedPaths="ExpandedPaths"
                                               SelectedFilePath="SelectedFilePath"
                                               OnDirectoryToggled="OnDirectoryToggled"
                                               OnFileSelected="OnFileSelected"
                                               OnDeleteRequested="OnDeleteRequested"
                                               DirectoryEntriesProvider="DirectoryEntriesProvider"
                                               DirectoryLoadingProvider="DirectoryLoadingProvider"
                                               DirectoryErrorProvider="DirectoryErrorProvider" />
                        }
                    </div>
                }
            </li>
        }
    </ul>
}

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<WorkspaceEntryDto> Entries { get; set; } = [];

    [Parameter]
    public string ParentPath { get; set; } = string.Empty;

    [Parameter]
    public int Depth { get; set; }

    [Parameter]
    public IReadOnlySet<string> ExpandedPaths { get; set; } = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

    [Parameter]
    public string? SelectedFilePath { get; set; }

    [Parameter]
    public EventCallback<string> OnDirectoryToggled { get; set; }

    [Parameter]
    public EventCallback<string> OnFileSelected { get; set; }

    [Parameter]
    public EventCallback<string> OnDeleteRequested { get; set; }

    [Parameter]
    public Func<string, IReadOnlyList<WorkspaceEntryDto>?>? DirectoryEntriesProvider { get; set; }

    [Parameter]
    public Func<string, bool>? DirectoryLoadingProvider { get; set; }

    [Parameter]
    public Func<string, string?>? DirectoryErrorProvider { get; set; }

    private IEnumerable<WorkspaceEntryDto> OrderedEntries =>
        Entries
            .OrderBy(entry => IsDirectory(entry) ? 0 : 1)
            .ThenBy(entry => entry.Name, StringComparer.OrdinalIgnoreCase);

    private async Task OnRowClicked(WorkspaceEntryDto entry, string fullPath)
    {
        if (IsDirectory(entry))
            await OnDirectoryToggled.InvokeAsync(fullPath);
        else
            await OnFileSelected.InvokeAsync(fullPath);
    }

    private bool IsDirectory(WorkspaceEntryDto entry) =>
        string.Equals(entry.Type, "directory", StringComparison.OrdinalIgnoreCase);

    private bool IsExpanded(string path) => ExpandedPaths.Contains(path);

    private bool IsSelected(string path) =>
        string.Equals(SelectedFilePath, path, StringComparison.OrdinalIgnoreCase);

    private IReadOnlyList<WorkspaceEntryDto>? GetDirectoryEntries(string path) =>
        DirectoryEntriesProvider?.Invoke(path);

    private bool GetDirectoryLoadingState(string path) =>
        DirectoryLoadingProvider?.Invoke(path) == true;

    private string? GetDirectoryError(string path) =>
        DirectoryErrorProvider?.Invoke(path);

    /// <summary>
    /// Core agent identity files that cannot be deleted via the portal.
    /// Must be kept in sync with WorkspaceController.ProtectedFiles on the gateway.
    /// </summary>
    private static readonly IReadOnlySet<string> ProtectedFileNames = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "SOUL.md",
        "IDENTITY.md",
        "MEMORY.md",
        "AGENTS.md",
        "USER.md",
        "WORLD.md",
        "TOOLS.md"
    };

    private static bool IsProtectedFile(string fileName) => ProtectedFileNames.Contains(fileName);

    private static string BuildPath(string parent, string name) =>
        string.IsNullOrWhiteSpace(parent) ? name : $"{parent.TrimEnd('/')}/{name}";
}
