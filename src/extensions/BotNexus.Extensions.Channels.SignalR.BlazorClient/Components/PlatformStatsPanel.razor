@inject HttpClient Http
@implements IDisposable

@*
    Platform stats section (issue #1692). A small, self-contained read-only panel that polls the
    platform-wide stats endpoint and surfaces live in-flight work: active agent loops and active
    sub-agents, with peak / total-completed loop counters for context. Kept deliberately minimal so
    it can sit on the portal dashboard without pulling in extra services - it talks to /api/stats
    directly via HttpClient and refreshes on a light timer while mounted.
*@

<section class="platform-stats-panel" data-testid="platform-stats-panel">
    <h3 class="platform-stats-title">Platform</h3>

    @if (_loadError)
    {
        <div class="platform-stats-error" data-testid="platform-stats-error">Unable to load platform stats.</div>
    }
    else
    {
        <div class="platform-stats-grid">
            <div class="platform-stat" data-testid="stat-active-loops">
                <span class="platform-stat-value">@_stats.ActiveAgentLoops</span>
                <span class="platform-stat-label">Active agent loops</span>
            </div>
            <div class="platform-stat" data-testid="stat-active-subagents">
                <span class="platform-stat-value">@_stats.ActiveSubAgents</span>
                <span class="platform-stat-label">Active sub-agents</span>
            </div>
            <div class="platform-stat" data-testid="stat-peak-loops">
                <span class="platform-stat-value">@_stats.PeakAgentLoops</span>
                <span class="platform-stat-label">Peak loops</span>
            </div>
            <div class="platform-stat" data-testid="stat-total-loops">
                <span class="platform-stat-value">@_stats.TotalCompletedLoops</span>
                <span class="platform-stat-label">Completed loops</span>
            </div>
        </div>
    }
</section>

@code {
    // Poll cadence for the live counts. Short enough to feel live, long enough to stay cheap.
    private static readonly TimeSpan RefreshInterval = TimeSpan.FromSeconds(5);

    private readonly CancellationTokenSource _cts = new();
    private PlatformStats _stats = new();
    private bool _loadError;
    private Timer? _timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();

        // Periodic refresh while the panel is mounted. The callback marshals back onto the renderer
        // via InvokeAsync; the CTS guards against a fetch outliving disposal.
        _timer = new Timer(_ => _ = RefreshAsync(), null, RefreshInterval, RefreshInterval);
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<PlatformStats>("api/stats", _cts.Token);
            if (stats is not null)
            {
                _stats = stats;
                _loadError = false;
            }
        }
        catch (OperationCanceledException)
        {
            // Disposed / navigated away mid-request - nothing to surface.
        }
        catch (Exception)
        {
            _loadError = true;
        }
    }

    public void Dispose()
    {
        _timer?.Dispose();
        _cts.Cancel();
        _cts.Dispose();
    }

    /// <summary>
    /// Local view model mirroring the gateway's PlatformStatsDto. Defaults to zeros so the panel
    /// renders a stable idle state before the first fetch resolves.
    /// </summary>
    private sealed class PlatformStats
    {
        public int ActiveAgentLoops { get; set; }
        public int PeakAgentLoops { get; set; }
        public long TotalCompletedLoops { get; set; }
        public int ActiveSubAgents { get; set; }
    }
}
