@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services
@inject IClientStateStore Store
@inject IGatewayRestClient Rest
@inject NavigationManager Nav
@implements IDisposable

<div class="activity-dashboard" data-testid="activity-dashboard">
    <div class="activity-dashboard-header">
        <h1 class="activity-dashboard-title">Activity</h1>
        <span class="activity-dashboard-subtitle">Active conversations across the platform</span>
    </div>

    @if (_summary is { } summary)
    {
        <div class="activity-summary-strip" data-testid="activity-summary-strip" role="group" aria-label="Activity summary">
            <button type="button"
                    class="activity-summary-stat activity-summary-stat--action @(HasActiveFilters ? "active" : "")"
                    data-testid="activity-summary-conversations"
                    aria-label="Clear activity filters"
                    title="Clear all filters"
                    @onclick="ResetFilters">
                <span class="activity-summary-value">@summary.ConversationCount</span>
                <span class="activity-summary-label">@(summary.ConversationCount == 1 ? "conversation" : "conversations")</span>
            </button>
            <div class="activity-summary-stat" data-testid="activity-summary-agents">
                <span class="activity-summary-value">@summary.AgentCount</span>
                <span class="activity-summary-label">@(summary.AgentCount == 1 ? "agent" : "agents")</span>
            </div>
            <button type="button"
                    class="activity-summary-stat activity-summary-stat--action @(_filter.IncludeCron ? "active" : "")"
                    data-testid="activity-summary-scheduled"
                    aria-pressed="@_filter.IncludeCron"
                    title="@(_filter.IncludeCron ? "Hide scheduled (cron) conversations" : "Show scheduled (cron) conversations")"
                    @onclick="ToggleCron">
                <span class="activity-summary-value">@summary.ScheduledCount</span>
                <span class="activity-summary-label">scheduled</span>
            </button>
            <div class="activity-summary-stat activity-summary-stat--freshness" data-testid="activity-summary-freshness">
                <span class="activity-summary-value" title="@(summary.LatestActivity?.ToString("o"))">@FreshnessLabel(summary.LatestActivity)</span>
                <span class="activity-summary-label">latest activity</span>
            </div>
        </div>
    }

    <div class="activity-filter-bar" role="group" aria-label="Filter activity" data-testid="activity-filter-bar">
        <button type="button"
                class="activity-filter-btn @(_filter.IncludeCron ? "active" : "")"
                data-testid="activity-filter-cron"
                aria-pressed="@_filter.IncludeCron"
                title="Show scheduled (cron) conversations"
                @onclick="ToggleCron">@(_filter.IncludeCron ? "\u2611" : "\u2610") Cron</button>

        <select class="activity-filter-select" data-testid="activity-filter-agent"
                aria-label="Filter by agent"
                value="@(_filter.AgentId ?? "")"
                @onchange="OnAgentFilterChanged">
            <option value="">All agents</option>
            @foreach (var (agentId, agent) in Store.Agents.OrderForDisplay())
            {
                <option value="@agentId">@AgentLabel(agentId)</option>
            }
        </select>

        <select class="activity-filter-select" data-testid="activity-filter-status"
                aria-label="Filter by status"
                value="@_filter.Status"
                @onchange="OnStatusFilterChanged">
            <option value="@ActivityStatusFilter.Active">Active</option>
            <option value="@ActivityStatusFilter.Archived">Archived</option>
            <option value="@ActivityStatusFilter.All">All statuses</option>
        </select>

        <select class="activity-filter-select" data-testid="activity-filter-recency"
                aria-label="Filter by recency"
                value="@_filter.Recency"
                @onchange="OnRecencyFilterChanged">
            <option value="@ActivityRecencyWindow.Any">Any time</option>
            <option value="@ActivityRecencyWindow.Today">Today</option>
            <option value="@ActivityRecencyWindow.Week">Last 7 days</option>
            <option value="@ActivityRecencyWindow.Month">Last 30 days</option>
        </select>
    </div>

    @if (_isLoading && _rows is null)
    {
        <div class="activity-loading" data-testid="activity-loading">Loading activity&#x2026;</div>
    }
    else if (_loadError)
    {
        <div class="activity-error" data-testid="activity-error">Could not load activity. Retrying&#x2026;</div>
    }
    else if (_rows is { Count: 0 })
    {
        <div class="activity-empty" data-testid="activity-empty">
            No active conversations match the current filters.
        </div>
    }
    else if (_rows is { } rows)
    {
        <table class="activity-table" data-testid="activity-table">
            <thead>
                <tr>
                    <th scope="col">Conversation</th>
                    <th scope="col">Agents</th>
                    <th scope="col">Status</th>
                    <th scope="col">Channels</th>
                    <th scope="col">Last activity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in rows)
                {
                    <tr class="activity-row @(row.IsCron ? "activity-row-cron" : "")"
                        data-testid="activity-row"
                        data-conversation-id="@row.ConversationId"
                        tabindex="0"
                        role="link"
                        @onclick="() => NavigateToConversation(row)"
                        @onkeydown="e => OnRowKeyDown(e, row)">
                        <td class="activity-cell-title">
                            <span class="activity-conversation-title">@row.Title</span>
                            @if (row.IsCron)
                            {
                                <span class="activity-badge activity-badge-cron">Scheduled</span>
                            }
                        </td>
                        <td class="activity-cell-agents">
                            @foreach (var agentId in row.InvolvedAgents)
                            {
                                <span class="activity-agent-chip">@AgentLabel(agentId)</span>
                            }
                        </td>
                        <td class="activity-cell-status">
                            <span class="activity-status activity-status-@row.Status.ToLowerInvariant()">@row.Status</span>
                        </td>
                        <td class="activity-cell-channels">@row.ChannelCount</td>
                        <td class="activity-cell-activity" title="@row.LastActivity.ToString("o")">
                            @FormatRelative(row.LastActivity)
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    // Poll interval mirrors the existing portal conversation-list polling cadence; SignalR push is a
    // later evolution (see #1888). Kept as a field so a future enhancement can make it configurable.
    private static readonly TimeSpan PollInterval = TimeSpan.FromSeconds(15);

    private ActivityDashboardFilter _filter = new();
    private IReadOnlyList<ActivityRow>? _rows;
    private ActivitySummary? _summary;
    private bool _isLoading;
    private bool _loadError;
    private CancellationTokenSource? _pollCts;

    protected override async Task OnInitializedAsync()
    {
        Store.OnChanged += HandleStateChanged;
        await LoadAsync();
        StartPolling();
    }

    private void HandleStateChanged() => _ = InvokeAsync(StateHasChanged);

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var conversations = await Rest.GetAllConversationsAsync();
            _rows = ActivityDashboardProjection.Project(conversations, _filter, DateTimeOffset.UtcNow);
            _summary = ActivityDashboardProjection.Summarize(_rows);
            _loadError = false;
        }
        catch
        {
            _loadError = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void StartPolling()
    {
        _pollCts = new CancellationTokenSource();
        var token = _pollCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(PollInterval, token);
                }
                catch (TaskCanceledException)
                {
                    return;
                }

                if (token.IsCancellationRequested)
                    return;

                await InvokeAsync(async () =>
                {
                    await LoadAsync();
                    StateHasChanged();
                });
            }
        }, token);
    }

    private async Task ApplyFilterAsync(ActivityDashboardFilter filter)
    {
        _filter = filter;
        await LoadAsync();
        StateHasChanged();
    }

    private bool HasActiveFilters => _filter != new ActivityDashboardFilter();

    private Task ResetFilters() => ApplyFilterAsync(new ActivityDashboardFilter());

    private Task ToggleCron() => ApplyFilterAsync(_filter with { IncludeCron = !_filter.IncludeCron });

    private Task OnAgentFilterChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        return ApplyFilterAsync(_filter with { AgentId = string.IsNullOrEmpty(value) ? null : value });
    }

    private Task OnStatusFilterChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ActivityStatusFilter>(e.Value?.ToString(), out var status))
            return ApplyFilterAsync(_filter with { Status = status });
        return Task.CompletedTask;
    }

    private Task OnRecencyFilterChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<ActivityRecencyWindow>(e.Value?.ToString(), out var window))
            return ApplyFilterAsync(_filter with { Recency = window });
        return Task.CompletedTask;
    }

    private void NavigateToConversation(ActivityRow row) =>
        Nav.NavigateTo(
            $"/chat/{Uri.EscapeDataString(row.OwningAgentId)}/{Uri.EscapeDataString(row.ConversationId)}");

    private void OnRowKeyDown(KeyboardEventArgs e, ActivityRow row)
    {
        if (e.Key is "Enter" or " ")
            NavigateToConversation(row);
    }

    /// <summary>Resolve an agent id to its display name via the store, falling back to a title-cased id.</summary>
    private string AgentLabel(string agentId)
    {
        var agent = Store.GetAgent(agentId);
        if (agent is { DisplayName.Length: > 0 })
            return agent.DisplayName;
        return agentId;
    }

    private static string FormatRelative(DateTimeOffset ts)
    {
        var age = DateTimeOffset.UtcNow - ts;
        if (age < TimeSpan.Zero)
            age = TimeSpan.Zero;
        return age.TotalSeconds < 60 ? "just now"
            : age.TotalMinutes < 60 ? $"{(int)age.TotalMinutes} min ago"
            : age.TotalHours < 24 ? $"{(int)age.TotalHours}h ago"
            : $"{(int)age.TotalDays}d ago";
    }

    /// <summary>Relative label for the summary strip's freshness stat, with an em-dash when idle.</summary>
    private static string FreshnessLabel(DateTimeOffset? ts) =>
        ts is { } value ? FormatRelative(value) : "\u2014";

    public void Dispose()
    {
        Store.OnChanged -= HandleStateChanged;
        _pollCts?.Cancel();
        _pollCts?.Dispose();
    }
}
