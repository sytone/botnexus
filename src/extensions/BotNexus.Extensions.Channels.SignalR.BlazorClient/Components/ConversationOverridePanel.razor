@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services
@inject IGatewayRestClient RestClient

@*
    Per-conversation model / thinking / context override picker (PBI5, issue #1706).
    Lets a user override the agent's default model, thinking level, and context window for a single
    conversation, and clear the override back to the agent default. The persisted override is
    consumed by the gateway's ModelOverrideResolver as the top precedence layer.
*@
<div class="conversation-override-panel" data-testid="conversation-override-panel">
    <h4>Conversation model override</h4>

    <label>
        Model
        <input type="text"
               data-testid="override-model"
               placeholder="(agent default)"
               @bind="ModelValue" />
    </label>

    <label>
        Reasoning
        <select data-testid="override-thinking" @bind="ThinkingValue">
            <option value="">(agent default)</option>
            <option value="minimal">minimal</option>
            <option value="low">low</option>
            <option value="medium">medium</option>
            <option value="high">high</option>
            <option value="xhigh">xhigh</option>
            <option value="max">max</option>
        </select>
    </label>

    <label>
        Context window (tokens)
        <input type="number"
               data-testid="override-context"
               placeholder="(agent default)"
               @bind="ContextValue" />
    </label>

    <div class="conversation-override-actions">
        <button type="button" data-testid="override-save" @onclick="SaveAsync" disabled="@_busy">Save</button>
        <button type="button" data-testid="override-clear" @onclick="ClearAsync" disabled="@_busy">Clear to agent default</button>
    </div>

    @if (!string.IsNullOrEmpty(_status))
    {
        <p class="conversation-override-status" data-testid="override-status">@_status</p>
    }
</div>

@code {
    /// <summary>The conversation whose override this panel edits.</summary>
    [Parameter, EditorRequired]
    public string ConversationId { get; set; } = default!;

    /// <summary>Optional initial model override, so the panel hydrates from the loaded conversation.</summary>
    [Parameter]
    public string? InitialModel { get; set; }

    /// <summary>Optional initial thinking-level override token.</summary>
    [Parameter]
    public string? InitialThinking { get; set; }

    /// <summary>Optional initial context-window override.</summary>
    [Parameter]
    public int? InitialContextWindow { get; set; }

    /// <summary>Raised after the override is saved or cleared, so a parent can refresh state.</summary>
    [Parameter]
    public EventCallback<ConversationResponseDto?> OnOverrideChanged { get; set; }

    private string? ModelValue { get; set; }
    private string ThinkingValue { get; set; } = string.Empty;
    private int? ContextValue { get; set; }
    private bool _busy;
    private string? _status;

    protected override void OnParametersSet()
    {
        ModelValue = InitialModel;
        ThinkingValue = InitialThinking ?? string.Empty;
        ContextValue = InitialContextWindow;
    }

    private async Task SaveAsync()
    {
        _busy = true;
        _status = null;
        try
        {
            var request = new SetConversationOverrideRequestDto(
                Model: string.IsNullOrWhiteSpace(ModelValue) ? null : ModelValue.Trim(),
                Thinking: string.IsNullOrWhiteSpace(ThinkingValue) ? null : ThinkingValue,
                ContextWindow: ContextValue);
            var updated = await RestClient.SetConversationOverrideAsync(ConversationId, request);
            _status = "Override saved.";
            await OnOverrideChanged.InvokeAsync(updated);
        }
        catch (Exception ex)
        {
            _status = $"Failed to save override: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ClearAsync()
    {
        _busy = true;
        _status = null;
        try
        {
            var updated = await RestClient.ClearConversationOverrideAsync(ConversationId);
            ModelValue = null;
            ThinkingValue = string.Empty;
            ContextValue = null;
            _status = "Override cleared; using the agent default.";
            await OnOverrideChanged.InvokeAsync(updated);
        }
        catch (Exception ex)
        {
            _status = $"Failed to clear override: {ex.Message}";
        }
        finally
        {
            _busy = false;
        }
    }
}
