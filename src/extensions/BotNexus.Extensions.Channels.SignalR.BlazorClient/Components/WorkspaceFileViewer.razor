<div class="workspace-viewer" data-testid="workspace-viewer">
    @if (ShowBackButton)
    {
        <button type="button"
                class="workspace-mobile-back"
                @onclick="() => BackRequested.InvokeAsync()"
                aria-label="Back to file tree">
            ← Files
        </button>
    }

    @if (IsLoading)
    {
        <div class="workspace-state">Loading file…</div>
    }
    else if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="workspace-state workspace-state-error">@ErrorMessage</div>
    }
    else if (FileResponse is null)
    {
        <div class="workspace-state">Select a file to preview its contents.</div>
    }
    else if (IsBinaryFile)
    {
        <div class="workspace-state">This file appears to be binary and can't be previewed.</div>
    }
    else
    {
        <header class="workspace-file-header">
            <h3>@DisplayPath</h3>
            <div class="workspace-file-actions">
                @if (IsEditing)
                {
                    <button type="button"
                            class="workspace-btn workspace-btn-save"
                            disabled="@(!HasUnsavedChanges)"
                            @onclick="() => OnSaveRequested.InvokeAsync(EditContent ?? string.Empty)">
                        Save
                    </button>
                    <button type="button"
                            class="workspace-btn workspace-btn-discard"
                            @onclick="() => OnDiscardRequested.InvokeAsync()">
                        Discard
                    </button>
                }
                else
                {
                    <button type="button"
                            class="workspace-btn workspace-btn-edit"
                            @onclick="() => OnEditRequested.InvokeAsync()">
                        Edit
                    </button>
                }
            </div>
            @if (ShowServerTruncationNotice || ShowClientTruncationNotice)
            {
                <p class="workspace-file-truncation">
                    Content was truncated for safe preview. Download/open locally for the full file.
                </p>
            }
        </header>

        @if (IsEditing)
        {
            <textarea class="workspace-file-editor"
                      value="@EditContent"
                      @oninput="OnEditorInput"
                      spellcheck="false"></textarea>
        }
        else
        {
            <pre class="workspace-file-content">@DisplayContent</pre>
        }
    }
</div>

@code {
    private const int MaxPreviewCharacters = 200_000;

    [Parameter]
    public bool IsLoading { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public WorkspaceResponseDto? FileResponse { get; set; }

    [Parameter]
    public bool ShowBackButton { get; set; }

    [Parameter]
    public EventCallback BackRequested { get; set; }

    [Parameter]
    public bool IsEditing { get; set; }

    [Parameter]
    public string? EditContent { get; set; }

    [Parameter]
    public EventCallback<string> OnSaveRequested { get; set; }

    [Parameter]
    public EventCallback OnDiscardRequested { get; set; }

    [Parameter]
    public EventCallback OnEditRequested { get; set; }

    [Parameter]
    public EventCallback<string> OnEditContentChanged { get; set; }

    private bool IsBinaryFile =>
        string.Equals(FileResponse?.Type, "binary", StringComparison.OrdinalIgnoreCase)
        || FileResponse?.Binary == true;

    private bool HasUnsavedChanges =>
        EditContent != (FileResponse?.Content ?? string.Empty);

    private bool ShowServerTruncationNotice => FileResponse?.IsTruncated == true;

    private bool ShowClientTruncationNotice =>
        !string.IsNullOrEmpty(FileResponse?.Content)
        && FileResponse!.Content!.Length > MaxPreviewCharacters;

    private string DisplayPath => string.IsNullOrWhiteSpace(FileResponse?.Path) ? "/" : FileResponse!.Path;

    private string DisplayContent
    {
        get
        {
            var content = FileResponse?.Content ?? string.Empty;
            return content.Length <= MaxPreviewCharacters
                ? content
                : content[..MaxPreviewCharacters];
        }
    }

    private async Task OnEditorInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        await OnEditContentChanged.InvokeAsync(value);
    }
}
