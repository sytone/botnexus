@inject IGatewayRestClient GatewayRestClient
@inject IJSRuntime JS
@implements IDisposable

@if (!string.IsNullOrWhiteSpace(SessionId))
{
    <div class="session-debug-overlay" @onclick="OnClose" @onkeydown="HandleKeyDown" tabindex="-1">
    <div class="session-debug-panel" role="dialog" aria-modal="true" aria-labelledby="session-debug-title" data-testid="session-debug-panel" @onclick:stopPropagation="true">
        <div class="session-debug-header">
            <h3 id="session-debug-title" class="session-debug-title">Session Debug</h3>
            <button class="session-debug-close" @onclick="OnClose" title="Close" data-testid="session-debug-close">&#x2715;</button>
        </div>

        @if (_isLoading)
        {
            <div class="session-debug-loading">Loading session…</div>
        }
        else if (_loadError is not null)
        {
            <div class="session-debug-error" data-testid="session-debug-error">@_loadError</div>
        }
        else if (_snapshot is not null)
        {
            <div class="session-debug-tabs" data-testid="session-debug-tabs">
                <button class="session-debug-tab @(_activeTab == "overview" ? "active" : "")"
                        data-testid="session-debug-tab-overview"
                        @onclick='() => _activeTab = "overview"'>Overview</button>
                <button class="session-debug-tab @(_activeTab == "metadata" ? "active" : "")"
                        data-testid="session-debug-tab-metadata"
                        @onclick='() => _activeTab = "metadata"'>Metadata</button>
                <button class="session-debug-tab @(_activeTab == "system-prompt" ? "active" : "")"
                        data-testid="session-debug-tab-system-prompt"
                        @onclick='() => _activeTab = "system-prompt"'>System Prompt</button>
                <button class="session-debug-tab @(_activeTab == "history" ? "active" : "")"
                        data-testid="session-debug-tab-history"
                        @onclick='() => SelectHistoryTabAsync()'>History</button>
                <button class="session-debug-tab @(_activeTab == "sub-agents" ? "active" : "")"
                        data-testid="session-debug-tab-sub-agents"
                        @onclick='() => SelectSubAgentsTabAsync()'>Sub-Agents</button>
            </div>

            @if (_activeTab == "overview")
            {
                <table class="session-debug-table" data-testid="session-debug-overview">
                    <tbody>
                        <tr><th>Session ID</th><td data-testid="session-id">@_snapshot.SessionId</td></tr>
                        <tr><th>Agent</th><td data-testid="agent-id">@_snapshot.AgentId</td></tr>
                        <tr><th>Status</th><td data-testid="status">@_snapshot.Status</td></tr>
                        <tr><th>Type</th><td data-testid="session-type">@_snapshot.SessionType</td></tr>
                        <tr><th>Created</th><td data-testid="created-at">@_snapshot.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
                        <tr><th>Updated</th><td data-testid="updated-at">@_snapshot.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td></tr>
                        <tr><th>Messages</th><td data-testid="message-count">@_snapshot.MessageCount</td></tr>
                        <tr><th>Conversation</th><td data-testid="conversation-id">@(_snapshot.ConversationId ?? "—")</td></tr>
                        <tr><th>Channel</th><td data-testid="channel-type">@(_snapshot.ChannelType ?? "—")</td></tr>
                    </tbody>
                </table>
            }
            else if (_activeTab == "metadata")
            {
                @if (_snapshot.Metadata is null || _snapshot.Metadata.Count == 0)
                {
                    <div class="session-debug-empty" data-testid="session-debug-metadata-empty">No metadata entries.</div>
                }
                else
                {
                    <table class="session-debug-table" data-testid="session-debug-metadata">
                        <thead>
                            <tr><th>Key</th><th>Value</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var kv in _snapshot.Metadata)
                            {
                                <tr>
                                    <td class="session-debug-meta-key" data-testid="meta-key">@kv.Key</td>
                                    <td class="session-debug-meta-value" data-testid="meta-value">@(kv.Value?.ToString() ?? "null")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_activeTab == "system-prompt")
            {
                @if (string.IsNullOrWhiteSpace(_snapshot.SystemPrompt))
                {
                    <div class="session-debug-empty" data-testid="session-debug-system-prompt-empty">System prompt not yet captured.</div>
                }
                else
                {
                    @if (_snapshot.SystemPromptCapturedAt.HasValue)
                    {
                        <div class="session-debug-meta" data-testid="system-prompt-captured-at">
                            Captured: @_snapshot.SystemPromptCapturedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                            <button class="session-debug-copy-btn"
                                    title="Copy to clipboard"
                                    data-testid="system-prompt-copy"
                                    @onclick="CopySystemPromptAsync">&#x1F4CB;</button>
                        </div>
                    }
                    <pre class="session-debug-system-prompt" data-testid="session-debug-system-prompt-content">@_snapshot.SystemPrompt</pre>
                }
            }
            else if (_activeTab == "history")
            {
                @if (_isLoadingHistory)
                {
                    <div class="session-debug-loading" data-testid="session-debug-history-loading">Loading history…</div>
                }
                else if (_history is null || _history.Entries is null || _history.Entries.Count == 0)
                {
                    <div class="session-debug-empty" data-testid="session-debug-history-empty">No history entries.</div>
                }
                else
                {
                    <div class="session-debug-history-controls" data-testid="session-debug-history-controls">
                        <span data-testid="session-debug-history-count">
                            @(_history.Offset + 1)–@(Math.Min(_history.Offset + _history.Entries.Count, _history.TotalCount))
                            of @_history.TotalCount
                        </span>
                        <select class="session-debug-page-size"
                                data-testid="session-debug-history-page-size"
                                @onchange="OnPageSizeChangedAsync">
                            <option value="25" selected="@(_historyPageSize == 25)">25</option>
                            <option value="50" selected="@(_historyPageSize == 50)">50</option>
                            <option value="100" selected="@(_historyPageSize == 100)">100</option>
                        </select>
                        <button class="session-debug-pager-btn"
                                data-testid="session-debug-history-prev"
                                disabled="@(_history.Offset == 0)"
                                @onclick="GoToPrevPageAsync">&#x276E; Prev</button>
                        <button class="session-debug-pager-btn"
                                data-testid="session-debug-history-next"
                                disabled="@(_history.Offset + _history.Entries.Count >= _history.TotalCount)"
                                @onclick="GoToNextPageAsync">Next &#x276F;</button>
                    </div>
                    <div class="session-debug-history-entries" data-testid="session-debug-history-entries">
                        @foreach (var entry in _history.Entries)
                        {
                            var isBoundary = entry.IsCompactionSummary;
                            var isSentinel = entry.IsCrashSentinel;
                            var isHistorical = entry.IsHistory;
                            var roleLabel = RoleBadge(entry.Role, entry.ToolName);
                            var rowClass = isBoundary ? "session-debug-entry compaction-boundary"
                                         : isSentinel ? "session-debug-entry crash-sentinel"
                                         : isHistorical ? "session-debug-entry historical"
                                         : "session-debug-entry";
                            <div class="@rowClass" data-testid="session-debug-entry">
                                <div class="entry-header">
                                    <span class="entry-role-badge" data-testid="entry-role">@roleLabel</span>
                                    <span class="entry-timestamp" data-testid="entry-timestamp">
                                        @entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")
                                    </span>
                                    @if (isBoundary)
                                    {
                                        <span class="entry-flag" data-testid="entry-compaction-flag">compacted</span>
                                    }
                                    @if (isSentinel)
                                    {
                                        <span class="entry-flag entry-flag-sentinel" data-testid="entry-sentinel-flag">sentinel</span>
                                    }
                                </div>
                                <details class="entry-content-details">
                                    <summary class="entry-content-preview" data-testid="entry-content-preview">
                                        @TruncateContent(entry.Content, 120)
                                    </summary>
                                    <pre class="entry-content-full" data-testid="entry-content-full">@entry.Content</pre>
                                </details>
                            </div>
                        }
                    </div>
                }
            }
            else if (_activeTab == "sub-agents")
            {
                @if (_isLoadingSubAgents)
                {
                    <div class="session-debug-loading" data-testid="session-debug-subagents-loading">Loading sub-agents…</div>
                }
                else if (_subAgents is null || _subAgents.Count == 0)
                {
                    <div class="session-debug-empty" data-testid="session-debug-subagents-empty">No sub-agents for this session.</div>
                }
                else
                {
                    <table class="session-debug-table" data-testid="session-debug-subagents">
                        <thead>
                            <tr><th>Sub-Agent ID</th><th>Status</th><th>Model</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var sa in _subAgents)
                            {
                                <tr>
                                    <td data-testid="subagent-id">@sa.SubAgentId</td>
                                    <td data-testid="subagent-status">@sa.Status</td>
                                    <td data-testid="subagent-model">@(sa.Model ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        }
    </div>
    </div>
}

@code {
    [Parameter] public string? SessionId { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }

    private SessionDebugSnapshotDto? _snapshot;
    private bool _isLoading;
    private string? _loadError;
    private string _activeTab = "overview";

    // History tab state
    private SessionDebugHistoryDto? _history;
    private bool _isLoadingHistory;
    private int _historyPageSize = 25;
    private int _historyOffset;

    // Sub-agents tab state
    private IReadOnlyList<SubAgentInfo>? _subAgents;
    private bool _isLoadingSubAgents;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(SessionId))
            return;

        _isLoading = true;
        _loadError = null;
        _snapshot = null;
        _activeTab = "overview";
        _subAgents = null;
        _isLoadingSubAgents = false;
        _history = null;
        _isLoadingHistory = false;
        _historyOffset = 0;
        StateHasChanged();

        try
        {
            _snapshot = await GatewayRestClient.GetSessionDebugAsync(SessionId);
            if (_snapshot is null)
                _loadError = "Session not found.";
        }
        catch (Exception ex)
        {
            _loadError = $"Unable to load session: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose() { }

    private void HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
            OnClose.InvokeAsync();
    }

    private async Task SelectHistoryTabAsync()
    {
        _activeTab = "history";
        if (_history is not null)
            return;
        await LoadHistoryPageAsync();
    }

    private async Task LoadHistoryPageAsync()
    {
        _isLoadingHistory = true;
        StateHasChanged();
        try
        {
            var snap = await GatewayRestClient.GetSessionDebugAsync(SessionId!, _historyOffset, _historyPageSize);
            _history = snap?.History;
        }
        catch
        {
            _history = null;
        }
        finally
        {
            _isLoadingHistory = false;
        }
    }

    private async Task GoToPrevPageAsync()
    {
        _historyOffset = Math.Max(0, _historyOffset - _historyPageSize);
        _history = null;
        await LoadHistoryPageAsync();
    }

    private async Task GoToNextPageAsync()
    {
        _historyOffset += _historyPageSize;
        _history = null;
        await LoadHistoryPageAsync();
    }

    private async Task OnPageSizeChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size) && size > 0)
            _historyPageSize = size;
        _historyOffset = 0;
        _history = null;
        await LoadHistoryPageAsync();
    }

    private async Task SelectSubAgentsTabAsync()
    {
        _activeTab = "sub-agents";
        if (_subAgents is not null)
            return;

        _isLoadingSubAgents = true;
        StateHasChanged();
        try
        {
            _subAgents = await GatewayRestClient.ListSessionSubAgentsAsync(SessionId!);
        }
        catch
        {
            _subAgents = [];
        }
        finally
        {
            _isLoadingSubAgents = false;
        }
    }

    private async Task CopySystemPromptAsync()
    {
        if (_snapshot?.SystemPrompt is null) return;
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", _snapshot.SystemPrompt); }
        catch { /* clipboard may be unavailable in some environments */ }
    }

    private static string RoleBadge(string? role, string? toolName) =>
        role?.ToLowerInvariant() switch
        {
            "user"      => "\U0001F464 user",
            "assistant" => "\U0001F916 assistant",
            "system"    => "\u2699\uFE0F system",
            "tool"      => $"\U0001F527 {toolName ?? "tool"}",
            _           => role ?? "?"
        };

    private static string TruncateContent(string? content, int max)
    {
        if (string.IsNullOrEmpty(content)) return "(empty)";
        if (content.Length <= max) return content;
        return string.Concat(content.AsSpan(0, max), "…");
    }
}
