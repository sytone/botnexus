@inject IGatewayRestClient GatewayRestClient
@inject IJSRuntime JS
@using Microsoft.AspNetCore.Components
@implements IDisposable

<div class="reports-panel @MobilePaneClass" data-testid="reports-panel">
    <section class="reports-list-pane">
        @if (_isLoadingReports)
        {
            <div class="workspace-state">Loading reports…</div>
        }
        else if (!string.IsNullOrWhiteSpace(_reportsLoadError))
        {
            <div class="workspace-state workspace-state-error">@_reportsLoadError</div>
        }
        else if (_reports.Count == 0)
        {
            <div class="workspace-state">No reports found in this workspace yet.</div>
        }
        else
        {
            <ul class="reports-list" data-testid="reports-list">
                @foreach (var report in _reports)
                {
                    <li>
                        <button type="button"
                                class="reports-list-row @(_selectedReportName == report.Name ? "selected" : null)"
                                data-report-name="@report.Name"
                                @onclick="() => SelectReportAsync(report)">
                            <span class="reports-list-name">@report.Name</span>
                            <span class="reports-list-meta">@BuildReportMetadata(report)</span>
                        </button>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="reports-viewer-pane">
        @if (_showMobileViewer)
        {
            <button type="button"
                    class="workspace-mobile-back"
                    @onclick="ShowListOnMobile"
                    aria-label="Back to reports list">
                ← Reports
            </button>
        }

        @if (_isLoadingReport)
        {
            <div class="workspace-state">Loading report…</div>
        }
        else if (!string.IsNullOrWhiteSpace(_selectedReportError))
        {
            <div class="workspace-state workspace-state-error">@_selectedReportError</div>
        }
        else if (_selectedReport is null)
        {
            <div class="workspace-state">Select a report to preview its contents.</div>
        }
        else
        {
            <header class="workspace-file-header">
                <h3>@($"reports/{_selectedReport.Name}")</h3>
                @if (ShowServerTruncationNotice || ShowClientTruncationNotice)
                {
                    <p class="workspace-file-truncation">
                        Content was truncated for safe preview. Open the file locally for the full report.
                    </p>
                }
                @if (!string.IsNullOrWhiteSpace(_markdownRenderNotice))
                {
                    <p class="report-render-notice">@_markdownRenderNotice</p>
                }
            </header>

            @if (!string.IsNullOrWhiteSpace(_renderedReportHtml))
            {
                <div class="report-content msg-content" data-testid="report-content-markdown">@((MarkupString)_renderedReportHtml)</div>
            }
            else
            {
                <pre class="workspace-file-content" data-testid="report-content-text">@DisplayReportContent</pre>
            }
        }
    </section>
</div>

@code {
    private const int MaxPreviewCharacters = 200_000;

    private readonly CancellationTokenSource _cts = new();
    private IReadOnlyList<ReportListItemDto> _reports = [];
    private bool _isLoadingReports = true;
    private bool _isLoadingReport;
    private string? _reportsLoadError;
    private string? _selectedReportError;
    private ReportContentDto? _selectedReport;
    private string? _selectedReportName;
    private string? _renderedReportHtml;
    private string? _markdownRenderNotice;
    private bool _showMobileViewer;

    [Parameter, EditorRequired]
    public string AgentId { get; set; } = default!;

    private string MobilePaneClass => _showMobileViewer ? "mobile-viewer" : "mobile-list";

    private bool ShowServerTruncationNotice =>
        _selectedReport is { } report && report.Content.Length < report.Size;

    private bool ShowClientTruncationNotice =>
        !string.IsNullOrEmpty(_selectedReport?.Content)
        && _selectedReport.Content.Length > MaxPreviewCharacters;

    private string DisplayReportContent
    {
        get
        {
            var content = _selectedReport?.Content ?? string.Empty;
            return content.Length <= MaxPreviewCharacters
                ? content
                : content[..MaxPreviewCharacters];
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadReportsAsync();
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }

    private async Task LoadReportsAsync()
    {
        _isLoadingReports = true;
        _reportsLoadError = null;

        try
        {
            var reports = await GatewayRestClient.GetReportsAsync(AgentId, _cts.Token);
            _reports = reports
                .OrderByDescending(report => report.LastModifiedUtc)
                .ThenBy(report => report.Name, StringComparer.OrdinalIgnoreCase)
                .ToArray();
        }
        catch (OperationCanceledException)
        {
            // Navigation away/dispose path.
        }
        catch (Exception)
        {
            _reportsLoadError = "Unable to load reports.";
        }
        finally
        {
            _isLoadingReports = false;
        }
    }

    private async Task SelectReportAsync(ReportListItemDto report)
    {
        _selectedReportName = report.Name;
        _selectedReport = null;
        _selectedReportError = null;
        _isLoadingReport = true;
        _renderedReportHtml = null;
        _markdownRenderNotice = null;

        try
        {
            var response = await GatewayRestClient.GetReportAsync(AgentId, report.Name, _cts.Token);
            if (response is null)
            {
                _selectedReportError = "Unable to load report content.";
                return;
            }

            _selectedReport = response;
            await RenderSelectedReportAsync(response);
            _showMobileViewer = true;
        }
        catch (OperationCanceledException)
        {
            // Navigation away/dispose path.
        }
        catch (Exception)
        {
            _selectedReportError = "Unable to load report content.";
        }
        finally
        {
            _isLoadingReport = false;
        }
    }

    private async Task RenderSelectedReportAsync(ReportContentDto report)
    {
        var content = report.Content;
        if (content.Length == 0)
            return;

        var preview = content.Length <= MaxPreviewCharacters
            ? content
            : content[..MaxPreviewCharacters];

        try
        {
            _renderedReportHtml = await JS.InvokeAsync<string>("BotNexus.renderMarkdown", preview);
        }
        catch (InvalidOperationException)
        {
            _markdownRenderNotice = "Markdown renderer unavailable. Showing plain text preview.";
        }
        catch (JSException)
        {
            _markdownRenderNotice = "Markdown renderer unavailable. Showing plain text preview.";
        }
    }

    private static string BuildReportMetadata(ReportListItemDto report)
    {
        var pieces = new List<string>(2);
        if (report.Size.HasValue)
            pieces.Add(FormatFileSize(report.Size.Value));

        var modified = report.LastModifiedUtc;
        if (modified.HasValue)
            pieces.Add(modified.Value.ToLocalTime().ToString("g"));

        return pieces.Count > 0
            ? string.Join(" • ", pieces)
            : "Markdown report";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
            return $"{bytes} B";

        if (bytes < 1024 * 1024)
            return $"{bytes / 1024d:0.#} KB";

        return $"{bytes / (1024d * 1024d):0.#} MB";
    }

    private void ShowListOnMobile()
    {
        _showMobileViewer = false;
    }
}
