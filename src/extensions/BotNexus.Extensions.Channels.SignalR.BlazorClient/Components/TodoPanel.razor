@using System.Text.Json
@inject IClientStateStore Store
@implements IDisposable

@*
    Per-conversation Todo panel (#1464 step 5). Read-only live view of the conversation's persisted
    todo plan. Hydrated from REST on conversation select and refreshed live via the TodoUpdated
    SignalR event. User-editing (check off / reorder) is a deliberate fast-follow per the issue.
*@

<div class="todo-panel" data-testid="todo-panel">
    @{
        var items = ParsedItems;
    }
    @if (items.Count == 0)
    {
        <div class="todo-empty-state" data-testid="todo-empty-state">
            No todo items yet. When the agent plans multi-step work with the <code>todo</code> tool,
            the checklist appears here and updates live.
        </div>
    }
    else
    {
        <div class="todo-progress" data-testid="todo-progress">
            <span class="todo-progress-count">@DoneCount(items) / @items.Count</span> done
        </div>
        <ul class="todo-list" data-testid="todo-list">
            @foreach (var item in items)
            {
                <li class="todo-item todo-status-@(item.Status)" data-testid="todo-item" data-status="@item.Status">
                    <span class="todo-item-box" aria-hidden="true">@StatusBox(item.Status)</span>
                    <span class="todo-item-text">@item.Text</span>
                    <span class="todo-item-status-label">@StatusLabel(item.Status)</span>
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string AgentId { get; set; } = default!;

    /// <summary>The conversation whose todo state is displayed. Null renders the empty state.</summary>
    [Parameter]
    public string? ConversationId { get; set; }

    private static readonly JsonSerializerOptions s_options = new()
    {
        PropertyNameCaseInsensitive = true,
    };

    private IReadOnlyList<TodoItemView> ParsedItems => Parse(TodoJson);

    private string? TodoJson
    {
        get
        {
            if (ConversationId is null)
                return null;
            return Store.GetConversation(ConversationId)?.TodoJson;
        }
    }

    /// <summary>Parses the persisted TodoJson document into display items. Tolerates null/blank/malformed input.</summary>
    private static IReadOnlyList<TodoItemView> Parse(string? todoJson)
    {
        if (string.IsNullOrWhiteSpace(todoJson))
            return [];

        try
        {
            var doc = JsonSerializer.Deserialize<TodoDocumentView>(todoJson, s_options);
            if (doc?.Items is null)
                return [];

            var result = new List<TodoItemView>(doc.Items.Count);
            foreach (var item in doc.Items)
            {
                if (item is null || string.IsNullOrWhiteSpace(item.Text))
                    continue;
                result.Add(new TodoItemView
                {
                    Text = item.Text!,
                    Status = NormalizeStatus(item.Status),
                });
            }
            return result;
        }
        catch (JsonException)
        {
            // Never throw on a malformed/legacy payload — just render empty.
            return [];
        }
    }

    private static string NormalizeStatus(string? status)
        => (status?.Trim().ToLowerInvariant()) switch
        {
            "in_progress" => "in_progress",
            "done" => "done",
            "cancelled" => "cancelled",
            _ => "pending",
        };

    private static int DoneCount(IReadOnlyList<TodoItemView> items)
    {
        var count = 0;
        foreach (var item in items)
        {
            if (item.Status == "done")
                count++;
        }
        return count;
    }

    private static string StatusBox(string status) => status switch
    {
        "done" => "\u2611",        // ballot box with check
        "in_progress" => "\u25D0", // half-filled circle
        "cancelled" => "\u2612",   // ballot box with X
        _ => "\u2610",             // empty ballot box
    };

    private static string StatusLabel(string status) => status switch
    {
        "in_progress" => "In progress",
        "done" => "Done",
        "cancelled" => "Cancelled",
        _ => "Pending",
    };

    protected override void OnInitialized()
    {
        Store.OnChanged += HandleStateChanged;
    }

    private void HandleStateChanged()
        => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Store.OnChanged -= HandleStateChanged;
    }

    private sealed class TodoDocumentView
    {
        public List<TodoItemDto>? Items { get; set; }
    }

    private sealed class TodoItemDto
    {
        public string? Text { get; set; }
        public string? Status { get; set; }
    }

    private sealed class TodoItemView
    {
        public string Text { get; set; } = string.Empty;
        public string Status { get; set; } = "pending";
    }
}
