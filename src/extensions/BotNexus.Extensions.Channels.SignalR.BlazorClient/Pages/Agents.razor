@page "/agents"
@inject NavigationManager Nav
@inject HttpClient Http
@inject GatewayHubConnection Hub
@implements IDisposable

<PageTitle>BotNexus — Agents</PageTitle>

<div class="agents-page">
    <header class="agents-toolbar">
        <h2>🤖 Agents</h2>
        <div class="agents-toolbar-actions">
            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <span class="agents-status @_statusClass" role="status">@_statusMessage</span>
            }
            <button class="toolbar-btn" @onclick="LoadAgentsAsync" disabled="@_loading" title="Refresh agent list">↻ Reload</button>
            <button class="toolbar-btn primary" @onclick="ShowAddForm" title="Add a new agent">+ Add Agent</button>
        </div>
    </header>

    @if (_loading)
    {
        <div class="config-loading" aria-live="polite">
            <div class="loading-spinner small"></div>
            <span>Loading agents…</span>
        </div>
    }
    else if (_error is not null)
    {
        <div class="agents-error" role="alert">⚠️ @_error</div>
    }
    else
    {
        @* Add / Edit form *@
        @if (_showForm)
        {
            <div class="agents-form-card">
                <h3>@(_editingId is not null ? $"Edit Agent: {_editingId}" : "Add Agent")</h3>
                <div class="agents-form-grid">
                    <label for="agent-id-input">Agent ID <span class="required">*</span></label>
                    <div>
                        <input id="agent-id-input" class="cfg-input @(HasFieldError("AgentId") ? "field-error" : "")"
                               value="@_form.AgentId" disabled="@(_editingId is not null)"
                               @oninput="OnAgentIdInput" aria-required="true" />
                        @if (HasFieldError("AgentId"))
                        {
                            <span class="agents-field-error" role="alert">@GetFieldError("AgentId")</span>
                        }
                    </div>

                    <label for="display-name-input">Display Name <span class="required">*</span></label>
                    <div>
                        <input id="display-name-input" class="cfg-input @(HasFieldError("DisplayName") ? "field-error" : "")"
                               value="@_form.DisplayName"
                               @oninput="OnDisplayNameInput" aria-required="true" />
                        @if (HasFieldError("DisplayName"))
                        {
                            <span class="agents-field-error" role="alert">@GetFieldError("DisplayName")</span>
                        }
                    </div>

                    <label for="description-input">Description</label>
                    <input id="description-input" class="cfg-input" value="@_form.Description"
                           @oninput="OnDescriptionInput" />

                    <label for="provider-input">Provider <span class="required">*</span></label>
                    <div>
                        @if (_providers.Count > 0)
                        {
                            <select id="provider-input" class="cfg-input @(HasFieldError("ApiProvider") ? "field-error" : "")"
                                    value="@_form.ApiProvider" @onchange="OnProviderChange" aria-required="true">
                                <option value="">— select provider —</option>
                                @foreach (var p in _providers)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input id="provider-input" class="cfg-input @(HasFieldError("ApiProvider") ? "field-error" : "")"
                                   value="@_form.ApiProvider" @oninput="OnProviderInput" placeholder="e.g. copilot" aria-required="true" />
                        }
                        @if (HasFieldError("ApiProvider"))
                        {
                            <span class="agents-field-error" role="alert">@GetFieldError("ApiProvider")</span>
                        }
                    </div>

                    <label for="model-id-input">Model ID <span class="required">*</span></label>
                    <div>
                        @if (_models.Count > 0)
                        {
                            <select id="model-id-input" class="cfg-input @(HasFieldError("ModelId") ? "field-error" : "")"
                                    value="@_form.ModelId" @onchange="OnModelChange" aria-required="true">
                                <option value="">— select model —</option>
                                @foreach (var m in _models)
                                {
                                    <option value="@m.ModelId">@m.Name</option>
                                }
                            </select>
                        }
                        else if (!string.IsNullOrEmpty(_form.ApiProvider) && !_loadingModels)
                        {
                            <input id="model-id-input" class="cfg-input @(HasFieldError("ModelId") ? "field-error" : "")"
                                   value="@_form.ModelId" @oninput="OnModelIdInput" placeholder="e.g. gpt-4.1" aria-required="true" />
                        }
                        else if (_loadingModels)
                        {
                            <span class="agents-field-loading">Loading models…</span>
                        }
                        else
                        {
                            <input id="model-id-input" class="cfg-input" value="@_form.ModelId" @oninput="OnModelIdInput"
                                   placeholder="Select a provider first" disabled />
                        }
                        @if (HasFieldError("ModelId"))
                        {
                            <span class="agents-field-error" role="alert">@GetFieldError("ModelId")</span>
                        }
                    </div>

                    <label for="system-prompt-input">System Prompt</label>
                    <textarea id="system-prompt-input" class="cfg-textarea" rows="4"
                              @oninput="OnSystemPromptInput">@_form.SystemPrompt</textarea>
                </div>
                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="agents-form-error" role="alert">⚠️ @_formError</div>
                }
                <div class="agents-form-actions">
                    <button class="toolbar-btn primary" @onclick="SaveFormAsync" disabled="@(_saving || !IsDirty)">
                        @(_saving ? "Saving…" : (_editingId is not null ? "💾 Save Changes" : "✓ Add Agent"))
                    </button>
                    <button class="toolbar-btn" @onclick="CancelForm" disabled="@_saving">Cancel</button>
                    @if (IsDirty)
                    {
                        <span class="agents-dirty-indicator" title="You have unsaved changes">● Unsaved changes</span>
                    }
                </div>
            </div>
        }

        @* Delete confirmation dialog *@
        @if (_confirmDeleteId is not null)
        {
            <div class="agents-confirm-overlay" @onclick="CancelDelete">
                <div class="agents-confirm-dialog" @onclick:stopPropagation="true" role="alertdialog"
                     aria-labelledby="delete-confirm-title">
                    <h4 id="delete-confirm-title">Delete Agent</h4>
                    <p>Are you sure you want to delete agent <strong>@_confirmDeleteId</strong>? This cannot be undone.</p>
                    <div class="agents-confirm-actions">
                        <button class="toolbar-btn danger" @onclick="ConfirmDeleteAsync" disabled="@_deleting">
                            @(_deleting ? "Deleting…" : "Delete")
                        </button>
                        <button class="toolbar-btn" @onclick="CancelDelete" disabled="@_deleting">Cancel</button>
                    </div>
                </div>
            </div>
        }

        @* Agent list *@
        @if (_agents.Count == 0 && !_showForm)
        {
            <div class="agents-empty">
                <p>No agents configured. Click <strong>+ Add Agent</strong> to create one.</p>
            </div>
        }
        else if (_agents.Count > 0)
        {
            <table class="agents-table" aria-label="Agent list">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Display Name</th>
                        <th>Provider</th>
                        <th>Model</th>
                        <th><span class="sr-only">Actions</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in _agents)
                    {
                        <tr>
                            <td class="agents-id">@agent.AgentId</td>
                            <td>@agent.DisplayName</td>
                            <td>@agent.ApiProvider</td>
                            <td>@agent.ModelId</td>
                            <td class="agents-actions">
                                <button class="agents-btn-edit" @onclick="() => EditAgent(agent)" title="Edit @agent.AgentId" aria-label="Edit @agent.AgentId">✏️</button>
                                <button class="agents-btn-delete" @onclick="() => RequestDelete(agent.AgentId!)" title="Delete @agent.AgentId" aria-label="Delete @agent.AgentId">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    }
</div>

@code {
    private record ProviderItem(string Id, string Name);
    private record ModelItem(string ModelId, string Name);

    private record AgentFormModel(
        string AgentId = "",
        string DisplayName = "",
        string Description = "",
        string ApiProvider = "",
        string ModelId = "",
        string? SystemPrompt = null);

    private record AgentRow(
        string? AgentId,
        string DisplayName,
        string? Description,
        string ApiProvider,
        string ModelId,
        string? SystemPrompt);

    private List<AgentRow> _agents = [];
    private List<ProviderItem> _providers = [];
    private List<ModelItem> _models = [];
    private bool _loading = true;
    private bool _loadingModels;
    private bool _saving;
    private bool _deleting;
    private string? _error;
    private string? _statusMessage;
    private string _statusClass = "";
    private bool _showForm;
    private string? _editingId;
    private AgentFormModel _form = new();
    private AgentFormModel _originalForm = new();
    private string? _formError;
    private string? _confirmDeleteId;
    private Dictionary<string, string> _fieldErrors = new();
    private CancellationTokenSource? _statusDismissCts;

    /// <summary>True when the form has been modified from its initial state.</summary>
    private bool IsDirty => _form != _originalForm;

    protected override async Task OnInitializedAsync()
    {
        Hub.OnAgentsChanged += HandleAgentsChanged;
        await Task.WhenAll(LoadAgentsAsync(), LoadProvidersAsync());
    }

    public void Dispose()
    {
        Hub.OnAgentsChanged -= HandleAgentsChanged;
        _statusDismissCts?.Cancel();
        _statusDismissCts?.Dispose();
    }

    private void HandleAgentsChanged(AgentsChangedPayload payload)
    {
        // Server notified that agents changed — refresh the list automatically
        _ = InvokeAsync(async () =>
        {
            await LoadAgentsAsync();
            SetStatus("Agent list updated from server.", "success");
            StateHasChanged();
        });
    }

    // ── Field-level validation helpers ─────────────────────────────────────
    private bool HasFieldError(string field) => _fieldErrors.ContainsKey(field);
    private string GetFieldError(string field) => _fieldErrors.GetValueOrDefault(field, "");

    private bool ValidateForm()
    {
        _fieldErrors.Clear();
        if (string.IsNullOrWhiteSpace(_form.AgentId))
            _fieldErrors["AgentId"] = "Agent ID is required.";
        if (string.IsNullOrWhiteSpace(_form.DisplayName))
            _fieldErrors["DisplayName"] = "Display Name is required.";
        if (string.IsNullOrWhiteSpace(_form.ApiProvider))
            _fieldErrors["ApiProvider"] = "Provider is required.";
        if (string.IsNullOrWhiteSpace(_form.ModelId))
            _fieldErrors["ModelId"] = "Model ID is required.";
        return _fieldErrors.Count == 0;
    }

    // ── Input handlers ─────────────────────────────────────────────────────
    private void OnAgentIdInput(ChangeEventArgs e)       => _form = _form with { AgentId = e.Value?.ToString() ?? "" };
    private void OnDisplayNameInput(ChangeEventArgs e)  => _form = _form with { DisplayName = e.Value?.ToString() ?? "" };
    private void OnDescriptionInput(ChangeEventArgs e)  => _form = _form with { Description = e.Value?.ToString() ?? "" };
    private void OnProviderInput(ChangeEventArgs e)     => _form = _form with { ApiProvider = e.Value?.ToString() ?? "" };
    private void OnModelIdInput(ChangeEventArgs e)      => _form = _form with { ModelId = e.Value?.ToString() ?? "" };
    private void OnSystemPromptInput(ChangeEventArgs e) => _form = _form with { SystemPrompt = e.Value?.ToString() };
    private void OnModelChange(ChangeEventArgs e)       => _form = _form with { ModelId = e.Value?.ToString() ?? "" };

    private async Task OnProviderChange(ChangeEventArgs e)
    {
        var provider = e.Value?.ToString() ?? "";
        _form = _form with { ApiProvider = provider, ModelId = "" };
        _models = [];
        if (!string.IsNullOrEmpty(provider))
            await LoadModelsAsync(provider);
    }

    private async Task LoadProvidersAsync()
    {
        try
        {
            var url = Nav.BaseUri.TrimEnd('/') + "/api/providers";
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var items = await Http.GetFromJsonAsync<List<ProviderItem>>(url, opts);
            _providers = items ?? [];
        }
        catch
        {
            _providers = [];
        }
    }

    private async Task LoadModelsAsync(string provider)
    {
        _loadingModels = true;
        StateHasChanged();
        try
        {
            var url = Nav.BaseUri.TrimEnd('/') + $"/api/models?provider={Uri.EscapeDataString(provider)}";
            var opts = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var items = await Http.GetFromJsonAsync<List<ModelItem>>(url, opts);
            _models = items ?? [];
        }
        catch
        {
            _models = [];
        }
        finally
        {
            _loadingModels = false;
        }
    }

    private async Task LoadAgentsAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            var apiUrl = Nav.BaseUri.TrimEnd('/') + "/api/agents";
            var rows = await Http.GetFromJsonAsync<List<AgentRow>>(apiUrl,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            _agents = rows ?? [];
        }
        catch (Exception ex)
        {
            _error = $"Failed to load agents: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void ShowAddForm()
    {
        _editingId = null;
        _form = new AgentFormModel();
        _originalForm = new AgentFormModel();
        _formError = null;
        _fieldErrors.Clear();
        _showForm = true;
    }

    private async Task EditAgent(AgentRow agent)
    {
        _editingId = agent.AgentId;
        _form = new AgentFormModel(
            agent.AgentId ?? "",
            agent.DisplayName,
            agent.Description ?? "",
            agent.ApiProvider,
            agent.ModelId,
            agent.SystemPrompt);
        _originalForm = _form;
        _formError = null;
        _fieldErrors.Clear();
        _models = [];
        if (!string.IsNullOrEmpty(agent.ApiProvider))
            await LoadModelsAsync(agent.ApiProvider);
        _showForm = true;
    }

    private void CancelForm()
    {
        _showForm = false;
        _editingId = null;
        _formError = null;
        _fieldErrors.Clear();
    }

    private async Task SaveFormAsync()
    {
        _formError = null;
        if (!ValidateForm())
            return;

        _saving = true;
        try
        {
            var apiUrl = Nav.BaseUri.TrimEnd('/') + "/api/agents";
            var payload = new
            {
                agentId = _form.AgentId,
                displayName = _form.DisplayName,
                description = string.IsNullOrWhiteSpace(_form.Description) ? null : _form.Description,
                apiProvider = _form.ApiProvider,
                modelId = _form.ModelId,
                systemPrompt = _form.SystemPrompt
            };

            HttpResponseMessage response;
            if (_editingId is not null)
                response = await Http.PutAsJsonAsync($"{apiUrl}/{_editingId}", payload);
            else
                response = await Http.PostAsJsonAsync(apiUrl, payload);

            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                _formError = $"Error {(int)response.StatusCode}: {body}";
                return;
            }

            var wasEditing = _editingId is not null;
            _showForm = false;
            _editingId = null;
            _fieldErrors.Clear();
            SetStatus(wasEditing ? "Agent updated." : "Agent created.", "success");
            await LoadAgentsAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ── Delete with confirmation ───────────────────────────────────────────
    private void RequestDelete(string agentId) => _confirmDeleteId = agentId;
    private void CancelDelete() => _confirmDeleteId = null;

    private async Task ConfirmDeleteAsync()
    {
        if (_confirmDeleteId is null) return;

        _deleting = true;
        var agentId = _confirmDeleteId;
        try
        {
            var apiUrl = Nav.BaseUri.TrimEnd('/') + $"/api/agents/{agentId}";
            var response = await Http.DeleteAsync(apiUrl);
            if (!response.IsSuccessStatusCode)
            {
                SetStatus($"Delete failed: {(int)response.StatusCode}", "error");
                return;
            }
            SetStatus($"Agent '{agentId}' removed.", "success");
            await LoadAgentsAsync();
        }
        catch (Exception ex)
        {
            SetStatus($"Delete error: {ex.Message}", "error");
        }
        finally
        {
            _deleting = false;
            _confirmDeleteId = null;
        }
    }

    private void SetStatus(string msg, string cssClass)
    {
        _statusMessage = msg;
        _statusClass = cssClass;

        // Auto-dismiss after 4 seconds
        _statusDismissCts?.Cancel();
        _statusDismissCts?.Dispose();
        _statusDismissCts = new CancellationTokenSource();
        var token = _statusDismissCts.Token;
        _ = DismissStatusAfterDelay(token);
    }

    private async Task DismissStatusAfterDelay(CancellationToken token)
    {
        try
        {
            await Task.Delay(4000, token);
            _statusMessage = null;
            _statusClass = "";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // Dismissed or replaced — ignore
        }
    }
}
