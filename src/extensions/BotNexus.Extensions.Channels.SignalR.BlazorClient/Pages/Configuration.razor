@page "/configuration"
@page "/configuration/{Section}"
@inject PlatformConfigService ConfigService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>BotNexus — Configuration</PageTitle>

<div class="platform-config-page">
    <header class="platform-config-toolbar">
        <h2>⚙️ Platform Configuration</h2>
        <div class="platform-config-actions">
            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <span class="platform-config-status @_statusClass">@_statusMessage</span>
            }
            <button class="toolbar-btn" @onclick="Validate" disabled="@_loading">✓ Validate</button>
            <button class="toolbar-btn" @onclick="LoadConfig" disabled="@_loading">↻ Reload</button>
            <button class="toolbar-btn primary" @onclick="SaveAll" disabled="@(!_dirty || _saving)">
                @(_saving ? "Saving…" : "💾 Save Changes")
            </button>
        </div>
    </header>

    @if (_loading)
    {
        <div class="config-loading">
            <div class="loading-spinner small"></div>
            <span>Loading configuration…</span>
        </div>
    }
    else if (_config is null)
    {
        <div class="empty-state">Failed to load configuration.</div>
    }
    else
    {
        <div class="config-page">
            <div class="config-panel-canvas">
                @switch (Section?.ToLowerInvariant() ?? "gateway")
                {
                    case "gateway":
                        <GatewayConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    case "providers":
                        <ProvidersConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    case "channels":
                        <ChannelsConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    case "locations":
                        <LocationsConfigPanel />
                        break;
                    case "world":
                        <WorldSettingsConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    case "cron":
                        <CronConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    case "apikey":
                        <ApiKeyConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                    default:
                        <GatewayConfigPanel Config="@_config" OnChanged="MarkDirty" />
                        break;
                }
            </div>
        </div>
    }

    @if (_validationResult is not null)
    {
        <div class="validation-overlay" @onclick="@(() => _validationResult = null)">
            <div class="validation-dialog" @onclick:stopPropagation="true">
                <h3>@(_validationResult.IsValid ? "✅ Configuration Valid" : "❌ Validation Errors")</h3>
                @if (_validationResult.ConfigPath is not null)
                {
                    <p class="text-muted">Path: @_validationResult.ConfigPath</p>
                }
                @if (_validationResult.Errors.Count > 0)
                {
                    <div class="validation-list errors">
                        @foreach (var err in _validationResult.Errors)
                        {
                            <div class="validation-item error">❌ @err</div>
                        }
                    </div>
                }
                @if (_validationResult.Warnings.Count > 0)
                {
                    <div class="validation-list warnings">
                        @foreach (var warn in _validationResult.Warnings)
                        {
                            <div class="validation-item warning">⚠️ @warn</div>
                        }
                    </div>
                }
                @if (_validationResult.IsValid && _validationResult.Warnings.Count == 0)
                {
                    <p>No errors or warnings found.</p>
                }
                <div class="validation-actions">
                    <button class="toolbar-btn" @onclick="@(() => _validationResult = null)">Close</button>
                </div>
            </div>
        </div>
    }
</div>
