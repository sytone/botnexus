@page "/cron"
@using System.Text.Json
@inject CronApiClient CronApi
@inject HttpClient Http
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>BotNexus - Cron Jobs</PageTitle>

<div class="agents-page" data-testid="cron-jobs-page">
    <header class="agents-toolbar">
        <h2>&#x23F0; Cron Jobs</h2>
        <div class="agents-toolbar-actions">
            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <span class="agents-status @_statusClass" role="status">@_statusMessage</span>
            }
            <button class="toolbar-btn" @onclick="LoadJobsAsync" disabled="@_loading" title="Refresh cron job list">&#x21BB; Reload</button>
        </div>
    </header>

    @if (_loading)
    {
        <div class="config-loading" aria-live="polite">
            <div class="loading-spinner small"></div>
            <span>Loading cron jobs.</span>
        </div>
    }
    else if (_error is not null)
    {
        <div class="agents-error" role="alert">&#x26A0;&#xFE0F; @_error</div>
    }
    else if (_jobs.Count == 0)
    {
        <div class="agents-empty"><p>No cron jobs configured.</p></div>
    }
    else
    {
        @if (_confirmDeleteId is not null)
        {
            <div class="agents-confirm-overlay" @onclick="CancelDelete">
                <div class="agents-confirm-dialog" @onclick:stopPropagation="true" role="alertdialog"
                     aria-labelledby="cron-delete-confirm-title">
                    <h4 id="cron-delete-confirm-title">Delete Cron Job</h4>
                    <p>Are you sure you want to delete cron job <strong>@_confirmDeleteName</strong>? This cannot be undone.</p>
                    <div class="agents-confirm-actions">
                        <button class="toolbar-btn danger" @onclick="ConfirmDeleteAsync" disabled="@_busy">@(_busy ? "Deleting." : "Delete")</button>
                        <button class="toolbar-btn" @onclick="CancelDelete" disabled="@_busy">Cancel</button>
                    </div>
                </div>
            </div>
        }

        <section class="cron-selector-section" aria-label="Cron job selection">
            <label class="cron-selector-label">Select a cron job</label>
            <div class="cron-rich-select">
                <button type="button" class="cron-rich-select-toggle" data-testid="cron-job-selector-toggle"
                        @onclick="ToggleSelector" aria-expanded="@_selectorOpen">
                    @if (_selectedJob is null)
                    {
                        <span class="cron-selector-placeholder">Choose a job to view and edit</span>
                    }
                    else
                    {
                        <span class="cron-selector-option-main">
                            <strong>@_selectedJob.Name</strong>
                            <span>@_selectedJob.Schedule</span>
                        </span>
                        <span class="cron-selector-option-meta">
                            <span>@_selectedJob.ActionType</span>
                            <span>@OwnerLabel(_selectedJob)</span>
                        </span>
                    }
                    <span class="cron-selector-chevron" aria-hidden="true">&#x25BE;</span>
                </button>
                @if (_selectorOpen)
                {
                    <div class="cron-rich-select-menu" role="listbox" aria-label="Cron jobs">
                        @foreach (var job in _jobs)
                        {
                            <button type="button" class="cron-rich-select-option @(job.Id == _selectedJob?.Id ? "selected" : "")"
                                    role="option" aria-selected="@(job.Id == _selectedJob?.Id)"
                                    data-testid="cron-job-option" @onclick="() => SelectJobAsync(job)">
                                <span class="cron-selector-option-main">
                                    <strong>@job.Name</strong>
                                    <span class="agents-id">@job.Schedule</span>
                                </span>
                                <span class="cron-selector-option-meta">
                                    <span>@job.ActionType</span>
                                    <span>@OwnerLabel(job)</span>
                                </span>
                            </button>
                        }
                    </div>
                }
            </div>
        </section>

        @if (_selectedJob is null || _editJob is null)
        {
            <div class="agents-empty cron-selection-empty">
                <p>Select a cron job above to view its settings and execution history.</p>
            </div>
        }
        else
        {
            <section class="cron-page-card" data-testid="cron-job-editor">
                <header class="cron-page-card-header">
                    <div>
                        <h3>Edit Cron Job</h3>
                        <div class="cron-page-card-subtitle">
                            <span class="agents-id">@_editJob.Id</span>
                            @if (_editJob.System) { <span class="badge badge-system">System</span> }
                            @if (_editJob.Enabled) { <span class="badge badge-enabled">Enabled</span> }
                            else { <span class="badge badge-disabled">Disabled</span> }
                        </div>
                    </div>
                    <div class="cron-page-actions">
                        @if (ConversationLink(_editJob) is { } conversationLink)
                        {
                            <a class="toolbar-btn" href="@conversationLink">&#x1F4AC; Related conversation</a>
                        }
                        <button class="toolbar-btn" @onclick="() => RunNowAsync(_editJob)" disabled="@_busy"
                                aria-label="Run @_editJob.Name now">&#x25B6;&#xFE0F; Run now</button>
                        <button class="toolbar-btn danger" @onclick="() => RequestDelete(_editJob)" disabled="@_busy"
                                aria-label="Delete @_editJob.Name">Delete</button>
                    </div>
                </header>

                <div class="cron-page-card-body">
                    <div class="cron-edit-grid">
                        <div class="cron-edit-field">
                            <label for="cron-edit-name">Name</label>
                            <input id="cron-edit-name" type="text" @bind="_editJob.Name" />
                        </div>
                        <div class="cron-edit-field">
                            <label for="cron-edit-schedule">Schedule (cron expression)</label>
                            <input id="cron-edit-schedule" type="text" @bind="_editJob.Schedule" placeholder="0 * * * *" />
                        </div>
                        <div class="cron-edit-field">
                            <label for="cron-edit-timezone">Time Zone</label>
                            <input id="cron-edit-timezone" type="text" @bind="_editJob.TimeZone" placeholder="UTC" />
                        </div>
                    </div>

                    <dl class="cron-detail-props cron-static-props">
                        <dt>Action Type</dt><dd>@_editJob.ActionType</dd>
                        <dt>Owning Agent</dt><dd>@OwnerLabel(_editJob)</dd>
                        <dt>Created</dt><dd>@FormatTimestamp(_editJob.CreatedAt)@(string.IsNullOrEmpty(_editJob.CreatedBy) ? "" : $" by {_editJob.CreatedBy}")</dd>
                        <dt>Next Run</dt><dd>@FormatTimestamp(_editJob.NextRunAt)</dd>
                        <dt>Last Run</dt><dd>@FormatTimestamp(_editJob.LastRunAt) @if (!string.IsNullOrEmpty(_editJob.LastRunStatus)) { <span class="cron-run-status @RunStatusClass(_editJob.LastRunStatus)">@_editJob.LastRunStatus</span> }</dd>
                        @if (!string.IsNullOrEmpty(_editJob.LastRunError)) { <dt>Last Error</dt><dd class="cron-detail-error">@_editJob.LastRunError</dd> }
                    </dl>

                    @if (string.Equals(_editJob.ActionType, "agent-prompt", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="cron-edit-field">
                            <label for="cron-edit-message">Message</label>
                            <textarea id="cron-edit-message" rows="7" @bind="_editJob.Message"></textarea>
                        </div>
                        <div class="cron-edit-grid">
                            <div class="cron-edit-field">
                                <label for="cron-edit-provider">Provider</label>
                                <select id="cron-edit-provider" data-testid="cron-edit-provider" value="@_editProvider" @onchange="OnProviderChange">
                                    <option value="">(agent default)</option>
                                    @foreach (var provider in _providers) { <option value="@provider.Id">@provider.Name</option> }
                                </select>
                            </div>
                            <div class="cron-edit-field">
                                <label for="cron-edit-model">Model</label>
                                @if (_loadingModels)
                                {
                                    <span class="agents-field-loading">Loading models.</span>
                                }
                                else if (_models.Count > 0)
                                {
                                    <select id="cron-edit-model" data-testid="cron-edit-model" value="@_editJob.Model" @onchange="OnModelChange">
                                        <option value="">(agent default)</option>
                                        @foreach (var model in _models) { <option value="@model.ModelId">@model.Name</option> }
                                    </select>
                                }
                                else
                                {
                                    <input id="cron-edit-model" data-testid="cron-edit-model" type="text" @bind="_editJob.Model" placeholder="Select a provider to list models" />
                                }
                            </div>
                        </div>
                    }
                    else if (string.Equals(_editJob.ActionType, "command", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="cron-edit-field"><label for="cron-edit-shell">Shell Command</label><textarea id="cron-edit-shell" rows="7" @bind="_editJob.ShellCommand"></textarea></div>
                    }
                    else if (string.Equals(_editJob.ActionType, "webhook", StringComparison.OrdinalIgnoreCase))
                    {
                        <div class="cron-edit-field"><label for="cron-edit-webhook">Webhook URL</label><input id="cron-edit-webhook" type="text" @bind="_editJob.WebhookUrl" /></div>
                    }
                    <div class="cron-edit-field cron-edit-field-inline">
                        <label for="cron-edit-enabled"><input id="cron-edit-enabled" type="checkbox" @bind="_editJob.Enabled" /> Enabled</label>
                    </div>
                </div>
                <footer class="cron-page-card-footer">
                    <button class="toolbar-btn primary" @onclick="SaveEditAsync" disabled="@_busy"
                            aria-label="Save @_editJob.Name">@(_busy ? "Saving." : "Save changes")</button>
                    <button class="toolbar-btn" @onclick="ResetEdit">Reset</button>
                </footer>
            </section>

            <section class="cron-page-card cron-history-card">
                <header class="cron-page-card-header"><h3>Execution History</h3></header>
                <div class="cron-page-card-body">
                    @if (_loadingRuns)
                    {
                        <div class="config-loading" aria-live="polite"><div class="loading-spinner small"></div><span>Loading run history.</span></div>
                    }
                    else if (_runs.Count == 0)
                    {
                        <div class="cron-detail-empty">No execution history recorded yet.</div>
                    }
                    else
                    {
                        <table class="agents-table cron-runs-table" aria-label="Execution history" data-testid="cron-runs-table">
                            <thead><tr><th>Started</th><th>Duration</th><th>Status</th><th>Session / Conversation</th></tr></thead>
                            <tbody>
                                @foreach (var run in _runs)
                                {
                                    <tr data-testid="cron-run-row">
                                        <td class="agents-id">@FormatTimestamp(run.StartedAt)</td>
                                        <td>@FormatDuration(run.StartedAt, run.CompletedAt)</td>
                                        <td><span class="cron-run-status @RunStatusClass(run.Status)">@run.Status</span></td>
                                        <td class="agents-id">
                                            @if (!string.IsNullOrEmpty(run.SessionId))
                                            {
                                                @if (ConversationLink(_editJob) is { } runLink) { <a href="@runLink">@run.SessionId</a> }
                                                else { @run.SessionId }
                                            }
                                            else { <span>—</span> }
                                            @if (!string.IsNullOrEmpty(run.Error)) { <div class="cron-detail-error">@run.Error</div> }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    private List<CronJobDto> _jobs = [];
    private CronJobDto? _selectedJob;
    private CronJobDto? _editJob;
    private List<CronRunDto> _runs = [];
    private bool _loading = true;
    private bool _loadingRuns;
    private bool _busy;
    private bool _selectorOpen;
    private string? _error;
    private string? _statusMessage;
    private string _statusClass = "";
    private string? _confirmDeleteId;
    private string? _confirmDeleteName;
    private List<ProviderItem> _providers = [];
    private List<ModelItem> _models = [];
    private string _editProvider = "";
    private bool _loadingModels;
    private CancellationTokenSource? _statusDismissCts;

    private sealed record ProviderItem(string Id, string Name);
    private sealed record ModelItem(string ModelId, string Name, string? Provider = null);

    protected override async Task OnInitializedAsync() => await LoadJobsAsync();

    public void Dispose()
    {
        _statusDismissCts?.Cancel();
        _statusDismissCts?.Dispose();
    }

    private async Task LoadJobsAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();
        var selectedId = _selectedJob?.Id;
        var (jobs, error) = await CronApi.ListAsync();
        if (error is not null) _error = $"Failed to load cron jobs: {error}";
        else
        {
            _jobs = jobs.OrderBy(job => job.Name, StringComparer.OrdinalIgnoreCase).ToList();
            if (selectedId is not null && _jobs.FirstOrDefault(job => job.Id == selectedId) is { } selected)
                await SelectJobAsync(selected);
        }
        _loading = false;
        StateHasChanged();
    }

    private void ToggleSelector() => _selectorOpen = !_selectorOpen;

    private async Task SelectJobAsync(CronJobDto job)
    {
        _selectorOpen = false;
        _selectedJob = job;
        CloneForEdit(job);
        _runs = [];
        _loadingRuns = true;
        StateHasChanged();

        var runsTask = CronApi.RunsAsync(job.Id, 30);
        if (string.Equals(job.ActionType, "agent-prompt", StringComparison.OrdinalIgnoreCase))
            _ = InitProviderModelPickersAsync(job);

        var (runs, _) = await runsTask;
        if (_selectedJob?.Id != job.Id) return;
        _runs = runs.OrderByDescending(run => run.StartedAt).ToList();
        _loadingRuns = false;
        StateHasChanged();
    }

    private void CloneForEdit(CronJobDto job)
    {
        _editJob = new CronJobDto
        {
            Id = job.Id, Name = job.Name, Schedule = job.Schedule, ActionType = job.ActionType,
            AgentId = job.AgentId, Message = job.Message, TemplateName = job.TemplateName,
            Model = job.Model, WebhookUrl = job.WebhookUrl, ShellCommand = job.ShellCommand,
            Enabled = job.Enabled, System = job.System, TimeZone = job.TimeZone,
            CreatedBy = job.CreatedBy, CreatedAt = job.CreatedAt, LastRunAt = job.LastRunAt,
            NextRunAt = job.NextRunAt, LastRunStatus = job.LastRunStatus,
            LastRunError = job.LastRunError, ConversationId = job.ConversationId,
        };
        _providers = [];
        _models = [];
        _editProvider = "";
    }

    private void ResetEdit()
    {
        if (_selectedJob is not null) CloneForEdit(_selectedJob);
    }

    private async Task InitProviderModelPickersAsync(CronJobDto job)
    {
        await LoadProvidersAsync();
        if (_selectedJob?.Id != job.Id) return;
        if (!string.IsNullOrEmpty(job.Model))
        {
            foreach (var provider in _providers)
            {
                var models = await FetchModelsAsync(provider.Id);
                if (_selectedJob?.Id != job.Id) return;
                if (models.Any(model => string.Equals(model.ModelId, job.Model, StringComparison.OrdinalIgnoreCase)))
                {
                    _editProvider = provider.Id;
                    _models = models;
                    break;
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadProvidersAsync()
    {
        try
        {
            var url = Nav.BaseUri.TrimEnd('/') + "/api/providers";
            _providers = await Http.GetFromJsonAsync<List<ProviderItem>>(url, JsonOptions()) ?? [];
        }
        catch { _providers = []; }
    }

    private async Task<List<ModelItem>> FetchModelsAsync(string provider)
    {
        try
        {
            var url = Nav.BaseUri.TrimEnd('/') + $"/api/models?provider={Uri.EscapeDataString(provider)}";
            return await Http.GetFromJsonAsync<List<ModelItem>>(url, JsonOptions()) ?? [];
        }
        catch { return []; }
    }

    private static JsonSerializerOptions JsonOptions() => new() { PropertyNameCaseInsensitive = true };

    private async Task OnProviderChange(ChangeEventArgs e)
    {
        _editProvider = e.Value?.ToString() ?? "";
        _models = [];
        if (_editJob is not null) _editJob.Model = null;
        if (string.IsNullOrEmpty(_editProvider)) { StateHasChanged(); return; }
        _loadingModels = true;
        StateHasChanged();
        _models = await FetchModelsAsync(_editProvider);
        _loadingModels = false;
        StateHasChanged();
    }

    private void OnModelChange(ChangeEventArgs e)
    {
        if (_editJob is not null)
        {
            var value = e.Value?.ToString();
            _editJob.Model = string.IsNullOrEmpty(value) ? null : value;
        }
    }

    private async Task SaveEditAsync()
    {
        if (_editJob is null) return;
        _busy = true;
        var (_, error) = await CronApi.UpdateAsync(_editJob.Id, _editJob);
        _busy = false;
        if (error is not null) { SetStatus($"Save failed: {error}", "error"); return; }
        SetStatus($"Cron job '{_editJob.Name}' saved.", "success");
        await LoadJobsAsync();
    }

    private async Task RunNowAsync(CronJobDto job)
    {
        _busy = true;
        var (success, error) = await CronApi.RunNowAsync(job.Id);
        _busy = false;
        if (!success) { SetStatus($"Run failed: {error}", "error"); return; }
        SetStatus($"Triggered '{job.Name}'.", "success");
        await SelectJobAsync(_selectedJob ?? job);
    }

    private void RequestDelete(CronJobDto job)
    {
        _confirmDeleteId = job.Id;
        _confirmDeleteName = job.Name;
    }

    private void CancelDelete()
    {
        _confirmDeleteId = null;
        _confirmDeleteName = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_confirmDeleteId is null) return;
        _busy = true;
        var name = _confirmDeleteName;
        var (success, error) = await CronApi.DeleteAsync(_confirmDeleteId);
        _busy = false;
        if (!success) { SetStatus($"Delete failed: {error}", "error"); return; }
        SetStatus($"Cron job '{name}' removed.", "success");
        _confirmDeleteId = null;
        _confirmDeleteName = null;
        _selectedJob = null;
        _editJob = null;
        _runs = [];
        await LoadJobsAsync();
    }

    private static string OwnerLabel(CronJobDto job) => string.IsNullOrEmpty(job.AgentId) ? "No agent" : job.AgentId;

    private static string FormatTimestamp(DateTimeOffset? timestamp)
        => timestamp is null || timestamp.Value == default ? "—" : timestamp.Value.ToLocalTime().ToString("MMM d, h:mm tt");

    private static string FormatDuration(DateTimeOffset start, DateTimeOffset? end)
    {
        if (end is null || end.Value == default) return "—";
        var span = end.Value - start;
        if (span < TimeSpan.Zero) return "—";
        if (span.TotalSeconds < 1) return $"{span.TotalMilliseconds:F0} ms";
        if (span.TotalMinutes < 1) return $"{span.TotalSeconds:F1} s";
        if (span.TotalHours < 1) return $"{span.Minutes}m {span.Seconds}s";
        return $"{(int)span.TotalHours}h {span.Minutes}m";
    }

    private static string RunStatusClass(string? status) => status?.ToLowerInvariant() switch
    {
        "ok" or "success" or "completed" => "cron-run-status-ok",
        "error" or "failed" => "cron-run-status-error",
        "timedout" or "timeout" => "cron-run-status-warn",
        "running" => "cron-run-status-running",
        _ => "cron-run-status-neutral"
    };

    private static string? ConversationLink(CronJobDto job)
    {
        if (string.IsNullOrEmpty(job.AgentId) || string.IsNullOrEmpty(job.ConversationId)) return null;
        return $"chat/{Uri.EscapeDataString(job.AgentId)}/{Uri.EscapeDataString(job.ConversationId)}";
    }

    private void SetStatus(string message, string cssClass)
    {
        _statusMessage = message;
        _statusClass = cssClass;
        _statusDismissCts?.Cancel();
        _statusDismissCts?.Dispose();
        _statusDismissCts = new CancellationTokenSource();
        _ = DismissStatusAfterDelay(_statusDismissCts.Token);
    }

    private async Task DismissStatusAfterDelay(CancellationToken token)
    {
        try
        {
            await Task.Delay(4000, token);
            _statusMessage = null;
            _statusClass = "";
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }
}
