@page "/"
@inject AgentSessionManager Manager
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>BotNexus</PageTitle>

<div class="main-grid">
    @* ── Agent sidebar ─────────────────────────────────────── *@
    <nav class="agent-list">
        <h3>Agents</h3>
        <ConnectionStatus Hub="@Manager.Hub" />

        @if (Manager.Sessions.Count == 0 && Manager.Hub.IsConnected)
        {
            <p class="text-muted">No agents available.</p>
        }

        @foreach (var (agentId, state) in Manager.Sessions)
        {
            <button class="agent-tab @(agentId == Manager.ActiveAgentId ? "selected" : "")"
                    @onclick="() => SelectAgent(agentId)">
                <div class="agent-tab-content">
                    <span class="agent-name">@state.DisplayName</span>
                    <span class="agent-id">@agentId</span>
                </div>
                <div class="agent-tab-badges">
                    @if (state.UnreadCount > 0)
                    {
                        <span class="unread-badge">@state.UnreadCount</span>
                    }
                    @if (state.IsStreaming)
                    {
                        <span class="agent-streaming-dot" title="Streaming…">●</span>
                    }
                </div>
            </button>
        }
    </nav>

    @* ── Chat area — one panel per agent, show/hide for instant switching ── *@
    <section class="chat-area">
        @if (Manager.ActiveAgentId is null)
        {
            <div class="empty-state">
                <p>Select an agent to start chatting.</p>
            </div>
        }

        @foreach (var (agentId, state) in Manager.Sessions)
        {
            <div class="chat-panel-wrapper @(agentId == Manager.ActiveAgentId ? "active" : "hidden")">
                <ChatPanel State="@state" Manager="@Manager" />
            </div>
        }
    </section>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Manager.OnStateChanged += HandleStateChanged;

        try
        {
            var baseUri = new Uri(Nav.BaseUri);
            var hubUrl = new Uri(baseUri, "/hub/gateway").ToString();
            await Manager.InitializeAsync(hubUrl);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Hub connection failed: {ex.Message}");
        }
    }

    private void HandleStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task SelectAgent(string agentId)
    {
        await Manager.SetActiveAgentAsync(agentId);
    }

    public void Dispose()
    {
        Manager.OnStateChanged -= HandleStateChanged;
    }
}
