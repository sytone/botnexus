<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>BotNexus.Extensions.McpInvoke</RootNamespace>
    <Description>Single invoke_mcp tool for skill-driven MCP access. Lazy server lifecycle, no tool description flooding.</Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="BotNexus.Extensions.McpInvoke.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\agent\BotNexus.Agent.Core\BotNexus.Agent.Core.csproj" />
    <ProjectReference Include="..\..\agent\BotNexus.Agent.Providers.Core\BotNexus.Agent.Providers.Core.csproj" />
    <ProjectReference Include="..\..\gateway\BotNexus.Gateway.Contracts\BotNexus.Gateway.Contracts.csproj" />
    <ProjectReference Include="..\BotNexus.Extensions.Mcp\BotNexus.Extensions.Mcp.csproj" />
  </ItemGroup>

  <!-- Copy extension output + manifest to artifacts/extensions/ for dev-time discovery -->
  <Target Name="CopyExtensionToArtifacts" AfterTargets="Build">
    <PropertyGroup>
      <ExtensionArtifactDir>$(MSBuildThisFileDirectory)..\..\..\artifacts\extensions\botnexus-mcp-invoke\</ExtensionArtifactDir>
    </PropertyGroup>
    <MakeDir Directories="$(ExtensionArtifactDir)" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ExtensionArtifactDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="$(MSBuildThisFileDirectory)botnexus-extension.json" DestinationFolder="$(ExtensionArtifactDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
