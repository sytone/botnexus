<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <!--
      Extension assemblies are loaded into an isolated AssemblyLoadContext at runtime, so their
      managed NuGet dependency closure must ship in the extension output/deploy directory. Library
      projects do NOT copy transitive managed dependencies by default (only project-reference DLLs
      and native runtimes land in bin), so the ALC cannot resolve a third-party managed dependency
      that the host gateway does not already have loaded - it fails with FileNotFoundException at
      load/dispose time and can crash the host. Copying the lock-file assembly closure fixes this.
      Same class of defect as the ServiceBus adapter (#2001). See issue #2184.
    -->
    <CopyLocalLockFileAssemblies>true</CopyLocalLockFileAssemblies>
  </PropertyGroup>
  <PropertyGroup>
    <RootNamespace>BotNexus.Extensions.Channels.Agent365</RootNamespace>
    <Description>Microsoft 365 Agents SDK channel adapter — bridges the Activity protocol to the BotNexus routing pipeline (Register tier).</Description>
  </PropertyGroup>
  <ItemGroup>
    <!-- Required for the inbound Agents SDK message endpoint (ASP.NET controller/minimal API). -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <!--
      Microsoft 365 Agents SDK (net8.0-targeted packages, consumed here on net10.0). These packages
      pull in the STABLE Microsoft.Extensions.* 10.0.7 line transitively. BotNexus centrally pins the
      10.0.0-preview.3 line for the packages it references DIRECTLY, but this project does not add a
      direct PackageReference to any Microsoft.Extensions.* package, so Central Package Management
      imposes no version constraint on the SDK's transitive 10.0.7 closure and there is no NU1605
      downgrade (10.0.7 > preview.3, so nothing is downgraded). Nothing project-references this
      extension — it is loaded dynamically via the AssemblyLoadContext extension loader into its own
      ALC at runtime — so the newer Microsoft.Extensions.* stays isolated to this leaf and the
      Cli/Gateway/Scenarios build graphs keep the pinned preview line untouched.
    -->
    <PackageReference Include="Microsoft.Agents.Builder" />
    <PackageReference Include="Microsoft.Agents.Connector" />
    <PackageReference Include="Microsoft.Agents.Core" />
    <PackageReference Include="Microsoft.Agents.Authentication.Msal" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="BotNexus.Extensions.Channels.Agent365.Tests" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="botnexus-extension.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\domain\BotNexus.Domain\BotNexus.Domain.csproj" />
    <ProjectReference Include="..\..\gateway\BotNexus.Gateway.Abstractions\BotNexus.Gateway.Abstractions.csproj" />
    <ProjectReference Include="..\..\gateway\BotNexus.Gateway.Contracts\BotNexus.Gateway.Contracts.csproj" />
    <ProjectReference Include="..\..\gateway\BotNexus.Gateway.Channels\BotNexus.Gateway.Channels.csproj" />
  </ItemGroup>
</Project>
