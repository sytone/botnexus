@page "/"
@inject IClientStateStore Store
@inject IAgentInteractionService Interaction
@inject IPortalLoadService PortalLoad
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>BotNexus</PageTitle>

@if (!PortalLoad.IsReady)
{
    <div class="portal-loading">
        @if (PortalLoad.LoadError is not null)
        {
            <div class="portal-load-error">&#x26A0; @PortalLoad.LoadError</div>
        }
        else
        {
            <div class="portal-load-spinner">Connecting&#x2026;</div>
        }
    </div>
}
else
{
    var activeAgent = Store.ActiveAgentId is not null ? Store.GetAgent(Store.ActiveAgentId) : null;
    var activeConvId = activeAgent?.ActiveConversationId;
    var messages = activeConvId is not null ? Store.GetMessages(activeConvId) : [];
    var streamState = activeConvId is not null ? Store.GetStreamState(activeConvId) : null;
    var conversations = activeAgent?.Conversations.Values
        .Where(c => c.Status == "Active")
        .OrderByDescending(c => c.UpdatedAt)
        .ToList() ?? [];

    <div class="mobile-app">

        <!-- TOP BAR -->
        <div class="top-bar">
            <select class="agent-select" value="@Store.ActiveAgentId" @onchange="OnAgentChanged">
                @foreach (var (agentId, agent) in Store.Agents)
                {
                    <option value="@agentId">@(agent.Emoji is not null ? agent.Emoji + " " : "")@agent.DisplayName</option>
                }
            </select>

            <select @key="Store.ActiveAgentId" class="conv-select" value="@activeConvId" @onchange="OnConvChanged">
                @foreach (var conv in conversations)
                {
                    <option value="@conv.ConversationId">@conv.Title</option>
                }
            </select>

            <div class="overflow-menu-wrapper">
                <button class="overflow-btn" @onclick="ToggleMenu" aria-label="Menu">&#x22EE;</button>
                @if (_menuOpen)
                {
                    <div class="overflow-dropdown">
                        <div class="menu-session-id" title="Session ID">
                            <span>Session: </span><span class="session-id-text">@(activeAgent?.SessionId ?? "&#x2014;")</span>
                        </div>
                        <button class="menu-action" @onclick="NewSession">New session</button>
                    </div>
                }
            </div>
        </div>

        <!-- TOOL CALL MODAL -->
        @if (_modalToolMessage is not null)
        {
            var m = _modalToolMessage;
            <div class="tool-modal-backdrop" @onclick="CloseToolModal">
                <div class="tool-modal" @onclick:stopPropagation="true">
                    <div class="tool-modal-header">
                        <span class="tool-modal-icon">@(m.ToolResult is null ? "&#x23F3;" : (m.ToolIsError == true ? "&#x274C;" : "&#x2705;"))</span>
                        <span class="tool-modal-name">@m.ToolName</span>
                        @if (m.ToolDuration is not null)
                        {
                            <span class="tool-modal-duration">@FormatDuration(m.ToolDuration.Value)</span>
                        }
                        <button class="tool-modal-close" @onclick="CloseToolModal" aria-label="Close">&#x2715;</button>
                    </div>
                    @if (m.ToolArgs is not null)
                    {
                        <div class="tool-modal-section">
                            <div class="tool-modal-section-label">Arguments</div>
                            <pre class="tool-modal-content">@m.ToolArgs</pre>
                        </div>
                    }
                    @if (m.ToolResult is not null)
                    {
                        <div class="tool-modal-section">
                            <div class="tool-modal-section-label">Result</div>
                            <pre class="tool-modal-content">@m.ToolResult</pre>
                        </div>
                    }
                    @if (m.ToolArgs is null && m.ToolResult is null && !string.IsNullOrEmpty(m.Content))
                    {
                        <div class="tool-modal-section">
                            <pre class="tool-modal-content">@m.Content</pre>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- MESSAGE STREAM -->
        <div class="message-stream" @ref="_messageStreamRef">
            @foreach (var msg in messages)
            {
                @if (msg.IsToolCall)
                {
                    <button class="tool-pill @(msg.ToolIsError == true ? "tool-pill-error" : "")" @onclick="() => OpenToolModal(msg)" type="button">
                        <span class="tool-pill-icon">@(msg.ToolResult is null ? "&#x23F3;" : (msg.ToolIsError == true ? "&#x274C;" : "&#x2705;"))</span>
                        <span class="tool-pill-name">@msg.ToolName</span>
                        @if (msg.ToolDuration is not null)
                        {
                            <span class="tool-pill-duration">@FormatDuration(msg.ToolDuration.Value)</span>
                        }
                        <span class="tool-pill-tap">&#x25B8;</span>
                    </button>
                }
                else
                {
                    <div class="message @GetMessageClass(msg)">
                        @if (msg.Role == "assistant" && _markdownCache.TryGetValue(msg.Id, out var rendered))
                        {
                            <div class="message-content">@((MarkupString)rendered)</div>
                        }
                        else
                        {
                            <div class="message-content">@msg.Content</div>
                        }
                        <div class="message-time">@msg.Timestamp.ToLocalTime().ToString("HH:mm")</div>
                    </div>
                }
            }

            @if (streamState?.IsStreaming == true && !string.IsNullOrEmpty(streamState.Buffer))
            {
                <div class="message assistant streaming">
                    <div class="message-content">@streamState.Buffer<span class="stream-cursor">&#x258C;</span></div>
                </div>
            }
        </div>

        <!-- BOTTOM BAR -->
        <div class="bottom-bar">
            <textarea
                class="input-textarea"
                placeholder="Message&#x2026;"
                rows="1"
                @bind="_inputText"
                @bind:event="oninput"
                @onkeydown="OnKeyDown"
                disabled="@_isSending">
            </textarea>
            <button class="send-btn" @onclick="SendMessage" disabled="@(_isSending || string.IsNullOrWhiteSpace(_inputText))">
                &#x2192;
            </button>
        </div>

    </div>
}

@code {
    private string _inputText = "";
    private bool _isSending;
    private bool _menuOpen;
    private ElementReference _messageStreamRef;
    private readonly Dictionary<string, string> _markdownCache = new();
    private ChatMessage? _modalToolMessage;

    protected override async Task OnInitializedAsync()
    {
        Store.OnChanged += HandleStateChanged;
        PortalLoad.OnReadyChanged += HandleStateChanged;

        var origin = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);
        var hubUrl = $"{origin}/hub/gateway";
        await PortalLoad.InitializeAsync(hubUrl);
    }

    private void HandleStateChanged()
    {
        try
        {
            _ = InvokeAsync(async () =>
            {
                try
                {
                    StateHasChanged();
                    await RenderMarkdownAsync();
                    await ScrollToBottomAsync();
                }
                catch (ObjectDisposedException) { }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"[Mobile] Render error: {ex.Message}");
                }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private async Task OnAgentChanged(ChangeEventArgs e)
    {
        var agentId = e.Value?.ToString();
        if (string.IsNullOrEmpty(agentId) || agentId == Store.ActiveAgentId) return;
        Store.ActiveAgentId = agentId;
        Store.NotifyChanged();
        _menuOpen = false;
        var agent = Store.GetAgent(agentId);
        var firstConv = agent?.Conversations.Values
            .Where(c => c.Status == "Active")
            .OrderByDescending(c => c.UpdatedAt)
            .FirstOrDefault();
        if (firstConv is not null)
            await Interaction.SelectConversationAsync(agentId, firstConv.ConversationId);
    }

    private async Task OnConvChanged(ChangeEventArgs e)
    {
        var convId = e.Value?.ToString();
        if (string.IsNullOrEmpty(convId) || Store.ActiveAgentId is null) return;
        await Interaction.SelectConversationAsync(Store.ActiveAgentId, convId);
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || Store.ActiveAgentId is null) return;
        var content = _inputText.Trim();
        _inputText = "";
        _isSending = true;
        try
        {
            await Interaction.SendMessageAsync(Store.ActiveAgentId, content);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Mobile] Send failed: {ex.Message}");
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendMessage();
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    private async Task NewSession()
    {
        _menuOpen = false;
        if (Store.ActiveAgentId is not null)
            await Interaction.ResetSessionAsync(Store.ActiveAgentId);
    }

    private static string GetMessageClass(ChatMessage msg)
    {
        if (msg.Role == "thinking") return "thinking";
        return msg.Role == "user" ? "user" : "assistant";
    }

    private void OpenToolModal(ChatMessage msg) => _modalToolMessage = msg;
    private void CloseToolModal() => _modalToolMessage = null;

    private static string FormatDuration(TimeSpan d) => d.TotalSeconds < 1
        ? $"{d.TotalMilliseconds:0}ms"
        : $"{d.TotalSeconds:0.0}s";

    private async Task RenderMarkdownAsync()
    {
        var activeConvId = Store.ActiveAgentId is not null
            ? Store.GetAgent(Store.ActiveAgentId)?.ActiveConversationId
            : null;
        if (activeConvId is null) return;

        var needsRender = false;
        foreach (var msg in Store.GetMessages(activeConvId))
        {
            if (msg.Role == "assistant" && !_markdownCache.ContainsKey(msg.Id))
            {
                try
                {
                    var html = await JS.InvokeAsync<string>("BotNexus.renderMarkdown", msg.Content);
                    _markdownCache[msg.Id] = html;
                    needsRender = true;
                }
                catch { /* JS not ready yet, will retry on next render */ }
            }
        }
        if (needsRender) StateHasChanged();
    }

    private async Task ScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("eval",
                "document.querySelector('.message-stream')?.scrollTo({top:1e9,behavior:'smooth'})");
        }
        catch { }
    }

    public void Dispose()
    {
        Store.OnChanged -= HandleStateChanged;
        PortalLoad.OnReadyChanged -= HandleStateChanged;
    }
}
