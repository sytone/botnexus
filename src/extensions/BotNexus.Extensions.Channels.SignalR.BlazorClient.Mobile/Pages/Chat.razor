@* #2247: mobile mirrors the desktop route-owned view. /agent/{AgentId}/conversation/{ConversationId}
   is the canonical shape (default conversation resolves when omitted); the legacy /chat/... routes
   stay registered so existing deep-links and history entries restore on refresh/back. Both shapes
   run through ApplyRouteSelectionAsync -> SelectView(..., SelectionSource.RouteNavigation). *@
@page "/"
@page "/agent/{AgentId}"
@page "/agent/{AgentId}/conversation/{ConversationId}"
@page "/chat/{AgentId}"
@page "/chat/{AgentId}/{ConversationId}"
@inject IClientStateStore Store
@inject IAgentInteractionService Interaction
@inject IPortalLoadService PortalLoad
@inject BotNexus.Extensions.Channels.SignalR.BlazorClient.Mobile.Services.MobileHubTuningOptions HubTuning
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IServiceProvider Services
@implements IDisposable
@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services.SlashCommands
<PageTitle>BotNexus</PageTitle>
@if (!PortalLoad.IsReady)
{
    <div class="portal-loading">
        @if (PortalLoad.LoadError is not null)
        {
            <div class="portal-load-error">&#x26A0; @PortalLoad.LoadError</div>
        }
        else
        {
            <div class="portal-load-spinner">Connecting…</div>
        }
    </div>
}
else
{
    var activeAgent = Store.ActiveAgentId is not null ? Store.GetAgent(Store.ActiveAgentId) : null;
    var activeConvId = activeAgent?.ActiveConversationId;
    var messages = activeConvId is not null ? Store.GetMessages(activeConvId) : [];
    var streamState = activeConvId is not null ? Store.GetStreamState(activeConvId) : null;
    var conversations = activeAgent?.Conversations.Values
        .Where(c => c.Status == "Active")
        .OrderForDisplay()
        .ToList() ?? [];
    <div class="mobile-app">
        <!-- DISCONNECTED INDICATOR -->
        @if (!PortalLoad.IsSignalRConnected)
        {
            <div class="disconnected-bar" data-testid="disconnected-bar">
                &#x26A0; Disconnected
                <button class="reconnect-inline-btn" @onclick="ManualRefreshAsync" disabled="@_isRefreshing" aria-label="Reconnect">
                    @(_isRefreshing ? "↻" : "Reconnect")
                </button>
            </div>
        }
        <!-- TOP BAR -->
        <div class="top-bar">
            <select class="agent-select" value="@Store.ActiveAgentId" @onchange="OnAgentChanged">
                @foreach (var (agentId, agent) in Store.Agents.OrderForDisplay())
                {
                    <option value="@agentId">@(agent.Emoji is not null ? agent.Emoji + " " : "")@agent.DisplayName</option>
                }
            </select>
            <select @key="Store.ActiveAgentId" class="conv-select" value="@activeConvId" @onchange="OnConvChanged">
                @foreach (var conv in conversations)
                {
                    <option value="@conv.ConversationId">@conv.Title</option>
                }
            </select>
            <button class="refresh-btn" @onclick="ManualRefreshAsync" disabled="@_isRefreshing" aria-label="Refresh" data-testid="refresh-btn" title="Refresh conversations">
                @(_isRefreshing ? "↻" : "↺")
            </button>
            <div class="overflow-menu-wrapper">
                <button class="overflow-btn" @onclick="ToggleMenu" aria-label="Menu">&#x22EF;</button>
                @if (_menuOpen)
                {
                    <div class="overflow-dropdown">
                        <div class="menu-session-id" title="Session ID">
                            <span>Session: </span><span class="session-id-text">@(activeAgent?.SessionId ?? "&#x2014;")</span>
                        </div>
                        <button class="menu-action" data-testid="new-session-btn" @onclick="NewSession">New session</button>
                        <button class="menu-action" data-testid="new-conversation-btn" @onclick="NewConversation">New conversation</button>
                        @* Canvas is always available so it can be opened before the agent
                           publishes any HTML; the panel shows an empty-state placeholder until
                           content arrives. A dot indicates when live canvas content exists. *@
                        <button class="menu-action" data-testid="canvas-toggle-btn" @onclick="ToggleCanvas">
                            Canvas
                            @if (HasCanvasContent(activeAgent))
                            {
                                <span class="menu-action-dot" data-testid="canvas-content-dot" title="Canvas has content" aria-label="Canvas has content"></span>
                            }
                        </button>
                        @* Settings opens the schema-driven mobile Settings page (config-parity PBI
                           6/6 of #1579, issue #1615). It renders the SAME shared SchemaForm the
                           desktop uses, so no mobile-specific field code is needed. Always available. *@
                        <button class="menu-action" data-testid="settings-btn" @onclick="OpenSettings">Settings</button>
                        @* Archive (or close, for virtual cron sessions) the active conversation.
                           Hidden when no conversation is selected since there is nothing to archive. *@
                        @if (ActiveConversation(activeAgent) is { } activeConv)
                        {
                            <button class="menu-action menu-action-archive" data-testid="archive-conversation-btn" @onclick="() => Archive(activeConv)">
                                @(activeConv.IsVirtualSession ? "Close conversation" : "Archive conversation")
                            </button>
                        }
                    </div>
                }
            </div>
        </div>
        <!-- MESSAGE STREAM -->
        <div class="message-stream" @ref="_messageStreamRef">
            @if (HasMoreHistory)
            {
                <div class="history-load-more" data-testid="mobile-load-more">
                    @if (_isLoadingMore)
                    {
                        <span class="history-load-more-spinner">&#x21BB;</span>
                        <span>Loading older messages&#x2026;</span>
                    }
                    else
                    {
                        <button class="load-more-btn" data-testid="mobile-load-more-btn" @onclick="LoadMoreHistory">
                            Load older messages
                        </button>
                    }
                </div>
            }
            @foreach (var msg in messages)
            {
                @if (msg.IsBoundary)
                {
                    <div class="session-boundary" @key="msg.Id">@(msg.BoundaryLabel ?? "New session")</div>
                }
                else if (msg.IsToolCall)
                {
                    var toolIcon = msg.ToolIsError == true ? "&#x274C;" : msg.ToolResult is not null ? "&#x2705;" : "&#x23F3;";
                    var toolDuration = msg.ToolDuration is not null ? $" {msg.ToolDuration.Value.TotalSeconds:F1}s" : "";
                    @* Render the tool pill as a <div role="button"> so every branch in this
                       loop shares a <div> root. Combined with @key this prevents Blazor from
                       patching a <div> into a <button> at the same tree position mid-stream
                       (issue #1483). @onkeydown keeps it keyboard-activatable. *@
                    <div class="tool-pill @(msg.ToolIsError == true ? "tool-pill-error" : "")"
                         role="button"
                         tabindex="0"
                         @key="msg.Id"
                         @onclick="() => OpenToolModal(msg)"
                         @onkeydown="(e) => OnToolPillKeyDown(e, msg)"
                         title="Tap to view details">
                        <span class="tool-pill-icon">@((MarkupString)toolIcon)</span>
                        <span class="tool-pill-name">@msg.ToolName</span>
                        @if (!string.IsNullOrEmpty(toolDuration))
                        {
                            <span class="tool-pill-duration">@toolDuration</span>
                        }
                        <span class="tool-pill-chevron">&#x25B8;</span>
                    </div>
                }
                else
                {
                    <div class="message @GetMessageClass(msg)" @key="msg.Id">
                        @if (ShouldRenderAsMarkdown(msg.Role) && _markdownCache.TryGetValue(msg.Id, out var rendered))
                        {
                            <div class="message-content markdown-content">@((MarkupString)rendered)</div>
                        }
                        else
                        {
                            <div class="message-content plain-text-content">@msg.Content</div>
                        }
                        <div class="message-time">@FormatTimestamp(msg.Timestamp)</div>
                    </div>
                }
            }
            @if (streamState?.IsStreaming == true && !string.IsNullOrEmpty(streamState.Buffer))
            {
                <div class="message assistant streaming">
                    <div class="message-content plain-text-content">@streamState.Buffer<span class="stream-cursor">&#x2588;</span></div>
                </div>
            }
        </div>
        <!-- SLASH-COMMAND PALETTE -->
        @if (_showCommandPalette)
        {
            <div class="command-palette" data-testid="command-palette">
                @foreach (var cmd in _filteredCommands)
                {
                    <button class="command-item @(cmd.Name == _selectedCommand ? "selected" : "")"
                            data-testid="command-item"
                            @onclick="() => ExecuteCommand(cmd)">
                        <span class="command-name">@cmd.Name</span>
                        <span class="command-desc">@cmd.Description</span>
                    </button>
                }
            </div>
        }
        <!-- BOTTOM BAR -->
        <div class="bottom-bar">
            <textarea
                class="input-textarea"
                placeholder="/ for commands"
                rows="1"
                @bind="_inputText"
                @bind:event="oninput"
                @bind:after="UpdateCommandPalette"
                @onkeydown="OnKeyDown"
                disabled="@_isSending">
            </textarea>
            <button class="send-btn" @onclick="SendMessage" disabled="@(_isSending || string.IsNullOrWhiteSpace(_inputText))">
                &#x21A6;
            </button>
        </div>
        @* #1491: when the agent is blocked on an ask_user prompt for the active
           conversation, render the shared AskUserPrompt component as a bottom-sheet
           above the input bar. Reuses the same component + RespondToAskUserAsync
           interaction the desktop ChatPanel uses, so the mobile path stays behaviour
           identical. The sheet only renders when a pending prompt exists. *@
        @if (PendingAskUserPrompt is { } pendingPrompt)
        {
            <div class="ask-user-sheet" data-testid="ask-user-sheet">
                <AskUserPrompt Prompt="pendingPrompt"
                               ErrorMessage="_askUserError"
                               OnSubmit="HandleAskUserSubmit"
                               OnTimeout="HandleAskUserTimeout" />
            </div>
        }
    </div>
    <!-- NEW SESSION CONFIRM OVERLAY -->
    @if (_showNewSessionConfirm)
    {
        <div class="reset-confirm-overlay" @onclick="CancelNewSession">
            <div class="reset-confirm-box" @onclick:stopPropagation="true">
                <p>Start a new session? Prior messages will remain visible but the agent will start with a fresh context.</p>
                <div class="reset-confirm-actions">
                    <button class="cancel-btn" @onclick="CancelNewSession">Cancel</button>
                    <button class="confirm-btn" data-testid="new-session-confirm-btn" @onclick="DoNewSession">New session</button>
                </div>
            </div>
        </div>
    }
    <!-- ARCHIVE CONVERSATION CONFIRM OVERLAY -->
    @if (_archiveTarget is { } archiveTarget)
    {
        <div class="reset-confirm-overlay" @onclick="CancelArchive">
            <div class="reset-confirm-box" @onclick:stopPropagation="true">
                <p>
                    @if (archiveTarget.IsVirtualSession)
                    {
                        @($"Close “{archiveTarget.Title}”? It will reopen when the next cron trigger fires.")
                    }
                    else
                    {
                        @($"Archive “{archiveTarget.Title}”? It will be hidden from the conversation list.")
                    }
                </p>
                <div class="reset-confirm-actions">
                    <button class="cancel-btn" data-testid="archive-cancel-btn" @onclick="CancelArchive">Cancel</button>
                    <button class="confirm-btn" data-testid="archive-confirm-btn" @onclick="DoArchive">
                        @(archiveTarget.IsVirtualSession ? "Close" : "Archive")
                    </button>
                </div>
            </div>
        </div>
    }
    <!-- CANVAS PANEL -->
    @if (Store.ActiveAgentId is not null)
    {
        <MobileCanvasPanel AgentId="@Store.ActiveAgentId"
                           ConversationId="@activeConvId"
                           Open="_canvasOpen"
                           OnClose="CloseCanvas" />
    }
    <!-- TOOL CALL MODAL -->
    @if (_modalToolMessage is not null)
    {
        <div class="tool-modal-backdrop" @onclick="CloseToolModal"></div>
        <div class="tool-modal" role="dialog" aria-modal="true" aria-label="Tool call details">
            <div class="tool-modal-header">
                <span class="tool-modal-name">&#x1F527; @_modalToolMessage.ToolName</span>
                <button class="tool-modal-close" @onclick="CloseToolModal" aria-label="Close">&#x2715;</button>
            </div>
            @if (!string.IsNullOrEmpty(_modalToolMessage.ToolArgs))
            {
                <div class="tool-modal-section">
                    <div class="tool-modal-section-label">Arguments</div>
                    <pre class="tool-modal-content">@_modalToolMessage.ToolArgs</pre>
                </div>
            }
            @if (!string.IsNullOrEmpty(_modalToolMessage.ToolResult))
            {
                <div class="tool-modal-section">
                    <div class="tool-modal-section-label">Result @(_modalToolMessage.ToolIsError == true ? "(error)" : "")</div>
                    <pre class="tool-modal-content @(_modalToolMessage.ToolIsError == true ? "tool-modal-content--error" : "")">@_modalToolMessage.ToolResult</pre>
                </div>
            }
            else if (string.IsNullOrEmpty(_modalToolMessage.ToolArgs))
            {
                <div class="tool-modal-empty">No details available.</div>
            }
            @if (_modalToolMessage.ToolDuration is not null)
            {
                <div class="tool-modal-section"><span class="tool-modal-duration">Duration: @_modalToolMessage.ToolDuration.Value.TotalSeconds.ToString("F2")s</span></div>
            }
        </div>
    }
}
@code {
    [Parameter] public string? AgentId { get; set; }
    [Parameter] public string? ConversationId { get; set; }

    private string _inputText = "";
    private bool _isSending;

    // #1951: slash-command palette state. The command surface and execute-mapping live in the
    // shared BlazorClient.Core registry/dispatcher so mobile and desktop stay in lock-step.
    private bool _showCommandPalette;
    private string _selectedCommand = "";
    private IReadOnlyList<SlashCommand> _filteredCommands = [];

    // #1951: resolved lazily and optionally so mobile test fixtures that don't register the
    // dispatcher keep rendering; Program.cs always registers it for the real app.
    private ISlashCommandDispatcher? CommandDispatcher =>
        Services.GetService(typeof(ISlashCommandDispatcher)) as ISlashCommandDispatcher;
    private bool _isRefreshing;
    private bool _menuOpen;
    private bool _showNewSessionConfirm;
    private string? _askUserError;
    private ConversationState? _archiveTarget;
    private ElementReference _messageStreamRef;
    // #1691: load-more (scroll-up pagination) state.
    private bool _isLoadingMore;
    private bool _loadMoreObserverBound;
    private readonly Dictionary<string, string> _markdownCache = new();

    // #1475: user and assistant messages both render through the Markdown pipeline.
    // Platform-generated roles (System, Tool, Error, Notification) stay on raw text rendering.
    private static bool ShouldRenderAsMarkdown(string? role) =>
        string.Equals(role, "assistant", StringComparison.OrdinalIgnoreCase)
        || string.Equals(role, "user", StringComparison.OrdinalIgnoreCase);
    private ChatMessage? _modalToolMessage;
    private DotNetObjectReference<Chat>? _dotNetRef;
    private bool _appResumeListenerRegistered;
    private bool _canvasOpen;

    // Route application guard -- prevents re-applying the same route key twice.
    private string? _appliedRouteKey;

    // Scroll guard state -- tracks last-known active context to prevent cross-agent scroll
    private string? _lastActiveAgentId;
    private string? _lastActiveConversationId;
    private int _lastRenderedMessageCount;

    protected override void OnInitialized()
    {
        PortalLoad.OnReadyChanged += HandleReadyChanged;
        PortalLoad.OnConnectionStateChanged += HandleConnectionStateChanged;
        Store.OnChanged += HandleStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await ApplyRouteSelectionAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        var origin = new Uri(Nav.BaseUri).GetLeftPart(UriPartial.Authority);
        var hubUrl = $"{origin}/hub/gateway";
        PortalLoad.ClientKind = "mobile";
        // #1840: apply the mobile keep-alive/server-timeout and widened reconnect schedule to the
        // hub build so a tunnelled, backgrounded PWA stops churning through sub-second reconnects.
        PortalLoad.Tuning = HubTuning.ToTuning();
        await PortalLoad.InitializeAsync(hubUrl);
        await ApplyRouteSelectionAsync();
    }

    /// <summary>
    /// Scrolls to the bottom after the first render so that history loaded on
    /// mount or navigation is immediately visible at the most recent message.
    /// Without this override, the view stays at scroll position 0 regardless
    /// of how many messages are loaded (issue #793).
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Seed scroll-tracking state so the first Store.OnChanged event from
            // streaming is not treated as an agent/conversation switch, which would
            // cause an unconditional force-scroll even when the user has scrolled up.
            _lastActiveAgentId = Store.ActiveAgentId;
            _lastActiveConversationId = Store.ActiveAgentId is not null
                ? Store.GetAgent(Store.ActiveAgentId)?.ActiveConversationId
                : null;
            _lastRenderedMessageCount = _lastActiveConversationId is not null
                ? Store.GetMessages(_lastActiveConversationId).Count
                : 0;
            await ForceScrollToBottomAsync();

            // Register the full PWA lifecycle listeners (visibilitychange/pagehide/freeze/resume)
            // for app-resume reconnect (mobile PWA, #1841). All events funnel into the single
            // OnAppResumed callback, which drives the PBI1 liveness-verified hub reset (#1838).
            if (!_appResumeListenerRegistered)
            {
                try
                {
                    _dotNetRef = DotNetObjectReference.Create(this);
                    await JS.InvokeVoidAsync("BotNexusAppResume.initialize", _dotNetRef);
                    _appResumeListenerRegistered = true;
                }
                catch { /* JS not ready or not available in test context */ }
            }

            // #1691: attach the scroll-to-top observer so scrolling up fetches the next older page
            // and prepends it, matching the desktop behaviour through the shared Core paging logic.
            if (!_loadMoreObserverBound)
            {
                try
                {
                    _dotNetRef ??= DotNetObjectReference.Create(this);
                    await JS.InvokeVoidAsync("chatScroll.observeTopForLoadMore", _messageStreamRef, _dotNetRef);
                    _loadMoreObserverBound = true;
                }
                catch { /* JS not ready or not available in test context */ }
            }
        }
    }

    private void HandleReadyChanged() =>
        _ = InvokeAsync(async () =>
        {
            await ApplyRouteSelectionAsync();
            StateHasChanged();
            // Force-scroll to bottom once portal is ready and history is rendered
            // so the user always sees the most recent message on first load (issue #793).
            await ForceScrollToBottomAsync();
        });

    private void HandleStateChanged()
    {
        try
        {
            _ = InvokeAsync(async () =>
            {
                try
                {
                    StateHasChanged();
                    await RenderMarkdownAsync();
                    await ConditionalScrollAsync();
                }
                catch (ObjectDisposedException) { }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"[Mobile] Render error: {ex.Message}");
                }
            });
        }
        catch (ObjectDisposedException) { }
    }

    private void HandleConnectionStateChanged() =>
        _ = InvokeAsync(StateHasChanged);

    /// <summary>
    /// Called from JavaScript when the Page Visibility API reports the app has returned
    /// to the foreground (e.g. after being backgrounded in a PWA or mobile browser).
    /// Re-fetches conversation data and reconnects SignalR if disconnected.
    /// </summary>
    [JSInvokable]
    public async Task OnAppResumed()
    {
        // #1838: do not trust HubConnectionState/readyState on resume -- iOS zombie sockets
        // still report Connected after a silent background recycle. ResumeAsync probes the hub
        // with a short-timeout round-trip and rebuilds (fresh negotiate + re-subscribe) only when
        // the probe fails; on success it keeps the connection and refreshes. Its reentrancy guard
        // means rapid visibility toggles cannot stack concurrent rebuilds.
        await PortalLoad.ResumeAsync();
        await InvokeAsync(async () =>
        {
            StateHasChanged();
            await ForceScrollToBottomAsync();
        });
    }

    // #1691: invoked from JS (chatScroll.observeTopForLoadMore) when the user scrolls near the top.
    // Fetches and prepends the next older page through the shared Core paging logic and pins the
    // previously-visible message in place so the viewport does not jump to the top.
    [JSInvokable]
    public async Task OnScrolledToTop() => await LoadMoreHistory();

    private async Task LoadMoreHistory()
    {
        if (_isLoadingMore || Store.ActiveAgentId is not { } agentId)
            return;
        var convId = Store.GetAgent(agentId)?.ActiveConversationId;
        if (convId is null || !HasMoreHistory)
            return;

        _isLoadingMore = true;
        StateHasChanged();
        double previousHeight = 0;
        try
        {
            try { previousHeight = await JS.InvokeAsync<double>("chatScroll.captureScrollHeight", _messageStreamRef); }
            catch { }

            var added = await Interaction.LoadMoreHistoryAsync(agentId, convId);
            if (added > 0)
            {
                // Keep the conditional-scroll guard from treating the prepend as new-tail growth.
                _lastRenderedMessageCount = Store.GetMessages(convId).Count;
                StateHasChanged();
                try { await JS.InvokeVoidAsync("chatScroll.restoreScrollAfterPrepend", _messageStreamRef, previousHeight); }
                catch { }
            }
        }
        finally
        {
            _isLoadingMore = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Handles the manual refresh button tap: re-fetches data and reconnects.
    /// Shows a brief spinning indicator while in progress.
    /// </summary>
    private async Task ManualRefreshAsync()
    {
        if (_isRefreshing) return;
        _isRefreshing = true;
        StateHasChanged();
        try
        {
            await PortalLoad.RefreshAsync();
            await ForceScrollToBottomAsync();
        }
        finally
        {
            _isRefreshing = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Applies agent and conversation selection from route parameters, mirroring
    /// the desktop Home.razor ApplyRouteSelectionAsync logic (issue #400).
    /// </summary>
    private async Task ApplyRouteSelectionAsync()
    {
        if (!PortalLoad.IsReady || string.IsNullOrWhiteSpace(AgentId))
            return;

        var routeAgentId = Uri.UnescapeDataString(AgentId);
        var routeConversationId = string.IsNullOrWhiteSpace(ConversationId)
            ? null
            : Uri.UnescapeDataString(ConversationId);
        var routeKey = $"{routeAgentId}|{routeConversationId ?? ""}";
        if (string.Equals(_appliedRouteKey, routeKey, StringComparison.Ordinal))
            return;

        if (!Store.Agents.ContainsKey(routeAgentId))
        {
            // Unknown agent -- fall back to first known agent if nothing is selected yet.
            if (Store.ActiveAgentId is null && Store.Agents.Keys.FirstOrDefault() is { } fallback)
            {
                Store.SelectView(fallback, string.Empty, SelectionSource.RouteNavigation);
                Store.NotifyChanged();
            }

            return;
        }

        if (!string.Equals(Store.ActiveAgentId, routeAgentId, StringComparison.Ordinal))
        {
            Store.SelectView(routeAgentId, string.Empty, SelectionSource.RouteNavigation);
            Store.NotifyChanged();
        }

        if (routeConversationId is null)
        {
            _appliedRouteKey = routeKey;
            return;
        }

        var agent = Store.GetAgent(routeAgentId);
        if (agent is null || !agent.Conversations.ContainsKey(routeConversationId))
            return;

        if (!string.Equals(agent.ActiveConversationId, routeConversationId, StringComparison.Ordinal))
            await Interaction.SelectConversationAsync(routeAgentId, routeConversationId);

        _appliedRouteKey = routeKey;
    }

    private async Task OnAgentChanged(ChangeEventArgs e)
    {
        var agentId = e.Value?.ToString();
        if (string.IsNullOrEmpty(agentId) || agentId == Store.ActiveAgentId) return;
        Store.SelectView(agentId, string.Empty, SelectionSource.UserClick);
        Store.NotifyChanged();
        _menuOpen = false;
        var agent = Store.GetAgent(agentId);
        var firstConv = agent?.Conversations.Values
            .Where(c => c.Status == "Active")
            .OrderForDisplay()
            .FirstOrDefault();
        if (firstConv is not null)
        {
            await Interaction.SelectConversationAsync(agentId, firstConv.ConversationId);
            Nav.NavigateTo($"agent/{Uri.EscapeDataString(agentId)}/conversation/{Uri.EscapeDataString(firstConv.ConversationId)}");
        }
        else
        {
            Nav.NavigateTo($"agent/{Uri.EscapeDataString(agentId)}");
        }
    }

    private async Task OnConvChanged(ChangeEventArgs e)
    {
        var convId = e.Value?.ToString();
        if (string.IsNullOrEmpty(convId) || Store.ActiveAgentId is null) return;
        await Interaction.SelectConversationAsync(Store.ActiveAgentId, convId);
        Nav.NavigateTo($"agent/{Uri.EscapeDataString(Store.ActiveAgentId)}/conversation/{Uri.EscapeDataString(convId)}");
        // Scroll to the bottom so the selected conversation's latest message is visible.
        await ForceScrollToBottomAsync();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_inputText) || Store.ActiveAgentId is null) return;
        var content = _inputText.Trim();
        _inputText = "";
        _showCommandPalette = false;
        _isSending = true;
        try
        {
            await Interaction.SendMessageAsync(Store.ActiveAgentId, content);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[Mobile] Send failed: {ex.Message}");
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        UpdateCommandPalette();

        if (e is { Key: "Enter", ShiftKey: false })
        {
            if (_showCommandPalette && _filteredCommands.Count > 0)
            {
                var cmd = _filteredCommands.FirstOrDefault(c => c.Name == _selectedCommand) ?? _filteredCommands[0];
                await ExecuteCommand(cmd);
                return;
            }

            await SendMessage();
        }
        else if (e is { Key: "Escape" })
        {
            if (_showCommandPalette)
            {
                _showCommandPalette = false;
                StateHasChanged();
            }
        }
        else if (e is { Key: "Tab" } && _showCommandPalette && _filteredCommands.Count > 0)
        {
            _inputText = _filteredCommands[0].Name + " ";
            _showCommandPalette = false;
            StateHasChanged();
        }
    }

    // #1951: recompute the palette from the current input. The palette shows only when the input
    // starts with '/' and has no space; SlashCommandRegistry.Filter enforces that contract and
    // returns the prefix-filtered command set (the full list for a bare '/').
    private void UpdateCommandPalette()
    {
        var text = _inputText?.Trim() ?? "";
        if (text.StartsWith('/') && !text.Contains(' '))
        {
            _showCommandPalette = true;
            _filteredCommands = SlashCommandRegistry.Filter(text);
            _selectedCommand = _filteredCommands.Count > 0 ? _filteredCommands[0].Name : "";
        }
        else
        {
            _showCommandPalette = false;
            _filteredCommands = [];
        }
        StateHasChanged();
    }

    // #1951: execute a selected slash command. /new and /clear route through the mobile
    // confirm-overlay (matching the existing New-session UX); every other command is dispatched
    // straight through the shared Core dispatcher, which also consults the #1950 approval hook for
    // protected commands. This keeps mobile at full parity with the desktop ChatPanel.
    private async Task ExecuteCommand(SlashCommand cmd)
    {
        _showCommandPalette = false;
        _inputText = "";

        if (cmd.Kind is SlashCommandKind.ResetSession or SlashCommandKind.ClearLocalMessages)
        {
            _pendingConfirmCommand = cmd;
            _showNewSessionConfirm = true;
            StateHasChanged();
            return;
        }

        if (Store.ActiveAgentId is null || CommandDispatcher is null)
            return;

        await CommandDispatcher.ExecuteAsync(Store.ActiveAgentId, cmd);
    }

    // #1691: whether the active conversation has older history to page in on scroll-up.
    private bool HasMoreHistory
    {
        get
        {
            var activeConvId = Store.ActiveAgentId is not null
                ? Store.GetAgent(Store.ActiveAgentId)?.ActiveConversationId
                : null;
            return activeConvId is not null
                && Store.GetAgent(Store.ActiveAgentId!)?.Conversations.GetValueOrDefault(activeConvId) is { HasMoreHistory: true };
        }
    }

    // #1491: the pending ask_user prompt (if any) for the active conversation.
    // Mirrors desktop ChatPanel.PendingAskUserPrompt, deriving the active conversation
    // id from the store rather than a cascaded parameter.
    private AskUserPromptState? PendingAskUserPrompt
    {
        get
        {
            var activeConvId = Store.ActiveAgentId is not null
                ? Store.GetAgent(Store.ActiveAgentId)?.ActiveConversationId
                : null;
            return activeConvId is not null ? Store.GetPendingAskUser(activeConvId) : null;
        }
    }

    // #1491: submit the user's ask_user response through the same interaction path the
    // desktop uses (RespondToAskUserAsync). On success, clear the pending prompt and append
    // a summary line; on failure, surface the error inline without dropping the prompt.
    private async Task HandleAskUserSubmit(AskUserPromptSubmission submission)
    {
        var prompt = PendingAskUserPrompt;
        if (prompt is null)
            return;

        _askUserError = null;
        prompt.IsSubmitting = true;
        Store.NotifyChanged();

        try
        {
            await Interaction.RespondToAskUserAsync(
                prompt.ConversationId,
                prompt.RequestId,
                submission.FreeFormText,
                submission.SelectedValues,
                submission.Cancelled);

            Store.ClearPendingAskUser(prompt.ConversationId);
            Store.AppendMessage(prompt.ConversationId, new ChatMessage("System", BuildAskUserSummary(submission), DateTimeOffset.UtcNow));
            await ForceScrollToBottomAsync();
        }
        catch (Exception ex)
        {
            prompt.IsSubmitting = false;
            _askUserError = $"Failed to submit response: {ex.Message}";
            Store.NotifyChanged();
        }
    }

    // #1491: a soft timeout on the prompt clears it and notes the expiry, matching desktop.
    private async Task HandleAskUserTimeout()
    {
        var prompt = PendingAskUserPrompt;
        if (prompt is null)
            return;

        Store.ClearPendingAskUser(prompt.ConversationId);
        Store.AppendMessage(prompt.ConversationId, new ChatMessage("System", "Prompt timed out before you could answer.", DateTimeOffset.UtcNow));
        await ForceScrollToBottomAsync();
    }

    // #1491: human-readable summary of what the user answered, mirroring desktop.
    private static string BuildAskUserSummary(AskUserPromptSubmission submission)
    {
        if (submission.Cancelled)
            return "You cancelled the prompt.";

        var selected = submission.SelectedValues is { Length: > 0 }
            ? string.Join(", ", submission.SelectedValues)
            : null;
        var freeForm = string.IsNullOrWhiteSpace(submission.FreeFormText) ? null : submission.FreeFormText.Trim();

        return (selected, freeForm) switch
        {
            (not null, not null) => $"You answered: {selected} | {freeForm}",
            (not null, null) => $"You answered: {selected}",
            (null, not null) => $"You answered: {freeForm}",
            _ => "You answered the prompt."
        };
    }

    private void ToggleMenu() => _menuOpen = !_menuOpen;

    // #1951: when a slash command (/new or /clear) is routed through the confirm overlay this holds
    // the command so DoNewSession dispatches it through the shared Core dispatcher on confirm.
    private SlashCommand? _pendingConfirmCommand;

    private void NewSession()
    {
        _pendingConfirmCommand = null;
        _showNewSessionConfirm = true;
        _menuOpen = false;
    }

    private async Task NewConversation()
    {
        _menuOpen = false;
        if (Store.ActiveAgentId is null) return;
        var convId = await Interaction.CreateConversationAsync(Store.ActiveAgentId);
        if (convId is not null)
        {
            Nav.NavigateTo($"agent/{Uri.EscapeDataString(Store.ActiveAgentId)}/conversation/{Uri.EscapeDataString(convId)}");
            await ForceScrollToBottomAsync();
        }
    }

    private async Task DoNewSession()
    {
        _showNewSessionConfirm = false;
        var pending = _pendingConfirmCommand;
        _pendingConfirmCommand = null;

        if (Store.ActiveAgentId is null)
            return;

        // #1951: a slash command routed here (/new or /clear) is dispatched through the shared Core
        // dispatcher so behaviour matches the desktop exactly; the menu's New-session button (no
        // pending command) keeps calling ResetSessionAsync directly.
        if (pending is not null && CommandDispatcher is not null)
            await CommandDispatcher.ExecuteAsync(Store.ActiveAgentId, pending);
        else
            await Interaction.ResetSessionAsync(Store.ActiveAgentId);

        await ForceScrollToBottomAsync();
    }

    private void CancelNewSession()
    {
        _showNewSessionConfirm = false;
        _pendingConfirmCommand = null;
    }

    /// <summary>
    /// Returns the active conversation for the menu's archive action, or null when
    /// no conversation is selected (nothing to archive).
    /// </summary>
    private static ConversationState? ActiveConversation(AgentState? agent)
    {
        if (agent?.ActiveConversationId is not { } convId)
            return null;
        return agent.Conversations.TryGetValue(convId, out var conv) ? conv : null;
    }

    private void Archive(ConversationState conversation)
    {
        _archiveTarget = conversation;
        _menuOpen = false;
    }

    private async Task DoArchive()
    {
        var target = _archiveTarget;
        _archiveTarget = null;
        if (target is null || Store.ActiveAgentId is null) return;
        await Interaction.ArchiveConversationAsync(Store.ActiveAgentId, target.ConversationId);
    }

    private void CancelArchive()
    {
        _archiveTarget = null;
    }

    private void ToggleCanvas()
    {
        _canvasOpen = !_canvasOpen;
        _menuOpen = false;
    }

    // #1615: navigate to the schema-driven mobile Settings page. Closing the overflow menu first
    // keeps the dropdown from lingering over the settings surface after the route change.
    private void OpenSettings()
    {
        _menuOpen = false;
        Nav.NavigateTo("settings");
    }

    private void CloseCanvas()
    {
        _canvasOpen = false;
    }

    private static bool HasCanvasContent(AgentState? agent)
    {
        if (agent is null) return false;
        if (!string.IsNullOrWhiteSpace(agent.CanvasHtml)) return true;
        if (agent.ActiveConversationId is not null)
        {
            // Check if any conversation has canvas content
            if (agent.Conversations.TryGetValue(agent.ActiveConversationId, out var conv))
                return !string.IsNullOrWhiteSpace(conv.CanvasHtml);
        }
        return false;
    }

    private void OpenToolModal(ChatMessage msg)
    {
        _modalToolMessage = msg;
        StateHasChanged();
    }

    // Keyboard activation for the tool pill, which is a <div role="button"> (see #1483).
    // Enter or Space opens the tool detail modal, matching native <button> semantics.
    private void OnToolPillKeyDown(KeyboardEventArgs e, ChatMessage msg)
    {
        if (e.Key is "Enter" or " " or "Spacebar")
        {
            OpenToolModal(msg);
        }
    }

    private void CloseToolModal()
    {
        _modalToolMessage = null;
        StateHasChanged();
    }

    private static string GetMessageClass(ChatMessage msg)
    {
        if (msg.Role.Equals("thinking", StringComparison.OrdinalIgnoreCase)) return "thinking";
        return msg.Role.Equals("user", StringComparison.OrdinalIgnoreCase) ? "user" : "assistant";
    }

    // #1690: mirror desktop ChatPanel.FormatTimestamp so older messages show a date,
    // not just a time. Same-day messages render time only; prior-day messages prefix
    // the date. Identical format to the desktop client for parity.
    private static string FormatTimestamp(DateTimeOffset ts)
    {
        var local = ts.ToLocalTime();
        var now = DateTimeOffset.Now;
        return local.Date == now.Date
            ? local.ToString("h:mm tt")
            : local.ToString("MMM d, h:mm tt");
    }

    private async Task RenderMarkdownAsync()
    {
        var activeConvId = Store.ActiveAgentId is not null
            ? Store.GetAgent(Store.ActiveAgentId)?.ActiveConversationId
            : null;
        if (activeConvId is null) return;
        var needsRender = false;
        foreach (var msg in Store.GetMessages(activeConvId))
        {
            if (ShouldRenderAsMarkdown(msg.Role) && !string.IsNullOrEmpty(msg.Content) && !_markdownCache.ContainsKey(msg.Id))
            {
                try
                {
                    var html = await JS.InvokeAsync<string>("BotNexus.renderMarkdown", msg.Content);
                    _markdownCache[msg.Id] = html;
                    needsRender = true;
                }
                catch { /* JS not ready yet, will retry on next render */ }
            }
        }
        if (needsRender) StateHasChanged();
    }

    /// <summary>
    /// Scrolls to the bottom only when the active agent/conversation has changed or
    /// new messages have arrived for the currently-viewed conversation.
    /// Does NOT scroll when a background agent's state fires the global OnChanged event.
    /// </summary>
    private async Task ConditionalScrollAsync()
    {
        var activeAgentId = Store.ActiveAgentId;
        var activeConvId = activeAgentId is not null
            ? Store.GetAgent(activeAgentId)?.ActiveConversationId
            : null;

        // Agent or conversation switched -- force scroll immediately
        bool switched = activeAgentId != _lastActiveAgentId || activeConvId != _lastActiveConversationId;
        if (switched)
        {
            _lastActiveAgentId = activeAgentId;
            _lastActiveConversationId = activeConvId;
            _lastRenderedMessageCount = activeConvId is not null ? Store.GetMessages(activeConvId).Count : 0;
            await ForceScrollToBottomAsync();
            return;
        }

        // Same agent/conv -- only scroll if message count grew for the active conversation
        if (activeConvId is null) return;
        var currentCount = Store.GetMessages(activeConvId).Count;
        var isStreaming = Store.GetStreamState(activeConvId)?.IsStreaming == true;
        if (currentCount > _lastRenderedMessageCount || isStreaming)
        {
            _lastRenderedMessageCount = currentCount;
            await ScrollToBottomAsync(isStreaming);
        }
    }

    /// <summary>
    /// Smart scroll: only scrolls if near the bottom (user-scroll-aware).
    /// </summary>
    private async Task ScrollToBottomAsync(bool isStreaming = false)
    {
        try
        {
            await JS.InvokeVoidAsync("chatScroll.scrollToBottom", _messageStreamRef, isStreaming);
        }
        catch { }
    }

    /// <summary>
    /// Force-scrolls to bottom unconditionally (used on agent/conversation switch).
    /// </summary>
    private async Task ForceScrollToBottomAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("chatScroll.forceScrollToBottom", _messageStreamRef);
        }
        catch { }
    }

    public void Dispose()
    {
        Store.OnChanged -= HandleStateChanged;
        PortalLoad.OnReadyChanged -= HandleReadyChanged;
        PortalLoad.OnConnectionStateChanged -= HandleConnectionStateChanged;
        _dotNetRef?.Dispose();
    }
}
