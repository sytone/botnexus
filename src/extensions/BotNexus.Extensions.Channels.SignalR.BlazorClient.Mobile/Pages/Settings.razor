@page "/settings"
@inject PlatformConfigService ConfigService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>BotNexus - Settings</PageTitle>

@*
    Mobile platform-settings page (config-parity PBI 6/6 of #1579, issue #1615 -- the payoff PBI).
    The whole settings UI is rendered by the SAME shared SchemaForm the desktop Configuration page
    uses (PBI 3/6 #1611), fed by GET /api/config/schema (PBI 2/6 #1610). There is deliberately NO
    mobile-specific field code: any config field added to PlatformConfig with annotations shows up
    here automatically. Saves round-trip through the existing per-section PUT /api/config/{section}
    endpoint -- the same hot-reload-without-restart path the desktop uses.
*@
<div class="mobile-settings-page">
    <div class="settings-top-bar">
        <button class="settings-back-btn" @onclick="GoBack" aria-label="Back to chat" data-testid="settings-back-btn">&#x2190;</button>
        <h2 class="settings-title">Settings</h2>
        <div class="settings-actions">
            @if (!string.IsNullOrEmpty(_statusMessage))
            {
                <span class="settings-status @_statusClass">@_statusMessage</span>
            }
            <button class="toolbar-btn" @onclick="LoadConfig" disabled="@_loading" data-testid="settings-reload-btn">Reload</button>
            <button class="toolbar-btn primary" @onclick="SaveAll" disabled="@(!_dirty || _saving)" data-testid="settings-save-btn">
                @(_saving ? "Saving..." : "Save")
            </button>
        </div>
    </div>

    <div class="settings-body">
        @if (_loading)
        {
            <div class="settings-loading" data-testid="settings-loading">
                <span>Loading configuration&#x2026;</span>
            </div>
        }
        else if (_config is null || _schema is null)
        {
            <div class="settings-empty" data-testid="settings-load-error">Failed to load configuration.</div>
        }
        else
        {
            @* Generic schema-driven renderer shared with desktop -- no mobile-specific field code. *@
            <SchemaForm Schema="_schema" Value="_config" ValueChanged="OnConfigChanged" />
        }
    </div>
</div>
