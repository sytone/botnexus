@using System.Text.Json.Nodes
@using System.Globalization
@using System.Text.RegularExpressions
@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services
@inject IModelOptionsProvider ModelOptions

@*
    Generic config renderer (PBI 3/6 of #1579, issue #1611). Walks the UI-schema envelope from
    GET /api/config/schema (ConfigSchemaBuilder, PBI2 #1610) and draws an editor per node:
    text / toggle / number / select / secret-masked widgets, nested objects, dictionaries
    (additionalProperties), and string lists (items) -- grouped by x-ui-group, ordered by
    x-ui-order, with live field-level validation, two-way bound back to the config JSON for PUT.
    Lives in Core so desktop + mobile share it. Panel migration is PBI4 -- this is the renderer only.
*@

@if (RootProperties is null)
{
    <div class="schema-form-empty" data-testid="schema-form-empty">No schema.</div>
}
else
{
    <div class="schema-form" data-testid="schema-form">
        @foreach (var group in GroupedRoot)
        {
            <div class="schema-group" data-group="@group.Key">
                @if (!string.IsNullOrEmpty(group.Key))
                {
                    <h4 class="schema-group-title">@group.Key</h4>
                }
                @foreach (var (name, node) in group.Value)
                {
                    @RenderNode(name, node, name)
                }
            </div>
        }
    </div>
}

@code {
    /// <summary>Schema envelope: { schemaVersion, root, schema:{ type:object, properties:{...} } }.</summary>
    [Parameter, EditorRequired]
    public JsonObject Schema { get; set; } = default!;

    /// <summary>Config JSON edited in place and written back. Bind with @bind-Value.</summary>
    [Parameter, EditorRequired]
    public JsonObject Value { get; set; } = default!;

    [Parameter]
    public EventCallback<JsonObject> ValueChanged { get; set; }

    /// <summary>
    /// When set, renders only the single root section with this property key (e.g. <c>"providers"</c>)
    /// instead of the whole config tree. Drives the sidebar-sectioned layout (#1892): the page keys
    /// a nav off the root schema properties and feeds the selected section here. Null/empty or an
    /// unknown key falls back to rendering the full tree (backwards-compatible with callers that
    /// don't section).
    /// </summary>
    [Parameter]
    public string? SectionKey { get; set; }

    private const string SecretSentinel = "***";

    private JsonObject? RootProperties
    {
        get
        {
            var props = Schema?["schema"]?["properties"]?.AsObject();
            if (props is null || string.IsNullOrEmpty(SectionKey))
                return props;
            // Section view: narrow the root to just the selected property so the renderer draws a
            // single section. Unknown key -> fall back to the full tree rather than a blank form.
            if (props.TryGetPropertyValue(SectionKey, out var node) && node is JsonObject obj)
                return new JsonObject { [SectionKey] = obj.DeepClone() };
            return props;
        }
    }

    /// <summary>Ordered root section descriptors (key + label) for a sidebar/nav. Ignores <see cref="SectionKey"/>.</summary>
    public IReadOnlyList<(string Key, string Label)> RootSections()
    {
        var props = Schema?["schema"]?["properties"]?.AsObject();
        if (props is null)
            return [];
        return props
            .Where(kv => kv.Value is JsonObject)
            .Select(kv => (kv.Key, Node: kv.Value!.AsObject()))
            .OrderBy(x => x.Node["x-ui-order"]?.GetValue<int>() ?? int.MaxValue)
            .ThenBy(x => x.Key, StringComparer.Ordinal)
            .Select(x => (x.Key, Label: x.Node["x-ui-label"]?.GetValue<string>() ?? x.Key))
            .ToList();
    }

    // Per-provider model lists fetched for x-ui-options-source="models" fields (#1893). Keyed by the
    // enclosing providers-dictionary key; populated on demand and re-rendered when a fetch completes.
    private readonly Dictionary<string, IReadOnlyList<ModelOption>> _modelsByProvider = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _modelFetchInFlight = new(StringComparer.OrdinalIgnoreCase);

    // Resolve the option list for a select node. A dynamic x-ui-options-source ("models", "thinking",
    // "contextSizes") is resolved against the enclosing provider's live model list, falling back to
    // any static x-ui-options when the dynamic list is unavailable or empty.
    private IReadOnlyList<string> SelectOptions(JsonObject node, string path)
    {
        var source = node["x-ui-options-source"]?.GetValue<string>();
        if (!string.IsNullOrEmpty(source))
        {
            var dynamicOptions = ResolveDynamicOptions(source, path);
            if (dynamicOptions.Count > 0)
                return dynamicOptions;
        }
        return StaticOptions(node);
    }

    private static IReadOnlyList<string> StaticOptions(JsonObject node)
    {
        var arr = node["x-ui-options"]?.AsArray();
        if (arr is null)
            return [];
        return arr.Where(o => o is not null).Select(o => o!.GetValue<string>()).ToList();
    }

    private IReadOnlyList<string> ResolveDynamicOptions(string source, string path)
    {
        var provider = EnclosingProviderKey(path);
        if (provider is null)
            return [];
        // Kick off the fetch lazily; return what we have (possibly empty) this pass.
        if (!_modelsByProvider.TryGetValue(provider, out var models))
        {
            _ = EnsureModelsAsync(provider);
            return [];
        }
        return source switch
        {
            "models" => models.Select(m => m.ModelId).ToList(),
            // thinking / contextSizes derive from the model currently selected in a sibling field.
            "thinking" => SelectedModel(models, path)?.SupportedThinkingLevels.ToList() ?? [],
            "contextSizes" => SelectedModel(models, path)?.SupportedContextSizes
                .Select(s => s.ToString(CultureInfo.InvariantCulture)).ToList() ?? [],
            _ => [],
        };
    }

    // The model selected in the sibling "defaultModel" field of the same provider entry, used to
    // scope thinking/contextSizes option sets.
    private ModelOption? SelectedModel(IReadOnlyList<ModelOption> models, string path)
    {
        var dot = path.LastIndexOf('.');
        if (dot < 0)
            return null;
        var siblingModelPath = $"{path[..dot]}.defaultModel";
        var selectedId = AsString(Resolve(siblingModelPath));
        return selectedId is null ? null : models.FirstOrDefault(m => m.ModelId == selectedId);
    }

    // Extract the provider key when a field sits under providers.<key>.* so the dynamic source can be
    // scoped to that provider's models. Returns null for fields outside the providers dictionary.
    private static string? EnclosingProviderKey(string path)
    {
        var segs = path.Split('.', StringSplitOptions.RemoveEmptyEntries);
        for (var i = 0; i < segs.Length - 1; i++)
        {
            if (string.Equals(segs[i], "providers", StringComparison.OrdinalIgnoreCase))
                return segs[i + 1];
        }
        return null;
    }

    private async Task EnsureModelsAsync(string provider)
    {
        if (!_modelFetchInFlight.Add(provider))
            return;
        try
        {
            var models = await ModelOptions.GetModelsAsync(provider);
            _modelsByProvider[provider] = models;
            await InvokeAsync(StateHasChanged);
        }
        finally
        {
            _modelFetchInFlight.Remove(provider);
        }
    }

    private IEnumerable<KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>> GroupedRoot =>
        OrderAndGroup(RootProperties);

    private static IEnumerable<KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>> OrderAndGroup(JsonObject? props)
    {
        var items = new List<KeyValuePair<string, JsonObject>>();
        if (props is not null)
        {
            foreach (var kv in props)
                if (kv.Value is JsonObject o) items.Add(new(kv.Key, o));
        }
        return items
            .OrderBy(kv => kv.Value["x-ui-order"]?.GetValue<int>() ?? int.MaxValue)
            .ThenBy(kv => kv.Key, StringComparer.Ordinal)
            .GroupBy(kv => kv.Value["x-ui-group"]?.GetValue<string>() ?? string.Empty)
            .Select(g => new KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>(g.Key, g.ToList()));
    }

    private static string Widget(JsonObject node) =>
        node["x-ui-widget"]?.GetValue<string>() ?? InferWidget(node);

    private static string InferWidget(JsonObject node) => NodeType(node) switch
    {
        "boolean" => "toggle",
        "integer" or "number" => "number",
        _ => "text",
    };

    private static string? NodeType(JsonObject node) => node["type"] switch
    {
        JsonArray arr => arr.Select(t => t!.GetValue<string>()).FirstOrDefault(t => t != "null"),
        JsonValue v => v.GetValue<string>(),
        _ => null,
    };

    private static bool IsObject(JsonObject node) => NodeType(node) == "object" && node["additionalProperties"] is null;
    private static bool IsDictionary(JsonObject node) => node["additionalProperties"] is JsonObject;
    private static bool IsArray(JsonObject node) => NodeType(node) == "array";
    private static bool IsSecret(JsonObject node) => node["x-ui-secret"]?.GetValue<bool>() == true || Widget(node) == "secret";

    private static string Label(string name, JsonObject node) => node["x-ui-label"]?.GetValue<string>() ?? name;

    // Recursive node dispatcher: object -> children; dict -> entries; array -> items; else widget.
    private RenderFragment RenderNode(string name, JsonObject node, string path) => __builder =>
    {
        if (IsObject(node))
        {
            <fieldset class="schema-object" data-testid="@($"object-{path}")">
                <legend>@Label(name, node)</legend>
                @foreach (var group in OrderAndGroup(node["properties"]?.AsObject()))
                {
                    @foreach (var (childName, childNode) in group.Value)
                    {
                        @RenderNode(childName, childNode, $"{path}.{childName}")
                    }
                }
            </fieldset>
        }
        else if (IsDictionary(node))
        {
            var valueSchema = node["additionalProperties"]!.AsObject();
            var immutableKeys = node["x-ui-immutable-keys"]?.GetValue<bool>() == true;
            var dict = Resolve(path) as JsonObject;
            <fieldset class="schema-dict" data-testid="@($"dict-{path}")">
                <legend>@Label(name, node)</legend>
                @foreach (var entry in dict?.ToList() ?? [])
                {
                    var key = entry.Key;
                    var renameStateKey = $"{path}::{key}";
                    <div class="schema-dict-entry" data-key="@key">
                        <span class="schema-dict-key">@key</span>
                        @if (!immutableKeys)
                        {
                            <input class="dict-rename-input" data-testid="@($"dict-rename-input-{path}-{key}")"
                                   value="@(_renameKeys.TryGetValue(renameStateKey, out var rn) ? rn : key)"
                                   @onchange="e => _renameKeys[renameStateKey] = e.Value?.ToString() ?? string.Empty" />
                            <button type="button" class="dict-rename" data-testid="@($"dict-rename-{path}-{key}")"
                                    @onclick="() => RenameDictEntry(path, node, key)">Rename</button>
                        }
                        @RenderNode(key, valueSchema, $"{path}.{key}")
                        <button type="button" class="dict-entry-delete" data-testid="@($"dict-delete-{path}-{key}")"
                                @onclick="() => RemoveDictEntry(path, key)">Delete</button>
                    </div>
                }
                <div class="schema-dict-add">
                    <input class="dict-newkey" data-testid="@($"dict-newkey-{path}")"
                           value="@(_newKeys.TryGetValue(path, out var nk) ? nk : string.Empty)"
                           @onchange="e => _newKeys[path] = e.Value?.ToString() ?? string.Empty" />
                    <button type="button" class="dict-add" data-testid="@($"dict-add-{path}")"
                            @onclick="() => AddDictEntry(path, node, valueSchema)">Add</button>
                </div>
                @if (_collectionErrors.TryGetValue(path, out var derr) && derr is not null)
                {
                    <span class="schema-dict-error" data-testid="@($"dict-error-{path}")">@derr</span>
                }
            </fieldset>
        }
        else if (IsArray(node))
        {
            var itemSchema = node["items"]?.AsObject() ?? new JsonObject { ["type"] = "string" };
            var arr = Resolve(path) as JsonArray ?? [];
            <fieldset class="schema-array" data-testid="@($"array-{path}")">
                <legend>@Label(name, node)</legend>
                @for (var i = 0; i < arr.Count; i++)
                {
                    var index = i;
                    <div class="schema-array-item" data-index="@index">
                        @RenderNode($"[{index}]", itemSchema, $"{path}[{index}]")
                        <button type="button" class="array-item-up" data-testid="@($"array-up-{path}-{index}")"
                                disabled="@(index == 0)" @onclick="() => MoveListItem(path, index, -1)">Up</button>
                        <button type="button" class="array-item-down" data-testid="@($"array-down-{path}-{index}")"
                                disabled="@(index == arr.Count - 1)" @onclick="() => MoveListItem(path, index, 1)">Down</button>
                        <button type="button" class="array-item-remove" data-testid="@($"array-remove-{path}-{index}")"
                                @onclick="() => RemoveListItem(path, index)">Remove</button>
                    </div>
                }
                <button type="button" class="array-add" data-testid="@($"array-add-{path}")"
                        @onclick="() => AddListItem(path, itemSchema)">Add</button>
                @if (_collectionErrors.TryGetValue(path, out var aerr) && aerr is not null)
                {
                    <span class="schema-array-error" data-testid="@($"array-error-{path}")">@aerr</span>
                }
            </fieldset>
        }
        else
        {
            @RenderField(name, node, path)
        }
    };

    private RenderFragment RenderField(string name, JsonObject node, string path) => __builder =>
    {
        var widget = Widget(node);
        var error = Validate(node, Resolve(path));
        var redacted = IsRedacted(Resolve(path));
        var secretPlaceholder = redacted ? "(set; leave blank to keep)" : "";
        var secretValue = redacted ? "" : AsString(Resolve(path));
        var current = Resolve(path);
        var textValue = AsString(current) ?? "";
        var numberValue = current?.ToString() ?? "";
        var selectValue = AsString(current) ?? "";
        <div class="schema-field" data-testid="@($"field-{path}")">
            <label class="schema-field-label">@Label(name, node)</label>
            @if (widget == "toggle")
            {
                <input type="checkbox" checked="@(AsBool(Resolve(path)))"
                       @onchange="e => Set(path, JsonValue.Create((bool)e.Value!))" />
            }
            else if (widget == "number")
            {
                <input type="number" value="@numberValue"
                       @onchange="e => SetNumber(path, e.Value?.ToString())" />
            }
            else if (widget == "select")
            {
                var options = SelectOptions(node, path);
                <select value="@selectValue"
                        @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))">
                    @* Blank sentinel so an unset/optional select can stay empty and a dynamic list
                       that has not loaded yet still shows the current value. *@
                    <option value=""></option>
                    @foreach (var opt in options)
                    {
                        <option value="@opt" selected="@(string.Equals(opt, selectValue, StringComparison.Ordinal))">@opt</option>
                    }
                </select>
            }
            else if (IsSecret(node))
            {
                <input type="password" placeholder="@secretPlaceholder"
                       value="@secretValue"
                       @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))" />
            }
            else
            {
                <input type="text" value="@textValue"
                       @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))" />
            }
            @if (error is not null)
            {
                <span class="schema-field-error">@error</span>
            }
        </div>
    };

    private static bool IsRedacted(JsonNode? n) => AsString(n) == SecretSentinel;

    private static string? AsString(JsonNode? n)
    {
        if (n is not JsonValue v) return null;
        return v.TryGetValue<string>(out var s) ? s : v.ToString();
    }

    private static bool AsBool(JsonNode? n) => n is JsonValue v && v.TryGetValue<bool>(out var b) && b;

    private JsonNode? Resolve(string path)
    {
        JsonNode? cur = Value;
        foreach (var seg in Tokenize(path))
        {
            if (cur is null) return null;
            cur = seg.StartsWith('[')
                ? cur.AsArray()[int.Parse(seg.Trim('[', ']'), CultureInfo.InvariantCulture)]
                : cur.AsObject().TryGetPropertyValue(seg, out var v) ? v : null;
        }
        return cur;
    }

    // Collection-lifecycle UI state. Keyed by the collection's JSON path so multiple
    // dictionaries/arrays on one form keep independent draft keys and error messages.
    private readonly Dictionary<string, string> _newKeys = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string> _renameKeys = new(StringComparer.Ordinal);
    private readonly Dictionary<string, string?> _collectionErrors = new(StringComparer.Ordinal);

    // Writes a value at an arbitrary object-or-array path, creating intermediate objects as needed
    // and traversing existing arrays by index. The previous implementation only walked JsonObject
    // intermediates, so any path passing through a JsonArray element (e.g. models[0].id or a
    // dictionary-of-objects entry) silently wrote into a fresh object graph and lost the edit
    // (#2062). Traversal now mirrors Resolve(): a "[i]" token indexes the current JsonArray, every
    // other token indexes the current JsonObject.
    private void Set(string path, JsonNode? value)
    {
        var segs = Tokenize(path).ToList();
        JsonNode? cur = Value;
        for (var i = 0; i < segs.Count - 1; i++)
        {
            var seg = segs[i];
            if (seg.StartsWith('['))
            {
                var idx = int.Parse(seg.Trim('[', ']'), CultureInfo.InvariantCulture);
                var array = cur as JsonArray ?? throw new InvalidOperationException($"Path segment '{seg}' expects an array at '{path}'.");
                cur = array[idx];
            }
            else
            {
                var obj = cur as JsonObject ?? throw new InvalidOperationException($"Path segment '{seg}' expects an object at '{path}'.");
                // Look ahead: if the next token indexes an array, the intermediate must be an array,
                // otherwise create/keep an object.
                var nextIsIndex = segs[i + 1].StartsWith('[');
                if (nextIsIndex)
                {
                    if (obj[seg] is not JsonArray arr) { arr = []; obj[seg] = arr; }
                    cur = arr;
                }
                else
                {
                    if (obj[seg] is not JsonObject next) { next = []; obj[seg] = next; }
                    cur = next;
                }
            }
        }

        var last = segs[^1];
        if (last.StartsWith('['))
        {
            var idx = int.Parse(last.Trim('[', ']'), CultureInfo.InvariantCulture);
            var array = cur as JsonArray ?? throw new InvalidOperationException($"Path segment '{last}' expects an array at '{path}'.");
            array[idx] = value;
        }
        else
        {
            var obj = cur as JsonObject ?? throw new InvalidOperationException($"Path segment '{last}' expects an object at '{path}'.");
            obj[last] = value;
        }
        ValueChanged.InvokeAsync(Value);
    }

    // ── List lifecycle (#2062) ──────────────────────────────────────────────

    // Ensures the array at path exists (creating it in place without disturbing siblings) and
    // returns it. Uses Set's exact-path traversal so a nested/array-embedded collection is created
    // at the right spot rather than replacing an unrelated sibling.
    private JsonArray EnsureArray(string path)
    {
        if (Resolve(path) is JsonArray existing)
            return existing;
        var created = new JsonArray();
        Set(path, created);
        return (Resolve(path) as JsonArray)!;
    }

    private JsonObject EnsureObject(string path)
    {
        if (Resolve(path) is JsonObject existing)
            return existing;
        var created = new JsonObject();
        Set(path, created);
        return (Resolve(path) as JsonObject)!;
    }

    private void AddListItem(string path, JsonObject itemSchema)
    {
        var arr = EnsureArray(path);
        arr.Add(DefaultForSchema(itemSchema));
        _collectionErrors[path] = null;
        ValueChanged.InvokeAsync(Value);
    }

    private void RemoveListItem(string path, int index)
    {
        if (Resolve(path) is JsonArray arr && index >= 0 && index < arr.Count)
        {
            arr.RemoveAt(index);
            ValueChanged.InvokeAsync(Value);
        }
    }

    // Moves an item by a signed delta (-1 up, +1 down). Reorders in place by detaching and
    // re-inserting the node so unrelated siblings are untouched.
    private void MoveListItem(string path, int index, int delta)
    {
        if (Resolve(path) is not JsonArray arr)
            return;
        var target = index + delta;
        if (index < 0 || index >= arr.Count || target < 0 || target >= arr.Count)
            return;
        var node = arr[index];
        arr.RemoveAt(index);
        var clone = node?.DeepClone();
        arr.Insert(target, clone);
        ValueChanged.InvokeAsync(Value);
    }

    // ── Dictionary lifecycle (#2062) ────────────────────────────────────────

    private void AddDictEntry(string path, JsonObject dictNode, JsonObject valueSchema)
    {
        var key = (_newKeys.TryGetValue(path, out var k) ? k : string.Empty).Trim();
        var dict = Resolve(path) as JsonObject;
        var error = ValidateKey(dictNode, key, dict, originalKey: null);
        if (error is not null) { _collectionErrors[path] = error; return; }

        var target = EnsureObject(path);
        target[key] = DefaultForSchema(valueSchema);
        _newKeys[path] = string.Empty;
        _collectionErrors[path] = null;
        ValueChanged.InvokeAsync(Value);
    }

    private void RemoveDictEntry(string path, string key)
    {
        if (Resolve(path) is JsonObject dict && dict.ContainsKey(key))
        {
            dict.Remove(key);
            _collectionErrors[path] = null;
            ValueChanged.InvokeAsync(Value);
        }
    }

    // Renames a dictionary key while preserving the entry's value and its position among siblings.
    // Rebuilds the object in order so a rename does not reorder unrelated entries (JsonObject has no
    // in-place rename). Immutable-key dictionaries never render a rename control, so this is a no-op
    // guard for them.
    private void RenameDictEntry(string path, JsonObject dictNode, string originalKey)
    {
        if (dictNode["x-ui-immutable-keys"]?.GetValue<bool>() == true)
            return;
        var renameStateKey = $"{path}::{originalKey}";
        var newKey = (_renameKeys.TryGetValue(renameStateKey, out var nk) ? nk : originalKey).Trim();
        if (Resolve(path) is not JsonObject dict)
            return;
        if (string.Equals(newKey, originalKey, StringComparison.Ordinal))
        {
            _collectionErrors[path] = null;
            return;
        }
        var error = ValidateKey(dictNode, newKey, dict, originalKey);
        if (error is not null) { _collectionErrors[path] = error; return; }

        // Rebuild preserving order: swap the key in place.
        var entries = dict.ToList();
        foreach (var e in entries)
            dict.Remove(e.Key);
        foreach (var e in entries)
        {
            var emitKey = string.Equals(e.Key, originalKey, StringComparison.Ordinal) ? newKey : e.Key;
            dict[emitKey] = e.Value?.DeepClone();
        }
        _renameKeys.Remove(renameStateKey);
        _collectionErrors[path] = null;
        ValueChanged.InvokeAsync(Value);
    }

    // Validates a proposed dictionary key against schema metadata: non-empty, unique (ignoring the
    // entry being renamed), and matching any x-ui-key-pattern regex the schema supplies.
    private static string? ValidateKey(JsonObject dictNode, string key, JsonObject? dict, string? originalKey)
    {
        if (string.IsNullOrWhiteSpace(key))
            return "Key must not be empty.";
        if (dict is not null && dict.ContainsKey(key) && !string.Equals(key, originalKey, StringComparison.Ordinal))
            return $"Key '{key}' already exists.";
        var pattern = dictNode["x-ui-key-pattern"]?.GetValue<string>();
        if (!string.IsNullOrEmpty(pattern) && !Regex.IsMatch(key, pattern))
            return $"Key '{key}' does not match required pattern.";
        return null;
    }

    // Builds an empty-but-valid default value for a freshly added collection item/entry from its
    // schema node: objects get their declared child scalars defaulted, arrays start empty, scalars
    // use their schema default or a type-appropriate empty value.
    private static JsonNode? DefaultForSchema(JsonObject schema)
    {
        if (IsObject(schema))
        {
            var obj = new JsonObject();
            if (schema["properties"] is JsonObject props)
            {
                foreach (var (childName, childNode) in props)
                {
                    if (childNode is JsonObject childObj)
                        obj[childName] = DefaultForSchema(childObj);
                }
            }
            return obj;
        }
        if (IsDictionary(schema))
            return new JsonObject();
        if (IsArray(schema))
            return new JsonArray();
        if (schema["default"] is JsonNode def)
            return def.DeepClone();
        return NodeType(schema) switch
        {
            "boolean" => JsonValue.Create(false),
            "integer" or "number" => JsonValue.Create(0),
            _ => JsonValue.Create(string.Empty),
        };
    }

    private void SetNumber(string path, string? raw)
    {
        if (long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var l)) Set(path, JsonValue.Create(l));
        else if (double.TryParse(raw, NumberStyles.Float, CultureInfo.InvariantCulture, out var d)) Set(path, JsonValue.Create(d));
        else Set(path, null);
    }

    private static IEnumerable<string> Tokenize(string path)
    {
        foreach (var part in path.Split('.', StringSplitOptions.RemoveEmptyEntries))
        {
            var bracket = part.IndexOf('[');
            if (bracket < 0) { yield return part; continue; }
            yield return part[..bracket];
            yield return part[bracket..];
        }
    }

    private static string? Validate(JsonObject node, JsonNode? current)
    {
        if (node["x-ui-validation"] is not JsonObject rules || current is null) return null;
        if (!double.TryParse(current.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var num)) return null;
        if (rules["minimum"] is { } min && double.TryParse(min.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var lo) && num < lo) return $"Must be >= {lo}";
        if (rules["maximum"] is { } max && double.TryParse(max.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var hi) && num > hi) return $"Must be <= {hi}";
        return null;
    }
}
