@using System.Text.Json.Nodes
@using System.Globalization

@*
    Generic config renderer (PBI 3/6 of #1579, issue #1611). Walks the UI-schema envelope from
    GET /api/config/schema (ConfigSchemaBuilder, PBI2 #1610) and draws an editor per node:
    text / toggle / number / select / secret-masked widgets, nested objects, dictionaries
    (additionalProperties), and string lists (items) -- grouped by x-ui-group, ordered by
    x-ui-order, with live field-level validation, two-way bound back to the config JSON for PUT.
    Lives in Core so desktop + mobile share it. Panel migration is PBI4 -- this is the renderer only.
*@

@if (RootProperties is null)
{
    <div class="schema-form-empty" data-testid="schema-form-empty">No schema.</div>
}
else
{
    <div class="schema-form" data-testid="schema-form">
        @foreach (var group in GroupedRoot)
        {
            <div class="schema-group" data-group="@group.Key">
                @if (!string.IsNullOrEmpty(group.Key))
                {
                    <h4 class="schema-group-title">@group.Key</h4>
                }
                @foreach (var (name, node) in group.Value)
                {
                    @RenderNode(name, node, name)
                }
            </div>
        }
    </div>
}

@code {
    /// <summary>Schema envelope: { schemaVersion, root, schema:{ type:object, properties:{...} } }.</summary>
    [Parameter, EditorRequired]
    public JsonObject Schema { get; set; } = default!;

    /// <summary>Config JSON edited in place and written back. Bind with @bind-Value.</summary>
    [Parameter, EditorRequired]
    public JsonObject Value { get; set; } = default!;

    [Parameter]
    public EventCallback<JsonObject> ValueChanged { get; set; }

    /// <summary>
    /// When set, renders only the single root section with this property key (e.g. <c>"providers"</c>)
    /// instead of the whole config tree. Drives the sidebar-sectioned layout (#1892): the page keys
    /// a nav off the root schema properties and feeds the selected section here. Null/empty or an
    /// unknown key falls back to rendering the full tree (backwards-compatible with callers that
    /// don't section).
    /// </summary>
    [Parameter]
    public string? SectionKey { get; set; }

    private const string SecretSentinel = "***";

    private JsonObject? RootProperties
    {
        get
        {
            var props = Schema?["schema"]?["properties"]?.AsObject();
            if (props is null || string.IsNullOrEmpty(SectionKey))
                return props;
            // Section view: narrow the root to just the selected property so the renderer draws a
            // single section. Unknown key -> fall back to the full tree rather than a blank form.
            if (props.TryGetPropertyValue(SectionKey, out var node) && node is JsonObject obj)
                return new JsonObject { [SectionKey] = obj.DeepClone() };
            return props;
        }
    }

    /// <summary>Ordered root section descriptors (key + label) for a sidebar/nav. Ignores <see cref="SectionKey"/>.</summary>
    public IReadOnlyList<(string Key, string Label)> RootSections()
    {
        var props = Schema?["schema"]?["properties"]?.AsObject();
        if (props is null)
            return [];
        return props
            .Where(kv => kv.Value is JsonObject)
            .Select(kv => (kv.Key, Node: kv.Value!.AsObject()))
            .OrderBy(x => x.Node["x-ui-order"]?.GetValue<int>() ?? int.MaxValue)
            .ThenBy(x => x.Key, StringComparer.Ordinal)
            .Select(x => (x.Key, Label: x.Node["x-ui-label"]?.GetValue<string>() ?? x.Key))
            .ToList();
    }

    private IEnumerable<KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>> GroupedRoot =>
        OrderAndGroup(RootProperties);

    private static IEnumerable<KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>> OrderAndGroup(JsonObject? props)
    {
        var items = new List<KeyValuePair<string, JsonObject>>();
        if (props is not null)
        {
            foreach (var kv in props)
                if (kv.Value is JsonObject o) items.Add(new(kv.Key, o));
        }
        return items
            .OrderBy(kv => kv.Value["x-ui-order"]?.GetValue<int>() ?? int.MaxValue)
            .ThenBy(kv => kv.Key, StringComparer.Ordinal)
            .GroupBy(kv => kv.Value["x-ui-group"]?.GetValue<string>() ?? string.Empty)
            .Select(g => new KeyValuePair<string, List<KeyValuePair<string, JsonObject>>>(g.Key, g.ToList()));
    }

    private static string Widget(JsonObject node) =>
        node["x-ui-widget"]?.GetValue<string>() ?? InferWidget(node);

    private static string InferWidget(JsonObject node) => NodeType(node) switch
    {
        "boolean" => "toggle",
        "integer" or "number" => "number",
        _ => "text",
    };

    private static string? NodeType(JsonObject node) => node["type"] switch
    {
        JsonArray arr => arr.Select(t => t!.GetValue<string>()).FirstOrDefault(t => t != "null"),
        JsonValue v => v.GetValue<string>(),
        _ => null,
    };

    private static bool IsObject(JsonObject node) => NodeType(node) == "object" && node["additionalProperties"] is null;
    private static bool IsDictionary(JsonObject node) => node["additionalProperties"] is JsonObject;
    private static bool IsArray(JsonObject node) => NodeType(node) == "array";
    private static bool IsSecret(JsonObject node) => node["x-ui-secret"]?.GetValue<bool>() == true || Widget(node) == "secret";

    private static string Label(string name, JsonObject node) => node["x-ui-label"]?.GetValue<string>() ?? name;

    // Recursive node dispatcher: object -> children; dict -> entries; array -> items; else widget.
    private RenderFragment RenderNode(string name, JsonObject node, string path) => __builder =>
    {
        if (IsObject(node))
        {
            <fieldset class="schema-object" data-testid="@($"object-{path}")">
                <legend>@Label(name, node)</legend>
                @foreach (var group in OrderAndGroup(node["properties"]?.AsObject()))
                {
                    @foreach (var (childName, childNode) in group.Value)
                    {
                        @RenderNode(childName, childNode, $"{path}.{childName}")
                    }
                }
            </fieldset>
        }
        else if (IsDictionary(node))
        {
            var valueSchema = node["additionalProperties"]!.AsObject();
            <fieldset class="schema-dict" data-testid="@($"dict-{path}")">
                <legend>@Label(name, node)</legend>
                @foreach (var entry in (Resolve(path) as JsonObject)?.ToList() ?? [])
                {
                    <div class="schema-dict-entry" data-key="@entry.Key">
                        <span class="schema-dict-key">@entry.Key</span>
                        @RenderNode(entry.Key, valueSchema, $"{path}.{entry.Key}")
                    </div>
                }
            </fieldset>
        }
        else if (IsArray(node))
        {
            var itemSchema = node["items"]?.AsObject() ?? new JsonObject { ["type"] = "string" };
            var arr = Resolve(path) as JsonArray ?? [];
            <fieldset class="schema-array" data-testid="@($"array-{path}")">
                <legend>@Label(name, node)</legend>
                @for (var i = 0; i < arr.Count; i++)
                {
                    @RenderNode($"[{i}]", itemSchema, $"{path}[{i}]")
                }
            </fieldset>
        }
        else
        {
            @RenderField(name, node, path)
        }
    };

    private RenderFragment RenderField(string name, JsonObject node, string path) => __builder =>
    {
        var widget = Widget(node);
        var error = Validate(node, Resolve(path));
        var redacted = IsRedacted(Resolve(path));
        var secretPlaceholder = redacted ? "(set; leave blank to keep)" : "";
        var secretValue = redacted ? "" : AsString(Resolve(path));
        var current = Resolve(path);
        var textValue = AsString(current) ?? "";
        var numberValue = current?.ToString() ?? "";
        var selectValue = AsString(current) ?? "";
        <div class="schema-field" data-testid="@($"field-{path}")">
            <label class="schema-field-label">@Label(name, node)</label>
            @if (widget == "toggle")
            {
                <input type="checkbox" checked="@(AsBool(Resolve(path)))"
                       @onchange="e => Set(path, JsonValue.Create((bool)e.Value!))" />
            }
            else if (widget == "number")
            {
                <input type="number" value="@numberValue"
                       @onchange="e => SetNumber(path, e.Value?.ToString())" />
            }
            else if (widget == "select")
            {
                <select value="@selectValue"
                        @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))">
                    @foreach (var opt in node["x-ui-options"]?.AsArray() ?? [])
                    {
                        var optText = opt!.GetValue<string>();
                        <option value="@optText">@optText</option>
                    }
                </select>
            }
            else if (IsSecret(node))
            {
                <input type="password" placeholder="@secretPlaceholder"
                       value="@secretValue"
                       @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))" />
            }
            else
            {
                <input type="text" value="@textValue"
                       @onchange="e => Set(path, JsonValue.Create(e.Value?.ToString()))" />
            }
            @if (error is not null)
            {
                <span class="schema-field-error">@error</span>
            }
        </div>
    };

    private static bool IsRedacted(JsonNode? n) => AsString(n) == SecretSentinel;

    private static string? AsString(JsonNode? n)
    {
        if (n is not JsonValue v) return null;
        return v.TryGetValue<string>(out var s) ? s : v.ToString();
    }

    private static bool AsBool(JsonNode? n) => n is JsonValue v && v.TryGetValue<bool>(out var b) && b;

    private JsonNode? Resolve(string path)
    {
        JsonNode? cur = Value;
        foreach (var seg in Tokenize(path))
        {
            if (cur is null) return null;
            cur = seg.StartsWith('[')
                ? cur.AsArray()[int.Parse(seg.Trim('[', ']'), CultureInfo.InvariantCulture)]
                : cur.AsObject().TryGetPropertyValue(seg, out var v) ? v : null;
        }
        return cur;
    }

    private void Set(string path, JsonNode? value)
    {
        var segs = Tokenize(path).ToList();
        JsonObject obj = Value;
        for (var i = 0; i < segs.Count - 1; i++)
        {
            if (obj[segs[i]] is not JsonObject next) { next = []; obj[segs[i]] = next; }
            obj = next;
        }
        obj[segs[^1]] = value;
        ValueChanged.InvokeAsync(Value);
    }

    private void SetNumber(string path, string? raw)
    {
        if (long.TryParse(raw, NumberStyles.Integer, CultureInfo.InvariantCulture, out var l)) Set(path, JsonValue.Create(l));
        else if (double.TryParse(raw, NumberStyles.Float, CultureInfo.InvariantCulture, out var d)) Set(path, JsonValue.Create(d));
        else Set(path, null);
    }

    private static IEnumerable<string> Tokenize(string path)
    {
        foreach (var part in path.Split('.', StringSplitOptions.RemoveEmptyEntries))
        {
            var bracket = part.IndexOf('[');
            if (bracket < 0) { yield return part; continue; }
            yield return part[..bracket];
            yield return part[bracket..];
        }
    }

    private static string? Validate(JsonObject node, JsonNode? current)
    {
        if (node["x-ui-validation"] is not JsonObject rules || current is null) return null;
        if (!double.TryParse(current.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var num)) return null;
        if (rules["minimum"] is { } min && double.TryParse(min.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var lo) && num < lo) return $"Must be >= {lo}";
        if (rules["maximum"] is { } max && double.TryParse(max.ToString(), NumberStyles.Float, CultureInfo.InvariantCulture, out var hi) && num > hi) return $"Must be <= {hi}";
        return null;
    }
}
