@using BotNexus.Extensions.Channels.SignalR.BlazorClient.Services
@implements IDisposable

<div class="ask-user-prompt" data-testid="ask-user-prompt" role="group" aria-label="Agent question">
    <div class="ask-user-header">
        <span class="ask-user-title">❓ Agent needs input</span>
        @if (_secondsRemaining is not null)
        {
            <span class="ask-user-timeout">Expires in @_secondsRemaining.Value s</span>
        }
    </div>

    <p class="ask-user-text">@Prompt.Prompt</p>

    @if (IsChoiceMode)
    {
        <div class="ask-user-choices">
            @foreach (var choice in Prompt.Choices ?? [])
            {
                @if (Prompt.AllowMultiple || IsMultipleChoice)
                {
                    <label class="ask-user-choice">
                        <input type="checkbox"
                               disabled="@Prompt.IsSubmitting"
                               checked="@_selectedValues.Contains(choice.Value)"
                               @onchange="@(args => ToggleChoice(choice.Value, args.Value as bool? == true))" />
                        <span class="ask-user-choice-label" title="@choice.Description">@choice.Label</span>
                    </label>
                }
                else
                {
                    <label class="ask-user-choice">
                        <input type="radio"
                               name="ask-user-choice"
                               disabled="@Prompt.IsSubmitting"
                               checked="@(_singleChoice == choice.Value)"
                               @onchange="() => _singleChoice = choice.Value" />
                        <span class="ask-user-choice-label" title="@choice.Description">@choice.Label</span>
                    </label>
                }
            }
        </div>
    }

    @if (ShowsFreeForm)
    {
        <textarea class="ask-user-free-form"
                  @bind="_freeFormText"
                  @bind:event="oninput"
                  placeholder="Type your response…"
                  disabled="@Prompt.IsSubmitting"></textarea>
    }

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="ask-user-error">@ErrorMessage</div>
    }

    <div class="ask-user-actions">
        <button type="button"
                class="cancel-btn"
                data-testid="ask-user-cancel"
                disabled="@Prompt.IsSubmitting"
                @onclick="CancelAsync">
            Cancel
        </button>
        <button type="button"
                class="send-btn"
                data-testid="ask-user-submit"
                disabled="@(!CanSubmit || Prompt.IsSubmitting)"
                @onclick="SubmitAsync">
            @(Prompt.IsSubmitting ? "Submitting…" : "Submit")
        </button>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public AskUserPromptState Prompt { get; set; } = default!;

    [Parameter]
    public EventCallback<AskUserPromptSubmission> OnSubmit { get; set; }

    [Parameter]
    public EventCallback OnTimeout { get; set; }

    [Parameter]
    public string? ErrorMessage { get; set; }

    private string _freeFormText = string.Empty;
    private string? _singleChoice;
    private HashSet<string> _selectedValues = [];
    private string? _lastRequestId;
    private int? _secondsRemaining;
    private PeriodicTimer? _countdownTimer;
    private CancellationTokenSource? _countdownCts;

    private bool IsMultipleChoice =>
        string.Equals(Prompt.InputType, "MultipleChoice", StringComparison.OrdinalIgnoreCase);

    private bool IsSingleChoice =>
        string.Equals(Prompt.InputType, "SingleChoice", StringComparison.OrdinalIgnoreCase);

    private bool IsChoiceOrFreeForm =>
        string.Equals(Prompt.InputType, "ChoiceOrFreeForm", StringComparison.OrdinalIgnoreCase);

    private bool IsFreeFormOnly =>
        string.Equals(Prompt.InputType, "FreeForm", StringComparison.OrdinalIgnoreCase);

    private bool IsChoiceMode => IsSingleChoice || IsMultipleChoice || IsChoiceOrFreeForm;
    private bool ShowsFreeForm => IsFreeFormOnly || IsChoiceOrFreeForm || Prompt.AllowFreeForm;

    private bool CanSubmit =>
        IsFreeFormOnly
            ? !string.IsNullOrWhiteSpace(_freeFormText)
            : HasAnyChoiceSelection || (ShowsFreeForm && !string.IsNullOrWhiteSpace(_freeFormText));

    private bool HasAnyChoiceSelection => _selectedValues.Count > 0 || !string.IsNullOrWhiteSpace(_singleChoice);

    protected override void OnParametersSet()
    {
        if (!string.Equals(_lastRequestId, Prompt.RequestId, StringComparison.Ordinal))
        {
            _lastRequestId = Prompt.RequestId;
            _freeFormText = string.Empty;
            _singleChoice = null;
            _selectedValues = [];
        }

        StartCountdownIfNeeded();
    }

    private void ToggleChoice(string value, bool isChecked)
    {
        if (isChecked)
            _selectedValues.Add(value);
        else
            _selectedValues.Remove(value);
    }

    private async Task SubmitAsync()
    {
        var selectedValues = IsSingleChoice
            ? (_singleChoice is null ? null : [_singleChoice])
            : (_selectedValues.Count == 0 ? null : _selectedValues.ToArray());

        var freeForm = string.IsNullOrWhiteSpace(_freeFormText) ? null : _freeFormText.Trim();
        await OnSubmit.InvokeAsync(new AskUserPromptSubmission(freeForm, selectedValues, false));
    }

    private async Task CancelAsync()
    {
        await OnSubmit.InvokeAsync(new AskUserPromptSubmission(null, null, true));
    }

    private void StartCountdownIfNeeded()
    {
        StopCountdown();

        if (Prompt.ExpiresAt is null)
        {
            _secondsRemaining = null;
            return;
        }

        _secondsRemaining = Math.Max(0, (int)Math.Ceiling((Prompt.ExpiresAt.Value - DateTimeOffset.UtcNow).TotalSeconds));
        _countdownCts = new CancellationTokenSource();
        _countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _ = RunCountdownAsync(_countdownCts.Token);
    }

    private async Task RunCountdownAsync(CancellationToken cancellationToken)
    {
        if (_countdownTimer is null || Prompt.ExpiresAt is null)
            return;

        try
        {
            while (await _countdownTimer.WaitForNextTickAsync(cancellationToken))
            {
                var remaining = Math.Max(0, (int)Math.Ceiling((Prompt.ExpiresAt.Value - DateTimeOffset.UtcNow).TotalSeconds));
                _secondsRemaining = remaining;
                await InvokeAsync(StateHasChanged);

                if (remaining > 0)
                    continue;

                StopCountdown();
                if (OnTimeout.HasDelegate)
                    await OnTimeout.InvokeAsync();
                break;
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private void StopCountdown()
    {
        _countdownCts?.Cancel();
        _countdownCts?.Dispose();
        _countdownCts = null;
        _countdownTimer?.Dispose();
        _countdownTimer = null;
    }

    public void Dispose()
    {
        StopCountdown();
    }

}
