<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>BotNexus.Gateway.Telemetry</RootNamespace>
    <Description>OpenTelemetry-free telemetry primitives for BotNexus: canonical Meter/ActivitySource names, the IMetrics facade, metric instruments, and the telemetry config binder. Carries no OpenTelemetry SDK package references so in-Gateway seams can reference the metrics facade without dragging the OpenTelemetry transitive dependency graph (and its stable Microsoft.Extensions.* pins) into consumers. The OpenTelemetry SDK wiring lives in the sibling BotNexus.Gateway.Telemetry project.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
  </ItemGroup>

</Project>
