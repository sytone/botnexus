<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RootNamespace>BotNexus.Gateway.Api</RootNamespace>
    <Description>ASP.NET Core API surface — REST controllers and SignalR hub for the BotNexus Gateway.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Exporter.Console" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" Version="1.15.1" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" Version="1.15.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Enrichers.Environment" Version="3.0.1" />
    <PackageReference Include="Serilog.Enrichers.Thread" Version="4.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
    <PackageReference Include="Serilog.Sinks.OpenTelemetry" Version="4.2.0" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\domain\BotNexus.Domain\BotNexus.Domain.csproj" />
    <ProjectReference Include="..\BotNexus.Gateway.Contracts\BotNexus.Gateway.Contracts.csproj" />
    <ProjectReference Include="..\BotNexus.Gateway\BotNexus.Gateway.csproj" />
    <ProjectReference Include="..\..\cron\BotNexus.Cron\BotNexus.Cron.csproj" />
    <ProjectReference Include="..\..\channels\BotNexus.Channels.Core\BotNexus.Channels.Core.csproj" />
    <ProjectReference Include="..\..\channels\BotNexus.Channels.SignalR\BotNexus.Channels.SignalR.csproj" />
    <ProjectReference Include="..\..\channels\BotNexus.Channels.SignalR.BlazorClient\BotNexus.Channels.SignalR.BlazorClient.csproj" />
    <ProjectReference Include="..\..\providers\BotNexus.Providers.Anthropic\BotNexus.Providers.Anthropic.csproj" />
    <ProjectReference Include="..\..\providers\BotNexus.Providers.OpenAI\BotNexus.Providers.OpenAI.csproj" />
    <ProjectReference Include="..\..\providers\BotNexus.Providers.OpenAICompat\BotNexus.Providers.OpenAICompat.csproj" />
    <ProjectReference Include="..\..\BotNexus.WebUI\BotNexus.WebUI.csproj" />
  </ItemGroup>

  <Target Name="CopyWebUI" AfterTargets="Build">
    <ItemGroup>
      <WebUIFiles Include="$(MSBuildProjectDirectory)\..\..\BotNexus.WebUI\wwwroot\**" />
    </ItemGroup>
    <Copy SourceFiles="@(WebUIFiles)" DestinationFolder="$(OutputPath)wwwroot\%(RecursiveDir)" SkipUnchangedFiles="true" />
  </Target>

  <Target Name="CopyWebUIPublish" AfterTargets="Publish">
    <ItemGroup>
      <WebUIPublishFiles Include="$(MSBuildProjectDirectory)\..\..\BotNexus.WebUI\wwwroot\**" />
    </ItemGroup>
    <Copy SourceFiles="@(WebUIPublishFiles)" DestinationFolder="$(PublishDir)wwwroot\%(RecursiveDir)" SkipUnchangedFiles="true" />
  </Target>

  <!-- Copy Blazor WASM client to wwwroot/blazor/ so it's served at /blazor/ -->
  <Target Name="CopyBlazorClient" AfterTargets="Build" DependsOnTargets="ResolveProjectReferences">
    <PropertyGroup>
      <BlazorClientRoot>$(MSBuildProjectDirectory)\..\..\channels\BotNexus.Channels.SignalR.BlazorClient\</BlazorClientRoot>
    </PropertyGroup>
    <ItemGroup>
      <BlazorWwwroot Include="$(BlazorClientRoot)wwwroot\**" />
      <BlazorFramework Include="$(BlazorClientRoot)bin\$(Configuration)\net10.0\wwwroot\**" />
    </ItemGroup>
    <Copy SourceFiles="@(BlazorWwwroot)" DestinationFolder="$(OutputPath)wwwroot\blazor\%(RecursiveDir)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="@(BlazorFramework)" DestinationFolder="$(OutputPath)wwwroot\blazor\%(RecursiveDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
