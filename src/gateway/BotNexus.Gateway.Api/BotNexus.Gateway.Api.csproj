<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <RootNamespace>BotNexus.Gateway.Api</RootNamespace>
    <Description>ASP.NET Core API surface — REST controllers and extension host for the BotNexus Gateway.</Description>
  </PropertyGroup>

  <ItemGroup>
