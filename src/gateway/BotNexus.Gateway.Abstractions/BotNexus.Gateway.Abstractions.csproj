<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>BotNexus.Gateway.Abstractions</RootNamespace>
    <Description>Core abstractions and extension point interfaces for the BotNexus Gateway Service.</Description>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\agent\BotNexus.Agent.Core\BotNexus.Agent.Core.csproj" />
    <ProjectReference Include="..\..\domain\BotNexus.Domain\BotNexus.Domain.csproj" />
    <ProjectReference Include="..\BotNexus.Gateway.Contracts\BotNexus.Gateway.Contracts.csproj" />
    <!-- OpenTelemetry-free metrics facade (IMetrics). Telemetry.Abstractions carries NO
         OpenTelemetry SDK package references, so referencing it here does not drag the OTel
         transitive graph into consumers (including BotNexus.Cli): #1852 NU1605 guard. -->
    <ProjectReference Include="..\BotNexus.Gateway.Telemetry.Abstractions\BotNexus.Gateway.Telemetry.Abstractions.csproj" />
    <!-- Shared durable usage-telemetry primitive (IUsageTelemetry, #1850). Reached transitively
         via BotNexus.Gateway already; referenced directly so the extension telemetry seam can
         expose a namespaced handle over the shared store. -->
    <ProjectReference Include="..\..\persistence\BotNexus.Persistence.Sqlite\BotNexus.Persistence.Sqlite.csproj" />
  </ItemGroup>

</Project>
