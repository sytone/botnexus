{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BotNexus": {
    "ExtensionsPath": "./extensions",
    "Providers": {
      "openai": { "ApiKey": "", "ApiBase": null }
    },
    "Channels": {
      "SendProgress": true,
      "SendToolHints": false,
      "SendMaxRetries": 3,
      "Instances": {}
    },
    "Tools": {
      "RestrictToWorkspace": false,
      "Exec": { "Enable": true, "Timeout": 60 },
      "Web": { "Search": { "Provider": "brave", "ApiKey": "", "MaxResults": 5 } },
      "Extensions": {},
      "McpServers": {}
    }
  },
  "AllowedHosts": "*"
}
