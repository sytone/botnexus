<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>BotNexus.Persistence.Sqlite</RootNamespace>
    <Description>Shared SQLite persistence helpers - filesystem-aware journal-mode maintenance (bounded WAL with network-mount rollback fallback) and checkpoint utilities used by all BotNexus SQLite stores.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.Sqlite" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="TestableIO.System.IO.Abstractions.Wrappers" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="BotNexus.Persistence.Sqlite.Tests" />
  </ItemGroup>

</Project>
