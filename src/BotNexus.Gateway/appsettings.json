{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "BotNexus": {
    "ExtensionsPath": "./extensions",
    "Agents": {
      "Workspace": "~/.botnexus/workspace",
      "Model": "gpt-4o",
      "MaxTokens": 8192,
      "ContextWindowTokens": 65536,
      "Temperature": 0.1,
      "MaxToolIterations": 40,
      "Timezone": "UTC",
      "Named": {}
    },
    "Providers": {
      "openai": { "ApiKey": "", "ApiBase": null },
      "anthropic": { "ApiKey": "", "ApiBase": null },
      "azure-openai": { "ApiKey": "", "ApiBase": null }
    },
    "Channels": {
      "SendProgress": true,
      "SendToolHints": false,
      "SendMaxRetries": 3,
      "Instances": {
        "telegram": { "Enabled": false, "BotToken": "", "AllowFrom": [] },
        "discord": { "Enabled": false, "BotToken": "", "AllowFrom": [] },
        "slack": { "Enabled": false, "BotToken": "", "AllowFrom": [] }
      }
    },
    "Gateway": {
      "Host": "0.0.0.0",
      "Port": 18790,
      "WebSocketEnabled": true,
      "WebSocketPath": "/ws",
      "Heartbeat": { "Enabled": true, "IntervalSeconds": 1800 }
    },
    "Tools": {
      "RestrictToWorkspace": false,
      "Exec": { "Enable": true, "Timeout": 60 },
      "Web": { "Search": { "Provider": "brave", "ApiKey": "", "MaxResults": 5 } },
      "Extensions": {},
      "McpServers": {
        "filesystem": {
          "Command": "npx",
          "Args": [ "-y", "@modelcontextprotocol/server-filesystem", "/tmp" ],
          "Env": {},
          "ToolTimeout": 30,
          "EnabledTools": [ "*" ]
        },
        "github-mcp": {
          "Type": "Sse",
          "Url": "http://localhost:3001/sse",
          "Headers": { "Authorization": "Bearer <token>" },
          "ToolTimeout": 30,
          "EnabledTools": [ "*" ]
        }
      }
    },
    "Api": {
      "Host": "127.0.0.1",
      "Port": 8900,
      "Timeout": 120.0,
      "Enabled": false
    }
  }
}
