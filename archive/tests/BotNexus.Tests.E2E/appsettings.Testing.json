{
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "BotNexus": {
    "ExtensionsPath": "./extensions",
    "Agents": {
      "Workspace": "./test-workspace",
      "Model": "mock-model",
      "MaxTokens": 1024,
      "ContextWindowTokens": 4096,
      "Temperature": 0.0,
      "MaxToolIterations": 5,
      "Timezone": "UTC",
      "Named": {
        "nova": {
          "Name": "nova",
          "SystemPrompt": "You are Nova, a research and Q&A agent.",
          "Provider": "mock"
        },
        "quill": {
          "Name": "quill",
          "SystemPrompt": "You are Quill, a note-taking agent.",
          "Provider": "mock"
        },
        "bolt": {
          "Name": "bolt",
          "SystemPrompt": "You are Bolt, a calculator agent.",
          "Provider": "mock"
        },
        "echo": {
          "Name": "echo",
          "SystemPrompt": "You are Echo, a repeater agent.",
          "Provider": "mock"
        },
        "sage": {
          "Name": "sage",
          "SystemPrompt": "You are Sage, a summarizer agent.",
          "Provider": "mock"
        }
      }
    },
    "Providers": {},
    "Channels": {
      "SendProgress": false,
      "SendToolHints": false,
      "SendMaxRetries": 1,
      "Instances": {}
    },
    "Gateway": {
      "Host": "127.0.0.1",
      "Port": 0,
      "ApiKey": "",
      "WebSocketEnabled": true,
      "WebSocketPath": "/ws",
      "DefaultAgent": "nova",
      "BroadcastWhenAgentUnspecified": false,
      "Heartbeat": { "Enabled": false, "IntervalSeconds": 86400 }
    },
    "Tools": {
      "RestrictToWorkspace": false,
      "Extensions": {}
    },
    "Api": {
      "Enabled": false
    }
  }
}
