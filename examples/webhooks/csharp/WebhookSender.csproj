<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Self-contained BotNexus webhook sender example.

    Run it directly against a running gateway:

        dotnet run

    Configuration is read from environment variables (see WebhookSender.cs):
        BOTNEXUS_BASE_URL   (default http://localhost:5000)
        BOTNEXUS_AGENT_ID   (default farnsworth)
        BOTNEXUS_API_TOKEN  (optional bearer token for management endpoints)
        BOTNEXUS_WEBHOOK_SECRET / BOTNEXUS_WEBHOOK_ID  (optional: reuse a secret)

    No external NuGet packages — only in-framework HttpClient, HMACSHA256,
    and System.Text.Json.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>BotNexus.Examples.Webhooks</RootNamespace>
    <AssemblyName>WebhookSender</AssemblyName>
    <!-- Stand-alone example; intentionally excluded from the solution build. -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

</Project>
